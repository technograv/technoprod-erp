    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Handler personnalisé pour l'upload d'images dans le WYSIWYG
        function imageHandler() {
            const currentEditor = this.quill;
            showImageDimensionsModal(currentEditor);
        }

        // Configuration des éditeurs WYSIWYG
        const quillOptions = {
            theme: 'snow',
            placeholder: '',
            modules: {
                toolbar: {
                    container: null, // Sera défini pour chaque éditeur
                    handlers: {
                        'image': imageHandler
                    }
                }
            }
        };

        // Initialisation de l'éditeur pour note publique
        const optionsNotePublique = {...quillOptions};
        optionsNotePublique.modules.toolbar.container = '#toolbar-note-publique';
        optionsNotePublique.placeholder = 'Cette note sera visible sur le devis envoyé au client...';
        
        const quillNotePublique = new Quill('#editor-note-publique', optionsNotePublique);

        // Initialisation de l'éditeur pour note privée
        const optionsNotePrivee = {...quillOptions};
        optionsNotePrivee.modules.toolbar.container = '#toolbar-note-privee';
        optionsNotePrivee.placeholder = 'Notes internes, remarques pour l\'équipe...';
        
        const quillNotePrivee = new Quill('#editor-note-privee', optionsNotePrivee);

        // Synchronisation des éditeurs avec les champs cachés du formulaire
        quillNotePublique.on('text-change', function() {
            const content = quillNotePublique.root.innerHTML;
            document.getElementById('note_publique').value = content === '<p><br></p>' ? '' : content;
        });

        quillNotePrivee.on('text-change', function() {
            const content = quillNotePrivee.root.innerHTML;
            document.getElementById('note_privee').value = content === '<p><br></p>' ? '' : content;
        });

        // Nettoyer le contenu placeholder au premier focus
        quillNotePublique.on('selection-change', function(range) {
            if (range && quillNotePublique.getText().trim() === 'Cette note sera visible sur le devis envoyé au client...') {
                quillNotePublique.setText('');
            }
        });

        quillNotePrivee.on('selection-change', function(range) {
            if (range && quillNotePrivee.getText().trim() === 'Notes internes, remarques pour l\'équipe...') {
                quillNotePrivee.setText('');
            }
        });

        // Validation avant soumission du formulaire
        document.getElementById('devis-form').addEventListener('submit', function() {
            // S'assurer que les champs cachés sont à jour
            const contentPublique = quillNotePublique.root.innerHTML;
            const contentPrivee = quillNotePrivee.root.innerHTML;
            
            document.getElementById('note_publique').value = contentPublique === '<p><br></p>' ? '' : contentPublique;
            document.getElementById('note_privee').value = contentPrivee === '<p><br></p>' ? '' : contentPrivee;
        });

        // Correction forcée des largeurs des dropdowns après initialisation
        setTimeout(() => {
            // Pour la note publique
            const fontPickerPublique = document.querySelector('#toolbar-note-publique .ql-font .ql-picker');
            const sizePickerPublique = document.querySelector('#toolbar-note-publique .ql-size .ql-picker');
            
            if (fontPickerPublique) {
                fontPickerPublique.style.width = '180px';
                fontPickerPublique.style.minWidth = '180px';
                fontPickerPublique.style.maxWidth = '180px';
            }
            
            if (sizePickerPublique) {
                sizePickerPublique.style.width = '140px';
                sizePickerPublique.style.minWidth = '140px';
                sizePickerPublique.style.maxWidth = '140px';
            }

            // Pour la note privée
            const fontPickerPrivee = document.querySelector('#toolbar-note-privee .ql-font .ql-picker');
            const sizePickerPrivee = document.querySelector('#toolbar-note-privee .ql-size .ql-picker');
            
            if (fontPickerPrivee) {
                fontPickerPrivee.style.width = '180px';
                fontPickerPrivee.style.minWidth = '180px';
                fontPickerPrivee.style.maxWidth = '180px';
            }
            
            if (sizePickerPrivee) {
                sizePickerPrivee.style.width = '140px';
                sizePickerPrivee.style.minWidth = '140px';
                sizePickerPrivee.style.maxWidth = '140px';
            }
        }, 500); // Délai pour s'assurer que Quill.js a fini son initialisation

        // Fonction pour afficher la modal de choix des dimensions d'image
        function showImageDimensionsModal(targetEditor = null) {
            const modalHtml = `
                <div class="modal fade" id="imageDimensionsModal" tabindex="-1" aria-labelledby="imageDimensionsModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="imageDimensionsModalLabel">
                                    <i class="fas fa-image me-2"></i>Insérer une image
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <!-- Section upload d'image -->
                                <div class="mb-4">
                                    <label for="imageFileInput" class="form-label">
                                        <i class="fas fa-upload me-2"></i>Sélectionner une image
                                    </label>
                                    <input type="file" class="form-control" id="imageFileInput" accept="image/*">
                                </div>
                                
                                <!-- Prévisualisation de l'image -->
                                <div id="imagePreviewContainer" class="text-center mb-4" style="display: none;">
                                    <img id="imagePreview" class="img-thumbnail" style="max-width: 300px; max-height: 200px;">
                                    <p id="imageInfo" class="mt-2 text-muted"></p>
                                </div>
                                
                                <!-- Section dimensions -->
                                <div id="dimensionsSection" style="display: none;">
                                    <h6><i class="fas fa-expand-arrows-alt me-2"></i>Dimensions de l'image</h6>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="imageWidth" class="form-label">Largeur (px)</label>
                                            <input type="number" class="form-control" id="imageWidth" value="300" min="50" max="800">
                                        </div>
                                        <div class="col-md-6">
                                            <label for="imageHeight" class="form-label">Hauteur (px)</label>
                                            <input type="number" class="form-control" id="imageHeight" value="200" min="50" max="600">
                                        </div>
                                    </div>
                                    
                                    <div class="row mt-3">
                                        <div class="col-12">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="maintainAspectRatio" checked>
                                                <label class="form-check-label" for="maintainAspectRatio">
                                                    Conserver les proportions originales
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row mt-3">
                                        <div class="col-12">
                                            <label class="form-label">Dimensions prédéfinies :</label>
                                            <div class="btn-group w-100" role="group">
                                                <button type="button" class="btn btn-outline-secondary preset-size" data-width="150">Petite</button>
                                                <button type="button" class="btn btn-outline-secondary preset-size" data-width="300">Moyenne</button>
                                                <button type="button" class="btn btn-outline-secondary preset-size" data-width="450">Grande</button>
                                                <button type="button" class="btn btn-outline-secondary preset-size" data-width="100%">Pleine largeur</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </button>
                                <button type="button" class="btn btn-primary" id="insertImageIntoEditorBtn" style="display: none;">
                                    <i class="fas fa-check me-2"></i>Insérer l'image
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            // Supprimer la modal existante si elle existe
            const existingModal = document.getElementById('imageDimensionsModal');
            if (existingModal) {
                existingModal.remove();
            }
            
            // Ajouter la modal au DOM
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            
            // Attacher les événements
            const modal = new bootstrap.Modal(document.getElementById('imageDimensionsModal'));
            const fileInput = document.getElementById('imageFileInput');
            const preview = document.getElementById('imagePreview');
            const previewContainer = document.getElementById('imagePreviewContainer');
            const dimensionsSection = document.getElementById('dimensionsSection');
            const widthInput = document.getElementById('imageWidth');
            const heightInput = document.getElementById('imageHeight');
            const aspectRatioCheck = document.getElementById('maintainAspectRatio');
            const insertBtn = document.getElementById('insertImageIntoEditorBtn');
            const imageInfo = document.getElementById('imageInfo');
            
            let originalRatio = 1;
            let imageFile = null;
            let imageDataUrl = null;
            
            // Gestion de la sélection de fichier
            fileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (!file) return;
                
                imageFile = file;
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    imageDataUrl = e.target.result;
                    preview.src = imageDataUrl;
                    
                    // Calculer le ratio réel de l'image
                    const tempImg = new Image();
                    tempImg.onload = function() {
                        originalRatio = this.naturalWidth / this.naturalHeight;
                        const naturalWidth = this.naturalWidth;
                        const naturalHeight = this.naturalHeight;
                        
                        // Définir une taille par défaut raisonnable
                        let defaultWidth = Math.min(300, naturalWidth);
                        if (defaultWidth < 150) defaultWidth = naturalWidth; // Petites images gardent leur taille
                        
                        widthInput.value = defaultWidth;
                        heightInput.value = Math.round(defaultWidth / originalRatio);
                        
                        // Afficher les informations de l'image
                        const sizeKB = Math.round(file.size / 1024);
                        imageInfo.textContent = file.name + ' - ' + naturalWidth + ' × ' + naturalHeight + 'px (' + sizeKB + ' KB)';
                        
                        // Afficher la prévisualisation et les options
                        previewContainer.style.display = 'block';
                        dimensionsSection.style.display = 'block';
                        insertBtn.style.display = 'inline-block';
                    };
                    tempImg.src = imageDataUrl;
                };
                
                reader.readAsDataURL(file);
            });
            
            // Gestion du maintien des proportions
            widthInput.addEventListener('input', function() {
                if (aspectRatioCheck.checked && originalRatio) {
                    heightInput.value = Math.round(this.value / originalRatio);
                }
            });
            
            heightInput.addEventListener('input', function() {
                if (aspectRatioCheck.checked && originalRatio) {
                    widthInput.value = Math.round(this.value * originalRatio);
                }
            });
            
            // Gestion des tailles prédéfinies
            document.querySelectorAll('.preset-size').forEach(btn => {
                btn.addEventListener('click', function() {
                    const width = this.dataset.width;
                    
                    if (width === '100%') {
                        widthInput.value = '';
                        heightInput.value = '';
                        widthInput.placeholder = '100%';
                        heightInput.placeholder = 'auto';
                    } else {
                        const widthNum = parseInt(width);
                        widthInput.value = widthNum;
                        // CORRECTION: Toujours calculer la hauteur selon le ratio de l'image originale
                        if (originalRatio && originalRatio > 0) {
                            heightInput.value = Math.round(widthNum / originalRatio);
                        } else {
                            // Fallback si pas de ratio disponible
                            heightInput.value = Math.round(widthNum * 0.67); // Ratio 3:2 par défaut
                        }
                        widthInput.placeholder = '';
                        heightInput.placeholder = '';
                    }
                    
                    // Marquer le bouton comme actif temporairement
                    document.querySelectorAll('.preset-size').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    setTimeout(() => this.classList.remove('active'), 1000);
                });
            });
            
            // Bouton d'insertion
            insertBtn.addEventListener('click', function() {
                const editorToUse = targetEditor;
                if (!imageDataUrl || !editorToUse) return;
                
                const width = widthInput.value || widthInput.placeholder;
                const height = heightInput.value || heightInput.placeholder;
                
                // Insérer l'image avec les dimensions choisies
                const range = editorToUse.getSelection(true);
                
                // Insérer via l'API Quill avec les attributs appropriés
                const imageBlot = editorToUse.insertEmbed(range.index, 'image', imageDataUrl);
                
                // Après insertion, modifier directement l'élément DOM dans l'éditeur
                setTimeout(() => {
                    const insertedImages = editorToUse.root.querySelectorAll('img[src="' + imageDataUrl + '"]');
                    const lastInsertedImage = insertedImages[insertedImages.length - 1];
                    
                    if (lastInsertedImage) {
                        // Appliquer les styles directement sur l'image insérée
                        if (width === '100%' || width === '') {
                            lastInsertedImage.style.maxWidth = '100%';
                            lastInsertedImage.style.height = 'auto';
                            lastInsertedImage.style.width = '100%';
                        } else {
                            if (width) {
                                lastInsertedImage.style.width = width + 'px';
                                lastInsertedImage.style.maxWidth = width + 'px';
                            }
                            if (height && height !== 'auto') {
                                lastInsertedImage.style.height = height + 'px';
                            } else {
                                lastInsertedImage.style.height = 'auto';
                            }
                        }
                        
                        // Styles additionnels pour l'affichage dans l'éditeur
                        lastInsertedImage.style.display = 'inline-block';
                        lastInsertedImage.style.verticalAlign = 'middle';
                        lastInsertedImage.alt = imageFile.name;
                        
                        console.log('✅ Image redimensionnée dans l\'éditeur:', lastInsertedImage.style.cssText);
                    }
                }, 100);
                
                // Fermer la modal
                modal.hide();
            });
            
            // Nettoyer la modal après fermeture
            document.getElementById('imageDimensionsModal').addEventListener('hidden.bs.modal', function() {
                this.remove();
            });
            
            // Afficher la modal
            modal.show();
        }
    });
    </script>
{% endblock %}