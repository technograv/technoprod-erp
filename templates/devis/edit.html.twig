                                }
                                
                                if (sourceDropdown === 'livraison') {
                                    const originalFacturationAddr = window.preCreateValues?.facturationAddress || finalFacturationAddr;
                                    
                                    if (originalFacturationAddr && currentFacturationAddr !== originalFacturationAddr) {
