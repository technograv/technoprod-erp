                                facturation: finalFacturationAddr
                            });
                            
                            window.devisContactService.reloadAddresses = window.devisContactService._originalHandlers.reloadAddresses;
                            window.devisContactService.reloadContacts = window.devisContactService._originalHandlers.reloadContacts;
                            window.devisContactService.handleAddressChange = window.devisContactService._originalHandlers.handleAddressChange;
                            window.devisContactService.populateContacts = window.devisContactService._originalHandlers.populateContacts;
                            window.devisContactService.handleClientChange = window.devisContactService._originalHandlers.handleClientChange;
                            if (window.devisContactService._originalHandlers.populateAddresses) {
                                window.devisContactService.populateAddresses = window.devisContactService._originalHandlers.populateAddresses;
                            }
                            delete window.devisContactService._originalHandlers;
                            console.log('✅ DevisContactService réactivé');
                            
                            // 🛡️ VÉRIFICATION POST-RÉACTIVATION: Restaurer si écrasé
                            setTimeout(() => {
