// ==========================================
// SAUVEGARDE AUTOMATIQUE DES TOTAUX
// ==========================================

function saveDevisTotalsAutomatically(totalHt, totalTva, totalTtc) {
    // Debounce pour éviter trop d'appels
    if (window.saveDevisTotalsTimeout) {
        clearTimeout(window.saveDevisTotalsTimeout);
    }
    
    window.saveDevisTotalsTimeout = setTimeout(async () => {
        try {
            // Récupérer les valeurs de remise et acompte actuelles
            let remisePercent = document.getElementById('remise-percent-main') || document.getElementById('devis_remiseGlobalePercent');
            let remiseMontant = document.getElementById('remise-montant-main') || document.getElementById('devis_remiseGlobaleMontant');
            let acomptePercent = document.getElementById('devis_acomptePercent');
            let acompteMontant = document.getElementById('devis_acompteMontant');
            
            const response = await fetch(`/devis/${DEVIS_ID}/update-totals`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    totalHt: totalHt.toFixed(2),
                    totalTva: totalTva.toFixed(2),
                    totalTtc: totalTtc.toFixed(2),
                    remiseGlobalePercent: parseFloat(remisePercent?.value || 0),
                    remiseGlobaleMontant: parseFloat(remiseMontant?.value || 0),
                    acomptePercent: parseFloat(acomptePercent?.value || 0),
                    acompteMontant: parseFloat(acompteMontant?.value || 0)
                })
            });
            
            if (!response.ok) {
                console.warn('Erreur sauvegarde automatique totaux:', response.status);
            } else {
                console.log('💾 Totaux + remise + acompte sauvés automatiquement - HT:', totalHt.toFixed(2), '€, TTC:', totalTtc.toFixed(2), '€, Remise:', remisePercent?.value || 0, '%, Acompte:', acomptePercent?.value || 0, '%');
            }
        } catch (error) {
            console.warn('Erreur réseau sauvegarde totaux:', error);
        }
    }, 1000); // Attendre 1 seconde après le dernier changement
}

// ==========================================
// GESTION REMISE GLOBALE
// ==========================================

function initGlobalRemise() {
    console.log('initGlobalRemise appelée');
    
    // Essayons de trouver les vrais IDs générés par Symfony
    let remisePercent = document.getElementById('remise-percent-main');
    let remiseMontant = document.getElementById('remise-montant-main');
    
    // Si pas trouvés avec nos IDs, cherchons avec les IDs Symfony standards
    if (!remisePercent) {
        remisePercent = document.getElementById('devis_remiseGlobalePercent');
    }
    if (!remiseMontant) {
        remiseMontant = document.getElementById('devis_remiseGlobaleMontant');
    }
    
    if (!remisePercent || !remiseMontant) {
        return;
    }
    
    let totalHt = 0;
    
    // Fonction pour mettre à jour le total HT SANS synchronisation automatique
    window.updateTotalHtForRemise = function(ht) {
        totalHt = ht;
        console.log('Total HT mis à jour:', totalHt);
        // PAS de synchronisation automatique - laissons l'utilisateur saisir librement
    };
    
    // SIMPLE: Synchroniser uniquement quand on QUITTE le champ
    remisePercent.addEventListener('blur', function() {
        if (this.value && totalHt > 0) {
            const percent = parseFloat(this.value) || 0;
            const montant = (totalHt * percent / 100);
            remiseMontant.value = montant.toFixed(2);
        }
        calculateTotals();
    });
    
    remiseMontant.addEventListener('blur', function() {
        if (this.value && totalHt > 0) {
            const montant = parseFloat(this.value) || 0;
            const percent = (montant / totalHt * 100);
            remisePercent.value = percent.toFixed(1);
        }
        calculateTotals();
    });
    
    // Juste recalculer les totaux pendant la saisie
    remisePercent.addEventListener('input', calculateTotals);
    remiseMontant.addEventListener('input', calculateTotals);
    

    // Event listeners pour détecter quand les champs sont vidés manuellement
    remisePercent.addEventListener('keyup', function() {
        if (this.value === '' || this.value === '0') {
            remiseMontant.value = '';
            calculateTotals();
        }
    });
    
    remiseMontant.addEventListener('keyup', function() {
        if (this.value === '' || this.value === '0') {
            remisePercent.value = '';
            calculateTotals();
        }
    });
    
    // ===== FONCTION CALCUL TOTAL TTC FINAL (pour acompte) =====
    function calculateFinalTotalTtc() {
        const productElements = elements.filter(e => e.is_product);
        
        let totalHt = 0;
        let totalTva = 0;
        
        // Calculer le total HT et TVA de base
        productElements.forEach(element => {
            const quantite = parseFloat(element.quantite || 1);
            const prixUnitaire = parseFloat(element.prix_unitaire_ht || 0);
            const remisePercent = parseFloat(element.remise_percent || 0);
            const tvaPercent = parseFloat(element.tva_percent || 0);
            
            const lineHt = quantite * prixUnitaire * (1 - remisePercent / 100);
            
            totalHt += lineHt;
            totalTva += lineHt * (tvaPercent / 100);
        });
        
        // Appliquer la remise globale
        let remisePercentEl = document.getElementById('remise-percent-main') || document.getElementById('devis_remiseGlobalePercent');
        let remiseMontantEl = document.getElementById('remise-montant-main') || document.getElementById('devis_remiseGlobaleMontant');
        
        const remisePercent = parseFloat(remisePercentEl?.value || 0);
        const remiseMontantSaisie = parseFloat(remiseMontantEl?.value || 0);
        
        let remiseMontant = 0;
        if (remisePercent > 0) {
            remiseMontant = totalHt * (remisePercent / 100);
        } else if (remiseMontantSaisie > 0) {
            remiseMontant = remiseMontantSaisie;
        }
        
        const totalHtRemise = totalHt - remiseMontant;
        const totalTvaRemise = totalHtRemise * (totalTva / totalHt || 0); // Proportionnelle
        const totalTtc = totalHtRemise + totalTvaRemise;
        
        return totalTtc;
    }
    
    // ===== GESTION ACOMPTE (même logique simple) =====
    const acomptePercent = document.getElementById('devis_acomptePercent');
    const acompteMontant = document.getElementById('devis_acompteMontant');
    
    if (acomptePercent && acompteMontant) {
        console.log('🏦 Initialisation gestion acompte');
        
        // Synchroniser le montant quand on sort du champ pourcentage
        acomptePercent.addEventListener('blur', function() {
            // Calculer le total TTC après remise pour l'acompte
            const totalTtcApresRemise = calculateFinalTotalTtc();
            if (this.value && totalTtcApresRemise > 0) {
                const percent = parseFloat(this.value) || 0;
                const montant = (totalTtcApresRemise * percent / 100);
                acompteMontant.value = montant.toFixed(2);
                console.log('💰 Acompte montant calculé sur TTC après remise:', montant.toFixed(2), '€ (', percent, '% de', totalTtcApresRemise.toFixed(2), '€)');
            }
            calculateTotals();
        });
        
        // Synchroniser le pourcentage quand on sort du champ montant
        acompteMontant.addEventListener('blur', function() {
            // Calculer le total TTC après remise pour l'acompte
            const totalTtcApresRemise = calculateFinalTotalTtc();
            if (this.value && totalTtcApresRemise > 0) {
                const montant = parseFloat(this.value) || 0;
                const percent = (montant / totalTtcApresRemise * 100);
                acomptePercent.value = percent.toFixed(1);
                console.log('📊 Acompte pourcentage calculé sur TTC après remise:', percent.toFixed(1), '% (', montant.toFixed(2), '€ sur', totalTtcApresRemise.toFixed(2), '€)');
            }
            calculateTotals();
        });
        
        // Recalculer les totaux pendant la saisie (sans synchronisation)
        acomptePercent.addEventListener('input', calculateTotals);
        acompteMontant.addEventListener('input', calculateTotals);
        
        // Vider l'autre champ si on vide manuellement
        acomptePercent.addEventListener('keyup', function() {
            if (this.value === '' || this.value === '0') {
                acompteMontant.value = '';
                calculateTotals();
            }
        });

        acompteMontant.addEventListener('keyup', function() {
            if (this.value === '' || this.value === '0') {
                acomptePercent.value = '';
                calculateTotals();
            }
        });
    }
}

