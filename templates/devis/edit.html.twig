                                            source: window.preCreateValues ? 'preCreate' : 'final'
                                        });
                                        
                                        if (livraisonSelectAddr) {
                                            livraisonSelectAddr.value = originalLivraisonAddr;
                                            console.log('✅ Adresse livraison restaurée');
                                        }
                                    }
                                    
                                    // Nettoyer les valeurs sauvegardées
                                    if (window.preCreateValues) {
                                        delete window.preCreateValues;
                                        console.log('🧹 Valeurs pre-create nettoyées');
