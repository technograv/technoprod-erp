async function loadClientContactsAndAddresses(clientId) {
    try {
        // Charger les contacts
        const contactsResponse = await fetch(`/client/${clientId}/contacts`);
        const contactsData = await contactsResponse.json();
        
        // Charger les adresses
        const addressesResponse = await fetch(`/client/${clientId}/addresses`);  
        const addressesData = await addressesResponse.json();

        // Stocker les données pour la synchronisation
        window.clientContacts = contactsData;
        window.clientAddresses = addressesData;

        // Peupler les dropdowns
        populateContacts(contactsData);
        populateAddresses(addressesData);
        
        // Synchroniser l'email si un contact de livraison est déjà sélectionné
        const contactLivraisonSelect = document.getElementById('devis_contactLivraison');
        if (contactLivraisonSelect && contactLivraisonSelect.value) {
            setTimeout(() => {
                syncContactEmail(contactLivraisonSelect.value);
            }, 100);
        }

    } catch (error) {
        console.error('Erreur chargement contacts/adresses:', error);
    }
}

function populateContacts(contacts) {
    const contactFacturationSelect = document.getElementById('devis_contactFacturation');
    const contactLivraisonSelect = document.getElementById('devis_contactLivraison');

    // Facturation
    if (contactFacturationSelect) {
        const currentValue = contactFacturationSelect.value;
        const initialValue = contactFacturationSelect.getAttribute('data-initial-value');
        const valueToUse = currentValue || initialValue;
        
        contactFacturationSelect.innerHTML = '<option value="">Sélectionner un contact...</option>';
        
        let defaultFacturationContact = null;
        contacts.forEach(contact => {
            const option = document.createElement('option');
            option.value = contact.id;
            option.textContent = contact.label || ((contact.civilite || '') + ' ' + (contact.prenom || '') + ' ' + (contact.nom || '')).trim();
            
            // Ordre de priorité: valeur existante > valeur initiale du devis > contact par défaut
            if (contact.id == valueToUse) {
                option.selected = true;
            } else if (!valueToUse && contact.is_facturation_default) {
                defaultFacturationContact = contact;
                option.selected = true;
            }
            
            contactFacturationSelect.appendChild(option);
        });
        
        // Mettre à jour la valeur si on a sélectionné un contact
        if (contactFacturationSelect.value) {
            contactFacturationSelect.value = contactFacturationSelect.value;
        }
    }

    // Livraison
    if (contactLivraisonSelect) {
        const currentValue = contactLivraisonSelect.value;
        const initialValue = contactLivraisonSelect.getAttribute('data-initial-value');
        const valueToUse = currentValue || initialValue;
        
        contactLivraisonSelect.innerHTML = '<option value="">Sélectionner un contact...</option>';
        
        let defaultLivraisonContact = null;
        contacts.forEach(contact => {
            const option = document.createElement('option');
            option.value = contact.id;
            option.textContent = contact.label || ((contact.civilite || '') + ' ' + (contact.prenom || '') + ' ' + (contact.nom || '')).trim();
            
            // Ordre de priorité: valeur existante > valeur initiale du devis > contact par défaut
            if (contact.id == valueToUse) {
                option.selected = true;
            } else if (!valueToUse && contact.is_livraison_default) {
                defaultLivraisonContact = contact;
                option.selected = true;
            }
            
            contactLivraisonSelect.appendChild(option);
        });
        
        // Mettre à jour la valeur si on a sélectionné un contact
        if (contactLivraisonSelect.value) {
            contactLivraisonSelect.value = contactLivraisonSelect.value;
        }
        
        // Synchroniser l'email et déclencher les événements si des contacts sont sélectionnés automatiquement
        if ((!currentValue && !initialValue && defaultLivraisonContact) || (valueToUse && contactLivraisonSelect.value)) {
            setTimeout(() => {
                if (contactLivraisonSelect.value) {
                    syncContactEmail(contactLivraisonSelect.value);
                    contactLivraisonSelect.dispatchEvent(new Event('change'));
                }
            }, 100);
        }
    }
    
    // Déclencher l'événement change sur le contact de facturation si sélectionné automatiquement
    if (contactFacturationSelect && !contactFacturationSelect.dataset.currentValue && contactFacturationSelect.value) {
        setTimeout(() => {
            contactFacturationSelect.dispatchEvent(new Event('change'));
        }, 100);
    }
}

function populateAddresses(addresses) {
    const adresseFacturationSelect = document.getElementById('devis_adresseFacturation');
    const adresseLivraisonSelect = document.getElementById('devis_adresseLivraison');

    [adresseFacturationSelect, adresseLivraisonSelect].forEach(select => {
        if (!select) return;
        
        const currentValue = select.value;
        const initialValue = select.getAttribute('data-initial-value');
        const valueToUse = currentValue || initialValue;
        
        select.innerHTML = '<option value="">Sélectionner une adresse...</option>';
        
        addresses.forEach(address => {
            const option = document.createElement('option');
            option.value = address.id;
            
            // Utiliser le label de l'API ou construire à partir des données
            if (address.label) {
                option.textContent = address.label;
            } else {
                // Construire l'affichage avec vérification des champs
                let displayText = '';
                if (address.adresse && address.adresse.trim()) {
                    displayText += address.adresse.trim();
                }
                if (address.codePostal && address.codePostal.trim()) {
                    displayText += (displayText ? ', ' : '') + address.codePostal.trim();
                }
                if (address.ville && address.ville.trim()) {
                    displayText += (displayText && !address.codePostal ? ', ' : ' ') + address.ville.trim();
                }
                
                // Si aucune info, utiliser l'ID
                if (!displayText) {
                    displayText = `Adresse #${address.id}`;
                }
                
                option.textContent = displayText;
            }
            
            if (address.id == valueToUse) {
                option.selected = true;
            }
            select.appendChild(option);
        });
    });
}

function syncContactAddress(contactId, adresseSelect) {
    // Utiliser les données déjà chargées plutôt qu'une nouvelle API
    if (!window.clientContacts) {
        console.log('Pas de contacts chargés');
        return;
    }
    
    // Trouver le contact sélectionné
    const selectedContact = window.clientContacts.find(contact => contact.id == contactId);
    if (!selectedContact) {
        console.log('Contact non trouvé:', contactId);
        return;
    }
    
    console.log('Contact trouvé:', selectedContact);
    
    // Si le contact a une adresse associée, la sélectionner
    if (selectedContact.adresse_id) {
        console.log('Sélection de l\'adresse:', selectedContact.adresse_id);
        adresseSelect.value = selectedContact.adresse_id;
    } else {
        console.log('Aucune adresse associée au contact');
    }
}

function syncContactEmail(contactId, forceSync = false) {
    // ⚠️ DÉSACTIVÉ : DevisContactService gère maintenant cette logique
    if (window.devisContactServiceActive) {
        console.log('🛑 syncContactEmail() désactivé - DevisContactService actif');
        return;
    }
    
    console.log('🔧 syncContactEmail appelée avec contactId:', contactId, 'forceSync:', forceSync);
    
    // 🛡️ PROTECTION GLOBALE: Ne pas synchroniser pendant la création d'un contact de facturation
    if (window.lastContactAction && window.lastContactAction.source === 'facturation' && !forceSync) {
        console.log('🚫 Synchronisation email bloquée - Création contact facturation en cours');
        return;
    }
    
    // ⚠️ PROTECTION: Ne synchroniser l'email QUE si c'est le contact de LIVRAISON qui change
    // SAUF si on force la synchronisation (forceSync = true)
    if (!forceSync) {
        const livraisonSelect = document.getElementById('devis_contactLivraison');
        const isLivraisonContact = livraisonSelect && livraisonSelect.value == contactId;
        
        if (!isLivraisonContact) {
            console.log('🚫 Synchronisation email ignorée - Ce n\'est pas le contact de livraison');
            return;
        }
    }
    
    // Utiliser les données déjà chargées pour synchroniser l'email
    if (!window.clientContacts) {
        console.log('❌ window.clientContacts pas disponible');
        return;
    }
    
    console.log('✅ window.clientContacts disponible:', window.clientContacts.length, 'contacts');
    
    const emailDisplayField = document.getElementById('devis_emailEnvoiAutomatique');
    if (!emailDisplayField) {
        console.log('❌ Champ devis_emailEnvoiAutomatique introuvable');
        return;
    }
    
    console.log('✅ Champ email trouvé');
    
    // Trouver le contact sélectionné
    const selectedContact = window.clientContacts.find(contact => contact.id == contactId);
    if (!selectedContact) {
        console.log('❌ Contact non trouvé pour ID:', contactId);
        console.log('📋 Contacts disponibles:', window.clientContacts.map(c => ({id: c.id, nom: c.nom, email: c.email})));
        emailDisplayField.value = '';
        // updateHiddenEmailField(''); // Fonction supprimée car non nécessaire
        return;
    }
    
    console.log('✅ Contact trouvé:', selectedContact.nom, 'Email:', selectedContact.email);
    
    // Mettre à jour le champ email avec l'email du contact
    if (selectedContact.email) {
        console.log('📧 Mise à jour email:', selectedContact.email);
        emailDisplayField.value = selectedContact.email;
    } else {
        console.log('❌ Pas d\'email pour ce contact');
        emailDisplayField.value = '';
    }
}

