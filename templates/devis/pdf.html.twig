{% set couleurPrimaire = societe and societe.couleurPrimaire ? societe.couleurPrimaire : '#3b82f6' %}
{% set couleurSecondaire = societe and societe.couleurSecondaire ? societe.couleurSecondaire : '#6c757d' %}
{% set couleurTertiaire = societe and societe.couleurTertiaire ? societe.couleurTertiaire : '#28a745' %}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Devis {{ devis.numeroDevis }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 10px;
            margin: 0;
            padding: 20px 30px 20px 30px;
            color: #2c3e50;
            line-height: 1.5;
            background-color: white;
        }

        .container {
            background-color: white;
            padding: 0;
            border-radius: 0;
            box-shadow: none;
        }

        /* En-tête */
        .header {
            margin-bottom: 20px;
            padding-bottom: 0;
            border-bottom: none;
        }

        .header:after {
            content: "";
            display: table;
            clear: both;
        }

        .company-info {
            display: inline-block;
            vertical-align: top;
            width: 30%;
        }

        .company-info .company-name-wrapper {
            margin-bottom: 6px;
        }

        .company-info .company-name {
            color: #2c3e50;
            margin: 0;
            font-size: 16px;
            font-weight: 700;
        }

        .company-info .company-details {
            margin-top: 6px;
        }

        .company-info .company-details p {
            margin: 1px 0;
            font-size: 10px;
            color: #7f8c8d;
            line-height: 1.3;
        }

        .devis-info {
            display: inline-block;
            vertical-align: top;
            width: 39%;
            text-align: center;
        }

        .devis-info h2 {
            color: #2c3e50;
            margin: 0 0 4px 0;
            font-size: 22px;
            font-weight: 700;
        }

        .devis-info .validity {
            color: {{ couleurPrimaire }};
            font-size: 11px;
            font-weight: 500;
        }

        .logo-info {
            display: inline-block;
            vertical-align: top;
            width: 30%;
            text-align: right;
        }

        /* Métadonnées */
        .metadata {
            clear: both;
            width: 100%;
            margin-bottom: 20px;
        }

        .metadata:after {
            content: "";
            display: table;
            clear: both;
        }

        .metadata-item {
            float: left;
            width: 21.4%;
            margin-right: 1%;
            background-color: {{ couleurTertiaireRgba }};
            border-radius: 4px;
            padding: 6px 10px;
            box-sizing: border-box;
        }

        .metadata-item:last-child {
            margin-right: 0;
        }

        .metadata-label {
            font-size: 8px;
            color: #9ca3af;
            text-transform: none;
            letter-spacing: 0.3px;
            margin-bottom: 3px;
            font-weight: 400;
        }

        .metadata-value {
            font-size: 10px;
            color: #2c3e50;
            font-weight: 700;
        }

        /* Blocs Émetteur/Client */
        .parties-section {
            clear: both;
            padding-top: 7px;
            margin-bottom: 20px;
        }

        .parties-section:after {
            content: "";
            display: table;
            clear: both;
        }

        .partie-box {
            width: 100%;
            background-color: {{ couleurTertiaireRgba }};
            padding: 10px 12px;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .partie-box h3 {
            font-size: 8px;
            color: #9ca3af;
            margin-bottom: 3px;
            font-weight: 400;
            text-transform: none;
            letter-spacing: 0.3px;
        }

        .partie-box p {
            margin: 2px 0;
            font-size: 10px;
            color: #4b5563;
            line-height: 1.4;
        }

        .partie-box p strong {
            color: #2c3e50;
            font-weight: 700;
        }

        .partie-box p:first-of-type {
            font-size: 10px;
            margin-bottom: 2px;
        }

        /* Proposition commerciale */
        .proposition-box {
            clear: both;
            background-color: #eff6ff;
            border-left: 3px solid {{ couleurPrimaire }};
            padding: 10px 12px;
            margin-bottom: 20px;
            border-radius: 4px;
        }

        .proposition-box h4 {
            color: {{ couleurPrimaire }};
            font-size: 11px;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .proposition-box h4:before {
            content: url('data:image/svg+xml;base64,');
            display: inline-block;
            width: 14px;
            height: 14px;
            margin-right: 8px;
            vertical-align: middle;
        }

        .proposition-box p {
            font-size: 9px;
            color: #4b5563;
            line-height: 1.7;
        }

        /* Titre section */
        .section-title {
            font-size: 14px;
            color: #2c3e50;
            font-weight: 700;
            margin-bottom: 15px;
            padding-bottom: 0;
            border-bottom: none;
        }

        /* Tableau prestations */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            font-size: 9px;
        }

        .items-table thead {
            background-color: #2c3e50;
            color: white;
        }

        .items-table th {
            padding: 10px 8px;
            text-align: left;
            font-weight: 600;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .items-table td {
            padding: 12px 8px;
            border-bottom: 1px solid #ecf0f1;
            vertical-align: top;
        }

        .items-table tr:hover {
            background-color: #fafbfc;
        }

        .items-table .designation {
            font-weight: 600;
            color: #2c3e50;
            font-size: 10px;
            margin-bottom: 4px;
        }

        .items-table .description {
            color: #7f8c8d;
            font-size: 8px;
            line-height: 1.5;
            margin-top: 3px;
        }

        .items-table .text-center {
            text-align: center;
        }

        .items-table .text-right {
            text-align: right;
        }

        /* Sections bas de page */
        .bottom-section {
            clear: both;
            margin-top: 20px;
            padding-top: 7px;
        }

        .bottom-section:after {
            content: "";
            display: table;
            clear: both;
        }

        .conditions-box {
            width: 100%;
            padding: 10px 12px;
            background-color: {{ couleurTertiaireRgba }};
            border-radius: 4px;
            box-sizing: border-box;
        }

        .conditions-box h4 {
            font-size: 10px;
            color: #2c3e50;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .conditions-box p {
            font-size: 8.5px;
            color: #7f8c8d;
            margin: 4px 0;
            line-height: 1.5;
        }

        .synthese-box {
            width: 100%;
            padding: 10px 12px;
            background-color: {{ couleurTertiaireRgba }};
            border-radius: 4px;
            box-sizing: border-box;
        }

        .synthese-box h4 {
            font-size: 10px;
            color: #2c3e50;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .synthese-table {
            width: 100%;
        }

        .synthese-table td {
            padding: 6px 0;
            font-size: 9px;
        }

        .synthese-table td:last-child {
            text-align: right;
            font-weight: 600;
        }

        .synthese-table .total-ht {
            border-top: 1px solid #dee2e6;
            padding-top: 8px;
            font-weight: 700;
            font-size: 10px;
        }

        .synthese-table .tva-line {
            color: #7f8c8d;
        }

        .synthese-table .acompte-line {
            border-top: 2px solid #dee2e6;
            padding-top: 10px;
            font-weight: 700;
        }

        .synthese-table .total-ttc {
            background-color: #2c3e50;
            color: white;
            padding: 12px 10px;
            margin-top: 8px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 700;
        }

        /* Sections finales */
        .final-sections {
            clear: both;
            margin-top: 30px;
        }

        .final-sections:after {
            content: "";
            display: table;
            clear: both;
        }

        .acceptation-box {
            width: 100%;
            padding: 10px 12px;
            background-color: {{ couleurTertiaireRgba }};
            border-radius: 5px;
            box-sizing: border-box;
        }

        .acceptation-box h4 {
            font-size: 10px;
            color: #2c3e50;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .acceptation-box p {
            font-size: 8.5px;
            color: #7f8c8d;
            margin: 4px 0;
            line-height: 1.5;
        }

        .coordonnees-box {
            width: 100%;
            padding: 10px 12px;
            background-color: {{ couleurTertiaireRgba }};
            border-radius: 4px;
            box-sizing: border-box;
        }

        .coordonnees-box h4 {
            font-size: 10px;
            color: #2c3e50;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .coordonnees-box p {
            font-size: 8.5px;
            color: #7f8c8d;
            margin: 4px 0;
            font-family: 'Courier New', monospace;
        }

        /* Section titre */
        .section-row {
            background-color: #ecf0f1;
            padding: 12px 8px;
            font-weight: 700;
            color: #16a085;
            font-size: 11px;
            border-top: 2px solid #16a085;
        }

        /* Éléments spéciaux */
        .line-break-row {
            padding: 8px;
            border: none;
        }

        .separator-row {
            padding: 16px 8px;
            text-align: center;
            border: none;
        }

        .separator-row hr {
            border: none;
            border-top: 3px double #16a085;
            margin: 0;
        }

        .subtotal-row {
            background-color: #ecf0f1;
            padding: 10px 8px;
            text-align: right;
            border-top: 2px solid #16a085;
            font-weight: 700;
        }

        .page-break {
            page-break-after: always;
        }

        /* Badge statut */
        .badge {
            display: inline-block;
            padding: 3px 8px;
            font-size: 8px;
            font-weight: 600;
            border-radius: 12px;
            color: white;
        }

        .badge-success { background-color: #27ae60; }
        .badge-info { background-color: {{ couleurPrimaire }}; }
        .badge-warning { background-color: #f39c12; color: #2c3e50; }

        /* Signature */
        .signature-section {
            margin-top: 30px;
            border: 1px solid #dee2e6;
            padding: 15px;
            border-radius: 5px;
        }

        .signature-box {
            text-align: center;
            border: 1px dashed #16a085;
            padding: 20px;
            margin-top: 10px;
        }

        /* Styles contenu WYSIWYG */
        .items-table td strong { font-weight: 700; }
        .items-table td em { font-style: italic; }
        .items-table td u { text-decoration: underline; }
        .items-table td ul { margin: 3px 0; padding-left: 15px; }
        .items-table td ol { margin: 3px 0; padding-left: 15px; }
        .items-table td li { margin: 1px 0; font-size: 8px; }
        .items-table td p { margin: 3px 0; }

        /* Styles Quill pour notes client (proposition-box) */
        .proposition-box strong { font-weight: 700; }
        .proposition-box em { font-style: italic; }
        .proposition-box u { text-decoration: underline; }
        .proposition-box ul { margin: 5px 0; padding-left: 20px; list-style-type: disc; }
        .proposition-box ol { margin: 5px 0; padding-left: 20px; list-style-type: decimal; }
        .proposition-box li { margin: 2px 0; font-size: 9px; }
        .proposition-box p { margin: 5px 0; font-size: 9px; line-height: 1.6; }
        .proposition-box h1 { font-size: 14px; font-weight: 700; margin: 8px 0 5px 0; }
        .proposition-box h2 { font-size: 12px; font-weight: 700; margin: 7px 0 4px 0; }
        .proposition-box h3 { font-size: 11px; font-weight: 700; margin: 6px 0 3px 0; }

        /* Polices Quill */
        .ql-font-arial, .proposition-box .ql-font-arial { font-family: Arial, sans-serif; }
        .ql-font-helvetica, .proposition-box .ql-font-helvetica { font-family: Helvetica, sans-serif; }
        .ql-font-times, .proposition-box .ql-font-times { font-family: 'Times New Roman', serif; }
        .ql-font-georgia, .proposition-box .ql-font-georgia { font-family: Georgia, serif; }
        .ql-font-verdana, .proposition-box .ql-font-verdana { font-family: Verdana, sans-serif; }
        .ql-font-courier, .proposition-box .ql-font-courier { font-family: 'Courier New', monospace; }

        /* Tailles Quill */
        .ql-size-10px, .proposition-box .ql-size-10px { font-size: 10px; }
        .ql-size-12px, .proposition-box .ql-size-12px { font-size: 12px; }
        .ql-size-14px, .proposition-box .ql-size-14px { font-size: 14px; }
        .ql-size-16px, .proposition-box .ql-size-16px { font-size: 16px; }
        .ql-size-18px, .proposition-box .ql-size-18px { font-size: 18px; }
        .ql-size-20px, .proposition-box .ql-size-20px { font-size: 20px; }
        .ql-size-22px, .proposition-box .ql-size-22px { font-size: 22px; }
        .ql-size-24px, .proposition-box .ql-size-24px { font-size: 24px; }

        /* Alignements Quill */
        .ql-align-center, .proposition-box .ql-align-center { text-align: center; }
        .ql-align-right, .proposition-box .ql-align-right { text-align: right; }
        .ql-align-justify, .proposition-box .ql-align-justify { text-align: justify; }

        /* Styles WYSIWYG pour CGV */
        .cgv-content strong { font-weight: 700; }
        .cgv-content em { font-style: italic; }
        .cgv-content u { text-decoration: underline; }
        .cgv-content ul { margin: 5px 0; padding-left: 20px; }
        .cgv-content ol { margin: 5px 0; padding-left: 20px; }
        .cgv-content li { margin: 2px 0; }
        .cgv-content h1 { font-size: 14px; font-weight: 700; margin: 10px 0 5px 0; }
        .cgv-content h2 { font-size: 12px; font-weight: 700; margin: 8px 0 4px 0; }
        .cgv-content h3 { font-size: 11px; font-weight: 700; margin: 6px 0 3px 0; }
        .cgv-content p { margin: 4px 0; }

        /* Polices Quill pour CGV */
        .cgv-content .ql-font-arial { font-family: Arial, sans-serif; }
        .cgv-content .ql-font-helvetica { font-family: Helvetica, sans-serif; }
        .cgv-content .ql-font-times { font-family: 'Times New Roman', serif; }
        .cgv-content .ql-font-georgia { font-family: Georgia, serif; }
        .cgv-content .ql-font-verdana { font-family: Verdana, sans-serif; }
        .cgv-content .ql-font-courier { font-family: 'Courier New', monospace; }

        /* Tailles Quill pour CGV */
        .cgv-content .ql-size-10px { font-size: 10px; }
        .cgv-content .ql-size-12px { font-size: 12px; }
        .cgv-content .ql-size-14px { font-size: 14px; }
        .cgv-content .ql-size-16px { font-size: 16px; }
        .cgv-content .ql-size-18px { font-size: 18px; }
        .cgv-content .ql-size-20px { font-size: 20px; }
        .cgv-content .ql-size-22px { font-size: 22px; }
        .cgv-content .ql-size-24px { font-size: 24px; }

        /* Alignements Quill pour CGV */
        .cgv-content .ql-align-center { text-align: center; }
        .cgv-content .ql-align-right { text-align: right; }
        .cgv-content .ql-align-justify { text-align: justify; }
    </style>
</head>
<body>
    <div class="container">
        <!-- En-tête -->
        <div class="header">
            <div class="company-info">
                {# Afficher la société mère en haut à gauche #}
                <div class="company-name-wrapper">
                    <h1 class="company-name">{{ societe and societe.societeParent ? societe.societeParent.nom : (societe ? societe.nom : 'TechnoProd') }}</h1>
                </div>
                <div class="company-details">
                    {% if societe %}
                        {% if societe.adresse %}<p>{{ societe.adresse }}</p>{% endif %}
                        <p>{{ societe.codePostal }} {{ societe.ville }}</p>
                        {% if societe.telephone %}<p>{{ societe.telephone }}</p>{% endif %}
                        {% if societe.email %}<p>{{ societe.email }}</p>{% endif %}
                    {% else %}
                        <p>12 avenue des Entrepreneurs</p>
                        <p>69003 Lyon</p>
                        <p>04 72 00 18 22</p>
                        <p>contact@salessuite.fr</p>
                    {% endif %}
                </div>
            </div>

            <div class="devis-info">
                <h2>Devis {{ devis.numeroDevis }}</h2>
                <div class="validity">
                    <span style="display: inline-block; width: 11px; height: 11px; border: 2px solid {{ couleurPrimaire }}; border-radius: 50%; position: relative; margin-right: 4px; vertical-align: middle;">
                        <span style="position: absolute; width: 1px; height: 4px; background: {{ couleurPrimaire }}; left: 50%; top: 1px; transform: translateX(-50%);"></span>
                        <span style="position: absolute; width: 3px; height: 1px; background: {{ couleurPrimaire }}; left: 5px; top: 50%; transform: translateY(-50%);"></span>
                    </span>
                    Valable jusqu'au {{ devis.dateValidite|date('d/m/Y') }}
                </div>
            </div>

            <div class="logo-info">
                {% if logoBase64 %}
                    <img src="{{ logoBase64 }}" alt="Logo {{ societe.nom }}" style="max-height: 55px; max-width: 160px;">
                {% endif %}
            </div>
        </div>

        <!-- Métadonnées -->
        <div class="metadata">
            <div class="metadata-item">
                <div class="metadata-label">Date d'émission</div>
                <div class="metadata-value">{{ devis.dateCreation|date('d/m/Y') }}</div>
            </div>
            <div class="metadata-item">
                <div class="metadata-label">Commercial</div>
                <div class="metadata-value">{{ devis.commercial ? devis.commercial.fullName : '-' }}</div>
            </div>
            <div class="metadata-item">
                <div class="metadata-label">Référence client</div>
                <div class="metadata-value">{{ devis.client ? devis.client.code : '-' }}</div>
            </div>
            <div class="metadata-item">
                <div class="metadata-label">Mode de règlement</div>
                <div class="metadata-value">{{ devis.modeReglement ? devis.modeReglement.nom : 'Virement à 30 jours' }}</div>
            </div>
        </div>

        <!-- Contact de livraison / Contact de facturation -->
        <div class="parties-section">
            <div class="partie-box" style="float: left; width: 46%; margin-right: 1%;">
                <h3>Contact de livraison</h3>
                {% if devis.client %}
                    {% if devis.contactLivraison and devis.contactLivraison.id != devis.contactFacturation.id %}
                        <p><strong>{{ devis.client.nomComplet }}</strong></p>
                        <p>À l'attention de {{ devis.contactLivraison.nomComplet }}</p>
                        {% if devis.adresseLivraison %}
                            <p>{{ devis.adresseLivraison.ligne1 }}</p>
                            {% if devis.adresseLivraison.ligne2 %}<p>{{ devis.adresseLivraison.ligne2 }}</p>{% endif %}
                            <p>{{ devis.adresseLivraison.codePostal }} {{ devis.adresseLivraison.ville }}</p>
                        {% endif %}
                    {% else %}
                        <p><em>Identique au contact de facturation</em></p>
                    {% endif %}
                {% else %}
                    <p>-</p>
                {% endif %}
            </div>
            <div class="partie-box" style="float: left; width: 46%; margin-right: 0;">
                <h3>Contact de facturation</h3>
                {% if devis.client %}
                    <p><strong>{{ devis.client.nomComplet }}</strong></p>
                    {% if devis.contactFacturation %}
                        <p>À l'attention de {{ devis.contactFacturation.nomComplet }}</p>
                    {% endif %}
                    {% if devis.adresseFacturation %}
                        <p>{{ devis.adresseFacturation.ligne1 }}</p>
                        {% if devis.adresseFacturation.ligne2 %}<p>{{ devis.adresseFacturation.ligne2 }}</p>{% endif %}
                        <p>{{ devis.adresseFacturation.codePostal }} {{ devis.adresseFacturation.ville }}</p>
                    {% endif %}
                {% else %}
                    <p>-</p>
                {% endif %}
            </div>
        </div>

        <!-- Proposition commerciale -->
        {% if devis.notesClient and devis.notesClient|striptags|trim != '' %}
        <div class="proposition-box">
            <h4>Proposition commerciale personnalisée</h4>
            <div>{{ devis.notesClient|raw }}</div>
        </div>
        {% endif %}

        <!-- Détail des prestations -->
        <div class="section-title">Détail des prestations</div>

        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 36%;">Désignation</th>
                    <th style="width: 9%;" class="text-center">Unité</th>
                    <th style="width: 8%;" class="text-center">Qté</th>
                    <th style="width: 12%;" class="text-right">Prix unit. HT</th>
                    <th style="width: 8%;" class="text-center">Remise</th>
                    <th style="width: 12%;" class="text-right">Total HT</th>
                    <th style="width: 8%;" class="text-center">TVA</th>
                </tr>
            </thead>
            <tbody>
                {% for element in devis.elementsOrdered %}
                    {% if element.type == 'product' %}
                        <tr>
                            <td>
                                {% if element.imageVisible and element.productImage and element.productImage.filename %}
                                    {% set imagePath = projectDir ~ '/public/uploads/products/' ~ element.productImage.filename %}
                                    <img src="{{ imagePath|base64_image }}" alt="" style="max-width: 60px; max-height: 60px; float: left; margin-right: 10px;">
                                {% endif %}
                                <div class="designation">{{ element.designation }}</div>
                                {% if element.description %}
                                    <div class="description">{{ element.description|striptags|raw }}</div>
                                {% endif %}
                                {% if element.produit %}
                                    <div class="description">Réf: {{ element.produit.reference }}</div>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if element.produit and element.produit.uniteVente %}
                                    {{ element.produit.uniteVente.nom }}
                                {% elseif element.produit and element.produit.unite %}
                                    {{ element.produit.unite }}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td class="text-center">{{ element.quantite }}</td>
                            <td class="text-right">{{ element.prixUnitaireHt|number_format(2, ',', ' ') }} €</td>
                            <td class="text-center">
                                {% if element.remisePercent > 0 %}
                                    {{ element.remisePercent }}%
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td class="text-right"><strong>{{ element.totalLigneHt|number_format(2, ',', ' ') }} €</strong></td>
                            <td class="text-center">{{ element.tvaPercent }}%</td>
                        </tr>
                    {% elseif element.type == 'section_title' %}
                        <tr>
                            <td colspan="7" class="section-row">
                                {{ element.titre }}
                            </td>
                        </tr>
                    {% elseif element.type == 'line_break' %}
                        <tr>
                            <td colspan="7" class="line-break-row"></td>
                        </tr>
                    {% elseif element.type == 'page_break' %}
                        </tbody>
                    </table>

                    <div class="page-break"></div>

                    <table class="items-table">
                        <thead>
                            <tr>
                                <th style="width: 36%;">Désignation</th>
                                <th style="width: 9%;" class="text-center">Unité</th>
                                <th style="width: 8%;" class="text-center">Qté</th>
                                <th style="width: 12%;" class="text-right">Prix unit. HT</th>
                                <th style="width: 8%;" class="text-center">Remise</th>
                                <th style="width: 12%;" class="text-right">Total HT</th>
                                <th style="width: 8%;" class="text-center">TVA</th>
                            </tr>
                        </thead>
                        <tbody>
                    {% elseif element.type == 'separator' %}
                        <tr>
                            <td colspan="7" class="separator-row">
                                <hr>
                            </td>
                        </tr>
                    {% elseif element.type == 'subtotal' %}
                        <tr>
                            <td colspan="6" class="subtotal-row">
                                <strong>{{ element.titre ?: 'Sous-total' }} :</strong>
                            </td>
                            <td class="subtotal-row">
                                <strong>{{ devis.calculateSubtotalUpTo(element.position)|number_format(2, ',', ' ') }} €</strong>
                            </td>
                        </tr>
                    {% endif %}
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center" style="color: #95a5a6; padding: 30px;">
                            Aucune ligne de devis
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <!-- Bloc indissociable : tout le bas du devis -->
        <div style="page-break-inside: avoid;">

        <!-- Colonne gauche et droite -->
        <div class="bottom-section">
            <!-- Wrapper colonne gauche : Récapitulatif TVA (si plusieurs taux) + Conditions + Coordonnées bancaires -->
            <div style="float: left; width: 46%; margin-right: 4.5%; box-sizing: border-box;">
                {% set tvaDetailsByRate = devis.getTvaDetailsByRate() %}
                {% set tvaRatesWithAmount = 0 %}
                {% for taux, detail in tvaDetailsByRate %}
                    {% if detail.totalTva > 0.001 %}
                        {% set tvaRatesWithAmount = tvaRatesWithAmount + 1 %}
                    {% endif %}
                {% endfor %}

                {% if tvaRatesWithAmount > 1 %}
                <div class="conditions-box" style="margin-bottom: 10px;">
                    <h4>Récapitulatif TVA</h4>
                    <table style="width: 100%; font-size: 10px; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid #ddd;">
                                <th style="padding: 5px 0; text-align: left; font-weight: bold;">Taux</th>
                                <th style="padding: 5px 0; text-align: right; font-weight: bold;">Base HT</th>
                                <th style="padding: 5px 0; text-align: right; font-weight: bold;">Montant TVA</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for taux, detail in tvaDetailsByRate %}
                                {% if detail.totalTva > 0.001 %}
                                <tr>
                                    <td style="padding: 3px 0;">{{ taux }}%</td>
                                    <td style="padding: 3px 0; text-align: right;">{{ detail.totalHt|number_format(2, ',', ' ') }} €</td>
                                    <td style="padding: 3px 0; text-align: right;">{{ detail.totalTva|number_format(2, ',', ' ') }} €</td>
                                </tr>
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endif %}

                <div class="acceptation-box" style="margin-top: 10px;">
                    <h4>Acceptation du devis</h4>
                    <p>Signature précédée de la mention : Lu et approuvé, bon pour accord</p>
                    {% if devis.dateSignature %}
                        <p style="margin-top: 10px;"><strong>Signé par:</strong> {{ devis.signatureNom }} ({{ devis.signatureEmail }})</p>
                        <p><strong>Date:</strong> {{ devis.dateSignature|date('d/m/Y à H:i:s') }}</p>
                    {% else %}
                        <div style="margin-top: 15px;">
                            <p style="font-size: 8px; color: #7f8c8d; margin: 3px 0;">A ....................................................., le .......................................................</p>
                        </div>
                        <div style="margin-top: 10px; border: 1px dashed #bdc3c7; padding: 40px 20px; min-height: 60px;">
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Colonne droite : Synthèse financière -->
            <div style="float: left; width: 46%; margin-right: 0; box-sizing: border-box;">
                <div class="synthese-box">
                <h4>Synthèse financière</h4>
                <table class="synthese-table">
                    {% if devis.remiseGlobalePercent or devis.remiseGlobaleMontant %}
                        {% set sousTotal = 0 %}
                        {% for element in devis.elementsOrdered %}
                            {% if element.type == 'product' %}
                                {% set sousTotal = sousTotal + element.totalLigneHt %}
                            {% endif %}
                        {% endfor %}
                        <tr>
                            <td>Sous-total HT</td>
                            <td>{{ sousTotal|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% if devis.remiseGlobalePercent and devis.remiseGlobalePercent > 0 %}
                            <tr>
                                <td>Remise ({{ devis.remiseGlobalePercent }}%)</td>
                                <td>-{{ (sousTotal * devis.remiseGlobalePercent / 100)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% elseif devis.remiseGlobaleMontant and devis.remiseGlobaleMontant > 0 %}
                            <tr>
                                <td>Remise</td>
                                <td>-{{ devis.remiseGlobaleMontant|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endif %}
                    {% endif %}
                    <tr class="total-ht">
                        <td>Total HT</td>
                        <td>{{ devis.totalHt|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    <tr class="tva-line">
                        <td>Total TVA</td>
                        <td>{{ devis.totalTva|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    {% if devis.acomptePercent or devis.acompteMontant %}
                        <tr class="acompte-line">
                            <td>Acompte à la commande</td>
                            <td>{{ devis.calculateAcompte|number_format(2, ',', ' ') }} € TTC</td>
                        </tr>
                    {% endif %}
                    <tr>
                        <td colspan="2" class="total-ttc">
                            Total TTC&nbsp;&nbsp;&nbsp;&nbsp;{{ devis.totalTtc|number_format(2, ',', ' ') }} €
                        </td>
                    </tr>
                </table>
                </div>
            </div>
        </div>

        </div><!-- Fin du bloc indissociable -->

        <!-- Footer avec mentions légales -->
        <div style="position: fixed; bottom: 20px; left: 30px; right: 30px; padding-top: 15px; border-top: 1px solid #dee2e6; font-size: 8px; color: #7f8c8d; line-height: 1.4; background-color: white; text-align: center;">
            <p style="margin: 3px 0;">Devis gratuit. Les prix TTC sont établis sur la base des taux de TVA en vigueur à la date de remise de l'offre. Toute variation de ces taux sera répercutée sur les prix.
            {% if devis.acomptePercent %}
                Un acompte de {{ devis.acomptePercent }}% du prix TTC sera demandé afin de valider toute commande.
            {% elseif devis.acompteMontant %}
                Un acompte de {{ ((devis.acompteMontant / devis.totalTtc * 100)|number_format(0)) }}% du prix TTC sera demandé afin de valider toute commande.
            {% else %}
                Un acompte de 30% du prix TTC sera demandé afin de valider toute commande.
            {% endif %}
            L'acceptation de ce devis vaut acceptation de nos Conditions Générales et Particulières de Vente figurant en annexe.
            </p>
            <p style="margin: 10px 0 5px 0; font-size: 11px; font-weight: 600; color: #2c3e50;">Coordonnées bancaires</p>
            <p style="margin: 0; font-size: 10px; color: #2c3e50; font-weight: 500;">
                <span style="font-weight: 700;">IBAN :</span>
                {% if banquePrincipale and banquePrincipale.iban %}
                    {{ banquePrincipale.iban }}
                {% else %}
                    FR76 3000 4000 5000 6000 7000 189
                {% endif %}
                &nbsp;&nbsp;•&nbsp;&nbsp;
                <span style="font-weight: 700;">BIC :</span>
                {% if banquePrincipale and banquePrincipale.bic %}
                    {{ banquePrincipale.bic }}
                {% else %}
                    BNPAFRPPXXX
                {% endif %}
            </p>
        </div>

        <!-- CGV sur nouvelle page -->
        {% if conditionsVente and conditionsVente.contenu and conditionsVente.contenu|striptags|trim != '' %}
        <div class="page-break"></div>

        <div style="margin-top: 30px;">
            <h2 style="font-size: 16px; color: {{ couleurPrimaire }}; margin-bottom: 20px; text-align: center; text-transform: uppercase; letter-spacing: 1px;">
                Conditions Générales de Vente
            </h2>
            <div class="cgv-content" style="font-size: 9px; line-height: 1.6; color: #2c3e50;">
                {{ conditionsVente.contenu|nl2br|raw }}
            </div>
        </div>
        {% endif %}

    </div>
</body>
</html>
