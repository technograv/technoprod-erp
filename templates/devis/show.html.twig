{% block javascripts %}
<script>
// Activer les tooltips Bootstrap
var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl)
});

// Charger les versions quand l'onglet est activé
document.addEventListener('DOMContentLoaded', function() {
    const versionsTab = document.getElementById('versions-tab');
    if (versionsTab) {
        versionsTab.addEventListener('shown.bs.tab', function() {
            {% if devis.hasVersions %}
            loadVersions();
            {% endif %}
        });
    }
});

{% if devis.hasVersions %}
function loadVersions() {
    const versionsList = document.getElementById('versions-list');
    
    fetch('{{ path("app_devis_api_versions", {"id": devis.id}) }}')
        .then(response => response.json())
        .then(versions => {
            if (versions.length === 0) {
                versionsList.innerHTML = `
                    <div class="text-center text-muted">
                        <i class="fas fa-history fa-3x mb-3"></i>
                        <p>Aucune version disponible</p>
                    </div>
                `;
                return;
            }

            let html = '<div class="timeline position-relative">';
            
            versions.forEach((version, index) => {
                const isFirst = index === 0;
                const badgeClass = getStatusBadgeClass(version.statutAtTime);
                
                html += `
                    <div class="timeline-item ${isFirst ? 'latest' : ''} mb-4">
                        <div class="timeline-marker ${isFirst ? 'bg-primary' : 'bg-secondary'}">
                            <i class="fas fa-${isFirst ? 'clock' : 'history'} text-white"></i>
                        </div>
                        <div class="timeline-content ms-4">
                            <div class="card ${isFirst ? 'border-primary' : ''}">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">
                                            ${version.versionLabel || version.nomProjet || 'Version ' + version.versionNumber}
                                        </h6>
                                        <small class="text-muted">
                                            Version créée par ${version.modifiedBy} le ${version.createdAt}
                                        </small>
                                    </div>
                                    <div class="text-end">
                                        <div class="mb-1">
                                            <small class="text-muted">Total HT:</small>
                                            <span class="fw-bold">${version.totalHtAtTime || '0.00'}€</span>
                                        </div>
                                        <div class="mb-1">
                                            <small class="text-muted">TVA:</small>
                                            <span class="fw-bold">${version.totalTvaAtTime || '0.00'}€</span>
                                        </div>
                                        <div>
                                            <small class="text-muted">Total TTC:</small>
                                            <span class="fw-bold text-primary">${version.totalTtcAtTime}€</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <p class="mb-2"><strong>Motif :</strong> ${version.modificationReason || 'Non spécifié'}</p>
                                    <div class="d-flex gap-2">
                                        <a href="/devis/{{ devis.id }}/versions/${version.versionNumber}" 
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="fas fa-eye me-1"></i>Voir
                                        </a>
                                        ${!isFirst ? `
                                            <button class="btn btn-outline-secondary btn-sm" onclick="compareVersions(${version.versionNumber})">
                                                <i class="fas fa-exchange-alt me-1"></i>Comparer
                                            </button>
                                        ` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            versionsList.innerHTML = html;
        })
        .catch(error => {
            console.error('Erreur lors du chargement des versions:', error);
            versionsList.innerHTML = `
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Erreur lors du chargement des versions
                </div>
            `;
        });
}

function getStatusBadgeClass(status) {
    const classes = {
        'brouillon': 'bg-secondary',
        'envoye': 'bg-info',
        'relance': 'bg-warning',
        'signe': 'bg-primary',
        'acompte_regle': 'bg-success',
        'accepte': 'bg-success',
        'refuse': 'bg-danger',
        'expire': 'bg-dark'
    };
    return classes[status] || 'bg-secondary';
}

function getStatusLabel(status) {
    const labels = {
        'brouillon': 'Brouillon',
        'envoye': 'Envoyé',
        'relance': 'Relancé',
        'signe': 'Signé',
        'acompte_regle': 'Acompte réglé',
        'accepte': 'Accepté',
        'refuse': 'Refusé',
        'expire': 'Expiré'
    };
    return labels[status] || 'Inconnu';
}

function compareVersions(versionNumber) {
    // TODO: Implémenter la comparaison de versions
    alert('Fonctionnalité de comparaison à venir - Version ' + versionNumber);
}

{% endif %}

// Debug: vérifier si le script s'exécute
console.log('Script devis show chargé');

// Debug: vérifier la présence des éléments
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM chargé');
    const versionModal = document.getElementById('versionModal');
    const createBtn = document.getElementById('createVersionAndEditBtn');
    console.log('Modal versionModal trouvée:', versionModal);
    console.log('Bouton createVersionAndEditBtn trouvé:', createBtn);
    
    if (versionModal && createBtn) {
        console.log('Les deux éléments sont présents dans le DOM');
    } else {
        console.error('Éléments manquants - Modal:', !!versionModal, 'Bouton:', !!createBtn);
    }
