<!-- Barre flottante d'actions -->
<div class="floating-action-bar" id="floating-actions">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center">
            <!-- Gauche : Numéro/Statut + Actions principales -->
            <div class="d-flex gap-2 align-items-center">
                <span class="text-white me-2">
                    <i class="fas fa-file-invoice me-2"></i>
                    <strong>{{ devis.numeroDevis }}</strong>
                    <span class="badge bg-{{ devis.statutCouleur }} ms-2">{{ devis.statutLibelle }}</span>
                </span>

                {% if devis.canCancelSignature %}
                    {# Devis signé : bouton d'annulation de signature au lieu de modifier #}
                    <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#cancelSignatureModal">
                        <i class="fas fa-ban me-1"></i>Annuler signature
                    </button>
                {% elseif devis.statut in ['envoye', 'relance'] %}
                    {# Devis envoyé/relancé : création de version pour modification #}
                    <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#versionModal">
                        <i class="fas fa-edit me-1"></i>Modifier
                    </button>
                {% elseif devis.isEditable %}
                    {# Devis brouillon : modification directe #}
                    <a href="{{ path('app_devis_edit', {'id': devis.id}) }}" class="btn btn-light btn-sm">
                        <i class="fas fa-edit me-1"></i>Modifier
                    </a>
                {% endif %}

                <form method="post" action="{{ path('app_devis_duplicate', {'id': devis.id}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ devis.id) }}">
                    <button type="submit" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-copy me-1"></i>Dupliquer
                    </button>
                </form>

                {% if is_granted('ROLE_ADMIN') or devis.commercial == app.user %}
                    {% if devis.dateSignature is null %}
                        <form method="post" action="{{ path('app_devis_delete', {'id': devis.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir archiver ce devis ?');" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ devis.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash me-1"></i>Archiver
                            </button>
                        </form>
                    {% endif %}
                {% endif %}
            </div>

            <!-- Centre : Nom du projet -->
            <div class="text-center">
                {% if devis.nomProjet %}
                    <span class="text-white fw-bold fs-5">
                        {{ devis.nomProjet }}
                    </span>
                {% endif %}
            </div>

            <!-- Droite : Envoyer/PDF/Retour -->
            <div class="d-flex gap-2">
                {% if devis.statut in ['brouillon', 'envoye', 'relance'] %}
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#envoyerModal">
                        <i class="fas fa-paper-plane me-1"></i>
                        {% if devis.statut == 'envoye' or devis.statut == 'relance' %}Renvoyer{% else %}Envoyer{% endif %}
                    </button>
                {% endif %}

                <a href="{{ path('app_devis_pdf', {'id': devis.id}) }}" target="_blank" class="btn btn-info">
                    <i class="fas fa-file-pdf me-1"></i>PDF
                </a>

                <a href="{{ path('app_devis_index') }}" class="btn btn-outline-light">
                    <i class="fas fa-arrow-left me-1"></i>Retour
                </a>
            </div>
        </div>
    </div>
</div>

