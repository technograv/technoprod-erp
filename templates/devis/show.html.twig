// Charger les versions quand l'onglet est activé
document.addEventListener('DOMContentLoaded', function() {
    const versionsTab = document.getElementById('versions-tab');
    if (versionsTab) {
        versionsTab.addEventListener('shown.bs.tab', function() {
            {% if devis.hasVersions %}
