// Gestion de la création de version automatique pour modification avec délégation d'événements
window.isCreatingVersion = window.isCreatingVersion || false; // Protection contre la double exécution

document.addEventListener('click', function(event) {
    if (event.target && event.target.id === 'createVersionAndEditBtn') {
        console.log('Clic sur le bouton createVersionAndEditBtn détecté via délégation');
        event.preventDefault();
        event.stopPropagation();
        
        // Vérifier si une création est déjà en cours
        if (window.isCreatingVersion) {
            console.log('Création déjà en cours, ignorer le clic');
            return;
        }
        
        window.isCreatingVersion = true;
        const btn = event.target;
        // Afficher un indicateur de chargement
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Création en cours...';
        
        // Récupérer le nom de la version depuis le champ input
        const versionNameInput = document.getElementById('versionNameInput');
        const versionName = versionNameInput ? versionNameInput.value.trim() : '';
        const labelToSend = versionName || 'Version automatique avant modification';
        
        // Créer la version puis rediriger vers l'édition
        fetch('{{ path("app_devis_create_version", {"id": devis.id}) }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'label=' + encodeURIComponent(labelToSend)
        })
        .then(response => {
            console.log('Réponse reçue:', response.status, response.statusText);
            if (response.ok) {
                return response.json();
            } else {
                throw new Error('Erreur HTTP: ' + response.status);
            }
        })
        .then(data => {
            console.log('Données reçues:', data);
            if (data.success) {
                // Fermer la modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('versionModal'));
                if (modal) {
                    modal.hide();
                }
                // Version créée avec succès, rediriger vers l'édition
                console.log('Redirection vers édition...');
                window.location.href = '{{ path("app_devis_edit", {"id": devis.id}) }}';
            } else {
                throw new Error(data.message || 'Erreur lors de la création de la version');
            }
        })
        .catch(error => {
            console.error('Erreur complète:', error);
            alert('Erreur lors de la création de la version: ' + error.message);
            btn.disabled = false;
            btn.innerHTML = originalText;
            window.isCreatingVersion = false; // Réinitialiser en cas d'erreur
        });
    }
});

// Activer automatiquement l'onglet Lignes du devis si fragment #lignes
document.addEventListener('DOMContentLoaded', function() {
    if (window.location.hash === '#lignes') {
        // Empêcher le scroll automatique du navigateur
        history.replaceState(null, null, window.location.pathname + window.location.search);
        
        // Activer l'onglet Lignes du devis
        const lignesTab = document.getElementById('lignes-tab');
        const lignesTabPane = document.getElementById('lignes');
        const activeTab = document.querySelector('.nav-link.active');
        const activeTabPane = document.querySelector('.tab-pane.show.active');
        
        if (lignesTab && lignesTabPane) {
            // Désactiver l'onglet actuel
            if (activeTab) activeTab.classList.remove('active');
            if (activeTabPane) {
                activeTabPane.classList.remove('show', 'active');
            }
            
            // Activer l'onglet Lignes du devis
            lignesTab.classList.add('active');
            lignesTabPane.classList.add('show', 'active');
        }
        
        // S'assurer qu'on reste en haut
        window.scrollTo(0, 0);
    }
});

// Ouvrir automatiquement la modal d'envoi si demandé
{% if app.request.query.get('open_send_modal') %}
document.addEventListener('DOMContentLoaded', function() {
    const envoyerModal = new bootstrap.Modal(document.getElementById('envoyerModal'));
    envoyerModal.show();
});
{% endif %}
</script>
