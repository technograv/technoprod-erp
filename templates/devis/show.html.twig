{% if devis.hasVersions %}
// Utiliser une structure qui évite les redéclarations
window.devisVersionsManager = window.devisVersionsManager || {
    versionsLoaded: false
};

function loadVersions() {
    // Éviter les chargements multiples
    if (window.devisVersionsManager.versionsLoaded) return;

    const versionsList = document.getElementById('versions-list');
    if (!versionsList) return;

    window.devisVersionsManager.versionsLoaded = true;

    fetch('{{ path("app_devis_api_versions", {"id": devis.id}) }}')
        .then(response => response.json())
        .then(versions => {
            if (versions.length === 0) {
                versionsList.innerHTML = `
                    <div class="text-center text-muted">
                        <i class="fas fa-history fa-3x mb-3"></i>
                        <p>Aucune version disponible</p>
                    </div>
                `;
                return;
            }

            let html = '<div class="timeline position-relative">';
            
            versions.forEach((version, index) => {
                const isFirst = index === 0;
                const badgeClass = getStatusBadgeClass(version.statutAtTime);
                const isSignatureVersion = version.modificationReason && version.modificationReason.includes('Signature client');

                html += `
                    <div class="timeline-item ${isFirst ? 'latest' : ''} mb-4">
                        <div class="timeline-marker ${isFirst && !isSignatureVersion ? 'bg-primary' : (isSignatureVersion ? 'bg-success' : 'bg-secondary')}">
                            <i class="fas fa-${isSignatureVersion ? 'lock' : (isFirst ? 'clock' : 'history')} text-white"></i>
                        </div>
                        <div class="timeline-content ms-4">
                            <div class="card ${isFirst ? 'border-primary' : ''}">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="mb-1">
                                            ${isSignatureVersion ?
                                                '<h6 class="mb-0">Archivage automatique</h6>' :
                                                `<span><strong>${version.versionLabel || version.nomProjet || 'Version ' + version.versionNumber}</strong> créée par ${version.modifiedBy} le ${version.createdAt}</span>`
                                            }
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="mb-1">
                                            <small class="text-muted">Total HT:</small>
                                            <span class="fw-bold">${version.totalHtAtTime || '0.00'}€</span>
                                        </div>
                                        <div class="mb-1">
                                            <small class="text-muted">TVA:</small>
                                            <span class="fw-bold">${version.totalTvaAtTime || '0.00'}€</span>
                                        </div>
                                        <div>
                                            <small class="text-muted">Total TTC:</small>
                                            <span class="fw-bold text-primary">${version.totalTtcAtTime}€</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <p class="mb-2"><strong>Motif :</strong> ${isSignatureVersion ? `Signature du client le ${version.createdAt}` : (version.modificationReason || 'Non spécifié')}</p>
                                    <div class="d-flex gap-2">
                                        <a href="/devis/{{ devis.id }}/versions/${version.versionNumber}" 
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="fas fa-eye me-1"></i>Voir
                                        </a>
                                        <button class="btn btn-outline-success btn-sm" onclick="duplicateFromVersion(${version.id}, '${version.label || ('Version ' + version.versionNumber)}')">
                                            <i class="fas fa-copy me-1"></i>Dupliquer
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            versionsList.innerHTML = html;
        })
        .catch(error => {
            console.error('Erreur lors du chargement des versions:', error);
            window.devisVersionsManager.versionsLoaded = false; // Permettre de réessayer
            versionsList.innerHTML = `
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Erreur lors du chargement des versions
                </div>
            `;
        });
}

function getStatusBadgeClass(status) {
    const classes = {
        'brouillon': 'bg-secondary',
        'envoye': 'bg-info',
        'relance': 'bg-warning',
        'signe': 'bg-primary',
        'acompte_regle': 'bg-success',
        'accepte': 'bg-success',
        'refuse': 'bg-danger',
        'expire': 'bg-dark'
    };
    return classes[status] || 'bg-secondary';
}

function getStatusLabel(status) {
    const labels = {
        'brouillon': 'Brouillon',
        'envoye': 'Envoyé',
        'relance': 'Relancé',
        'signe': 'Signé',
        'acompte_regle': 'Acompte réglé',
        'accepte': 'Accepté',
        'refuse': 'Refusé',
        'expire': 'Expiré'
    };
    return labels[status] || 'Inconnu';
}

