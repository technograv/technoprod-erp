{% extends 'base.html.twig' %}

{% block title %}Paramétrage Utilisateur{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-sm-flex align-items-center justify-content-between mb-4">
                <h1 class="h3 mb-0 text-gray-800">
                    <i class="fas fa-user-cog me-2"></i>{% block page_title %}Paramétrage Utilisateur{% endblock %}
                </h1>
            </div>

            <!-- Messages flash -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- Navigation par onglets Pills -->
            <ul class="nav nav-pills mb-4" id="userPrefsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <a href="{{ path('app_user_preferences_index') }}" 
                       class="nav-link {{ app.request.get('_route') == 'app_user_preferences_index' ? 'active' : '' }}">
                        <i class="fas fa-home me-2"></i>Aperçu général
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a href="{{ path('app_user_preferences_email') }}" 
                       class="nav-link {{ app.request.get('_route') == 'app_user_preferences_email' ? 'active' : '' }}">
                        <i class="fas fa-envelope me-2"></i>Email & signatures
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a href="{{ path('app_user_preferences_general') }}" 
                       class="nav-link {{ app.request.get('_route') == 'app_user_preferences_general' ? 'active' : '' }}">
                        <i class="fas fa-cog me-2"></i>Préférences générales
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a href="{{ path('app_user_preferences_calendar') }}" 
                       class="nav-link {{ app.request.get('_route') == 'app_user_preferences_calendar' ? 'active' : '' }}">
                        <i class="fas fa-calendar-alt me-2"></i>Calendriers Google
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a href="{{ path('app_user_preferences_notes') }}" 
                       class="nav-link {{ app.request.get('_route') == 'app_user_preferences_notes' ? 'active' : '' }}">
                        <i class="fas fa-sticky-note me-2"></i>Notes personnelles
                    </a>
                </li>
            </ul>

            <!-- Contenu de la page -->
            <div class="row">
                <div class="col-12">
                    {% block content %}
                    {% endblock %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}