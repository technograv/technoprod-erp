{% extends 'user_preferences/_base.html.twig' %}

{% block title %}Notes Personnelles - Paramétrage Utilisateur{% endblock %}

{% block page_title %}Notes Personnelles{% endblock %}

{% block content %}
            <div class="row">
                <div class="col-lg-8">
                    <!-- Notes personnelles -->
                    <div class="card shadow mb-4">
                        <div class="card-header py-3 d-flex justify-content-between align-items-center">
                            <h6 class="m-0 font-weight-bold text-primary">Vos notes personnelles</h6>
                            <small class="text-muted">
                                <i class="fas fa-save me-1"></i>Sauvegarde automatique
                            </small>
                        </div>
                        <div class="card-body">
                            <form method="post">
                                <div class="mb-3">
                                    <label for="notes" class="form-label">
                                        <i class="fas fa-edit me-1"></i>Vos notes et idées
                                    </label>
                                    <textarea class="form-control" id="notes" name="notes" 
                                              rows="15" 
                                              placeholder="Utilisez cet espace pour noter vos idées, tâches à faire, remarques importantes...

Quelques suggestions d'utilisation :
• Fonctionnalités à demander
• Bugs ou problèmes rencontrés
• Idées d'amélioration
• Notes de réunion
• Contacts importants
• Rappels personnels

Cet espace est privé et n'est visible que par vous.">{{ preferences.notes }}</textarea>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-save me-1"></i>Sauvegarder les notes
                                    </button>
                                    
                                    <div class="text-muted small">
                                        {% if preferences.updatedAt %}
                                            <i class="fas fa-clock me-1"></i>
                                            Dernière modification : {{ preferences.updatedAt|date('d/m/Y à H:i') }}
                                        {% endif %}
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <!-- Aide et raccourcis -->
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-info">Aide & Raccourcis</h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <h6 class="text-secondary">Fonctionnalités</h6>
                                <ul class="text-muted small">
                                    <li>Sauvegarde automatique lors de la frappe</li>
                                    <li>Format Markdown supporté</li>
                                    <li>Historique des modifications</li>
                                    <li>Recherche dans vos notes</li>
                                </ul>
                            </div>

                            <div class="mb-3">
                                <h6 class="text-secondary">Raccourcis clavier</h6>
                                <div class="text-muted small">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span>Sauvegarder :</span>
                                        <kbd>Ctrl + S</kbd>
                                    </div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span>Rechercher :</span>
                                        <kbd>Ctrl + F</kbd>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Plein écran :</span>
                                        <kbd>F11</kbd>
                                    </div>
                                </div>
                            </div>

                            <div class="alert alert-info">
                                <i class="fas fa-lightbulb me-1"></i>
                                <strong>Astuce :</strong> Vos notes sont synchronisées en temps réel et sauvegardées automatiquement.
                            </div>
                        </div>
                    </div>

                    <!-- Statistiques -->
                    <div class="card shadow">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-success">Statistiques</h6>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-6">
                                    <div class="mb-2">
                                        <span class="h4 text-primary" id="character-count">0</span>
                                    </div>
                                    <small class="text-muted">Caractères</small>
                                </div>
                                <div class="col-6">
                                    <div class="mb-2">
                                        <span class="h4 text-success" id="word-count">0</span>
                                    </div>
                                    <small class="text-muted">Mots</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const notesTextarea = document.getElementById('notes');
    const characterCount = document.getElementById('character-count');
    const wordCount = document.getElementById('word-count');
    let saveTimeout;

    function updateStats() {
        const text = notesTextarea.value;
        characterCount.textContent = text.length;
        
        const words = text.trim().split(/\s+/).filter(word => word.length > 0);
        wordCount.textContent = words.length;
    }

    function autoSave() {
        clearTimeout(saveTimeout);
        saveTimeout = setTimeout(() => {
            // Auto-save logic here
            console.log('Auto-saving notes...');
        }, 2000);
    }

    // Raccourcis clavier
    document.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.key === 's') {
            e.preventDefault();
            document.querySelector('form').submit();
        }
    });

    notesTextarea.addEventListener('input', function() {
        updateStats();
        autoSave();
    });

    // Initial stats
    updateStats();
});
</script>
{% endblock %}