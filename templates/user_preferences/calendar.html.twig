{% extends 'user_preferences/_base.html.twig' %}

{% block title %}Calendriers Google - Paramétrage Utilisateur{% endblock %}

{% block page_title %}Calendriers Google{% endblock %}

{% block content %}
            <div class="row">
                <div class="col-12">
                    {% if calendar_error %}
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>{{ calendar_error }}
                        </div>
                    {% endif %}

                    <!-- Configuration calendriers -->
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">Sélection des calendriers à afficher</h6>
                        </div>
                        <div class="card-body">
                            {% if available_calendars|length > 0 %}
                                <form method="post">
                                    <p class="text-muted mb-4">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Cochez les calendriers que vous souhaitez voir dans votre tableau de bord commercial.
                                    </p>

                                    <div class="row">
                                        {% for calendar in available_calendars %}
                                        <div class="col-md-6 mb-3">
                                            <div class="card border-left-{{ calendar.primary ? 'primary' : 'secondary' }}">
                                                <div class="card-body py-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" 
                                                               name="selected_calendars[]" 
                                                               value="{{ calendar.id }}" 
                                                               id="calendar_{{ loop.index }}"
                                                               {{ calendar.id in selected_calendar_ids ? 'checked' : '' }}>
                                                        <label class="form-check-label" for="calendar_{{ loop.index }}">
                                                            <strong>{{ calendar.summary }}</strong>
                                                            {% if calendar.primary %}
                                                                <span class="badge bg-primary ms-2">Principal</span>
                                                            {% endif %}
                                                        </label>
                                                    </div>
                                                    {% if calendar.description %}
                                                        <small class="text-muted d-block mt-1">{{ calendar.description }}</small>
                                                    {% endif %}
                                                    <small class="text-muted d-block mt-1">
                                                        <i class="fas fa-eye me-1"></i>Visibilité : {{ calendar.access_role }}
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                        {% endfor %}
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mt-4">
                                        <button type="submit" class="btn btn-success">
                                            <i class="fas fa-save me-1"></i>Sauvegarder la sélection
                                        </button>
                                        
                                        <small class="text-muted">
                                            <i class="fas fa-sync-alt me-1"></i>
                                            Synchronisation automatique toutes les 15 minutes
                                        </small>
                                    </div>
                                </form>
                            {% else %}
                                <div class="text-center py-5">
                                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">Aucun calendrier disponible</h5>
                                    <p class="text-muted">
                                        Assurez-vous d'avoir configuré l'accès à Google Calendar dans les paramètres de l'application.
                                    </p>
                                    <a href="{{ path('app_user_preferences_general') }}" class="btn btn-primary">
                                        <i class="fas fa-cog me-1"></i>Configurer l'accès Google
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Statut synchronisation -->
                    <div class="card shadow">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-success">Statut de la synchronisation</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-secondary">Statut :</span>
                                        <span class="badge bg-success">
                                            <i class="fas fa-check me-1"></i>Connecté
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-secondary">Dernière synchro :</span>
                                        <small class="text-muted">{{ "now"|date('d/m/Y à H:i') }}</small>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-secondary">Calendriers actifs :</span>
                                        <span class="badge bg-info">{{ selected_calendar_ids|length }}</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-center">
                                        <button class="btn btn-outline-primary btn-sm" onclick="forceSync()">
                                            <i class="fas fa-sync-alt me-1"></i>Forcer la synchronisation
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
{% endblock %}

{% block javascripts %}
<script>
function forceSync() {
    // Simulation d'une synchronisation forcée
    const button = event.target;
    const icon = button.querySelector('i');
    
    button.disabled = true;
    icon.classList.add('fa-spin');
    
    setTimeout(() => {
        button.disabled = false;
        icon.classList.remove('fa-spin');
        
        // Afficher un message de succès
        const alert = document.createElement('div');
        alert.className = 'alert alert-success alert-dismissible fade show mt-3';
        alert.innerHTML = `
            <i class="fas fa-check me-2"></i>Synchronisation réussie !
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        button.closest('.card-body').appendChild(alert);
        
        // Supprimer l'alerte après 3 secondes
        setTimeout(() => {
            alert.remove();
        }, 3000);
    }, 2000);
}

document.addEventListener('DOMContentLoaded', function() {
    // Auto-submit du formulaire quand on change une checkbox
    const checkboxes = document.querySelectorAll('input[name="selected_calendars[]"]');
    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            // Optionnel : auto-save après un délai
            // setTimeout(() => this.form.submit(), 1000);
        });
    });
});
</script>
{% endblock %}