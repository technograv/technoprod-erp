            </li>

            <!-- 5. PRODUITS & SERVICES -->
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#produits-services" role="tab">
                    <i class="fas fa-box me-2"></i>Produits & Services
                </a>
            </li>

