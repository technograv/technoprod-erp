{% extends 'base.html.twig' %}

{% block title %}Modifier {{ fournisseur.raisonSociale }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin_fournisseur_index') }}">Fournisseurs</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin_fournisseur_show', {id: fournisseur.id}) }}">{{ fournisseur.raisonSociale }}</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>

    <h1 class="mb-4"><i class="fas fa-edit"></i> Modifier {{ fournisseur.raisonSociale }}</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <h5 class="card-title border-bottom pb-2 mb-3">Informations générales</h5>
                        <div class="row">
                            <div class="col-md-3">
                                {{ form_row(form.code) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.raisonSociale) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.formeJuridique) }}
                            </div>
                        </div>

                        <h5 class="card-title border-bottom pb-2 mb-3 mt-4">Identifiants légaux</h5>
                        <div class="row">
                            <div class="col-md-3">
                                {{ form_row(form.siren) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.siret) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.numeroTVA) }}
                            </div>
                            <div class="col-md-3">
                                {{ form_row(form.codeNAF) }}
                            </div>
                        </div>

                        <h5 class="card-title border-bottom pb-2 mb-3 mt-4">Contact</h5>
                        <div class="row">
                            <div class="col-md-4">
                                {{ form_row(form.email) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.telephone) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.siteWeb) }}
                            </div>
                        </div>

                        <h5 class="card-title border-bottom pb-2 mb-3 mt-4">Conditions commerciales</h5>
                        <div class="row">
                            <div class="col-md-4">
                                {{ form_row(form.conditionsPaiement) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.modeReglement) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.remiseGenerale) }}
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                {{ form_row(form.statut) }}
                            </div>
                        </div>

                        {{ form_row(form.notesInternes) }}

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('admin_fournisseur_show', {id: fournisseur.id}) }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light mb-3">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> Informations
                </div>
                <div class="card-body">
                    <p class="small mb-1"><strong>Créé le:</strong></p>
                    <p>{{ fournisseur.createdAt|date('d/m/Y H:i') }}</p>
                    <p class="small mb-1"><strong>Modifié le:</strong></p>
                    <p>{{ fournisseur.updatedAt|date('d/m/Y H:i') }}</p>
                </div>
            </div>

            <div class="card bg-light">
                <div class="card-header">
                    <i class="fas fa-chart-bar"></i> Statistiques
                </div>
                <div class="card-body">
                    <p class="mb-1">
                        <strong>Produits (fournisseur principal):</strong>
                        <span class="badge bg-primary">{{ fournisseur.produitsCommeDefaut|length }}</span>
                    </p>
                    <p class="mb-1">
                        <strong>Contacts:</strong>
                        <span class="badge bg-info">{{ fournisseur.contacts|length }}</span>
                    </p>
                    <p class="mb-0">
                        <strong>Adresses:</strong>
                        <span class="badge bg-info">{{ fournisseur.adresses|length }}</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
