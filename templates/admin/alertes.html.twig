// Lancer la détection manuelle des alertes
function lancerDetectionAlertes() {
    const btn = document.getElementById('btn-scan-alertes');
    const originalHtml = btn.innerHTML;

    // Désactiver le bouton et afficher un spinner
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Scan en cours...';

    fetch('/admin/alertes/scan', {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        btn.disabled = false;
        btn.innerHTML = originalHtml;

        if (data.success) {
            // Afficher un toast de succès
            const toast = document.createElement('div');
            toast.className = 'toast align-items-center text-bg-success border-0 position-fixed';
            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999;';
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-check-circle me-2"></i><strong>Scan terminé !</strong><br>
                        <small>${data.message}</small><br>
                        <small>${data.statistics.instances_non_resolues} instance(s) non résolue(s) au total</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            document.body.appendChild(toast);
            const bsToast = new bootstrap.Toast(toast, { autohide: true, delay: 5000 });
            bsToast.show();
            setTimeout(() => toast.remove(), 6000);

            // Recharger la liste des alertes pour mettre à jour les compteurs
            chargerAlertesAdmin();
        } else {
            alert('Erreur: ' + data.message);
        }
    })
    .catch(error => {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        console.error('Erreur lors du scan:', error);
        alert('Erreur de communication avec le serveur');
    });
}

