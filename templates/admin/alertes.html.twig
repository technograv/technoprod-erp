// Charger les champs d'une entité
function chargerChampsEntite() {
    const entityClass = document.getElementById('configEntity').value;
    const nameFieldSelect = document.getElementById('configNameField');

    if (!entityClass) {
        nameFieldSelect.innerHTML = '<option value="">Sélectionnez d\'abord une entité...</option>';
        nameFieldSelect.disabled = true;
        entityFields = [];
        entityRelations = [];
        return Promise.resolve(); // Retourner une Promise résolue
    }

    // Afficher un loader
    nameFieldSelect.innerHTML = '<option value="">Chargement...</option>';
    nameFieldSelect.disabled = true;

    // Encoder le nom de classe pour l'URL
    const encodedClass = encodeURIComponent(entityClass);

    return fetch('/admin/alertes/entity-fields/' + encodedClass, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            entityFields = data.fields;
            entityRelations = data.relations;

            // Remplir le select du champ nom
            nameFieldSelect.innerHTML = '<option value="">Sélectionnez un champ...</option>';

            // Ajouter l'option ID
            const idOption = document.createElement('option');
            idOption.value = 'id';
            idOption.textContent = 'ID (identifiant)';
            nameFieldSelect.appendChild(idOption);

            // Ajouter les champs
            data.fields.forEach(field => {
                const option = document.createElement('option');
                option.value = field.name;
                option.textContent = field.label + ' (' + field.type + ')';
                nameFieldSelect.appendChild(option);
            });

            nameFieldSelect.disabled = false;
        } else {
            nameFieldSelect.innerHTML = '<option value="">Erreur de chargement</option>';
            alert('Erreur: ' + (data.message || 'Impossible de charger les champs'));
        }
    })
    .catch(error => {
        console.error('Erreur chargement champs:', error);
        nameFieldSelect.innerHTML = '<option value="">Erreur de chargement</option>';
        alert('Erreur de communication avec le serveur');
    });
}

// Ajouter une condition
function ajouterCondition() {
    // Vérifier qu'une entité a été sélectionnée
    const entityClass = document.getElementById('configEntity').value;
    if (!entityClass) {
        alert('Veuillez d\'abord sélectionner un type d\'entité');
        return;
    }

    if (entityFields.length === 0 && entityRelations.length === 0) {
        alert('Les champs de l\'entité n\'ont pas encore été chargés. Veuillez patienter...');
        return;
    }

    const conditionId = 'condition_' + Date.now();
    const conditionDiv = document.createElement('div');
    conditionDiv.className = 'card mb-2';
    conditionDiv.id = conditionId;
    conditionDiv.innerHTML = `
        <div class="card-body p-3">
            <div class="row align-items-end">
                <div class="col-md-4">
                    <label class="form-label small">Type de condition</label>
                    <select class="form-select form-select-sm condition-type" data-id="${conditionId}" onchange="updateConditionFields('${conditionId}')">
                        <option value="field_empty">Champ vide</option>
                        <option value="field_not_empty">Champ non vide</option>
                        <option value="field_duplicate">Doublons détectés (même valeur)</option>
                        <option value="relation_empty">Relation vide</option>
                        <option value="relation_not_empty">Relation non vide</option>
                        <option value="field_equals">Champ égal à</option>
                        <option value="field_not_equals">Champ différent de</option>
                        <option value="number_less_than">Nombre inférieur à</option>
                        <option value="number_greater_than">Nombre supérieur à</option>
                        <option value="date_before">Date avant maintenant</option>
                        <option value="date_after">Date après maintenant</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Champ</label>
                    <select class="form-select form-select-sm condition-field" data-id="${conditionId}">
                        <option value="">Sélectionnez...</option>
                    </select>
                </div>
                <div class="col-md-3 condition-value-container" style="display: none;">
                    <label class="form-label small">Valeur</label>
                    <input type="text" class="form-control form-control-sm condition-value" data-id="${conditionId}">
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-sm btn-danger" onclick="supprimerCondition('${conditionId}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;

    const container = document.getElementById('conditionsList');
    const placeholder = container.querySelector('p.text-muted');
    if (placeholder) {
        placeholder.remove();
    }
    container.appendChild(conditionDiv);

    // Remplir le select avec les champs par défaut
    updateConditionFields(conditionId);
    updateConditionsCount();
}

// Mettre à jour les champs selon le type de condition
function updateConditionFields(conditionId) {
    const conditionDiv = document.getElementById(conditionId);
    const typeSelect = conditionDiv.querySelector('.condition-type');
    const valueContainer = conditionDiv.querySelector('.condition-value-container');
    const fieldSelect = conditionDiv.querySelector('.condition-field');
    const fieldLabel = conditionDiv.querySelector('.col-md-4:nth-child(2) label');

    const type = typeSelect.value;
    const needsValue = ['field_equals', 'field_not_equals', 'number_less_than', 'number_greater_than'].includes(type);
    const isRelation = ['relation_empty', 'relation_not_empty'].includes(type);

    // Afficher/masquer le champ valeur
    valueContainer.style.display = needsValue ? 'block' : 'none';

    // Changer le label selon le type
    fieldLabel.textContent = isRelation ? 'Relation' : 'Champ';

    // Ajuster les colonnes
    if (needsValue) {
        conditionDiv.querySelector('.col-md-4:nth-child(2)').className = 'col-md-3';
    } else {
        conditionDiv.querySelector('.col-md-4:nth-child(2)').className = 'col-md-4';
    }

    // Remplir le select avec les champs ou relations appropriés
    fieldSelect.innerHTML = '<option value="">Sélectionnez...</option>';

    if (isRelation) {
        // Afficher uniquement les relations de type collection
        entityRelations.forEach(relation => {
            if (relation.type === 'collection') {
                const option = document.createElement('option');
                option.value = relation.name;
                option.textContent = relation.label + ' (collection)';
                fieldSelect.appendChild(option);
            }
        });
    } else {
        // Afficher les champs appropriés selon le type de condition
        entityFields.forEach(field => {
            const option = document.createElement('option');
            option.value = field.name;
            option.textContent = field.label + ' (' + field.type + ')';
            fieldSelect.appendChild(option);
        });
    }
}

// Supprimer une condition
function supprimerCondition(conditionId) {
    document.getElementById(conditionId).remove();
    updateConditionsCount();

    const container = document.getElementById('conditionsList');
    if (container.children.length === 0) {
        container.innerHTML = '<p class="text-muted mb-2"><i class="fas fa-info-circle me-1"></i>Ajoutez des conditions pour détecter les entités problématiques</p>';
    }
}

// Mettre à jour le compteur de conditions
function updateConditionsCount() {
    const count = document.querySelectorAll('#conditionsList .card').length;
    document.getElementById('conditionsCount').textContent = count;
}

// Sauvegarder l'alerte configurable
function sauvegarderAlerteConfigurable() {
    // Récupérer les données du formulaire
    const nom = document.getElementById('configNom').value;
    const description = document.getElementById('configDescription').value;
    const severity = document.getElementById('configSeverity').value;
    const entity = document.getElementById('configEntity').value;
    const nameField = document.getElementById('configNameField').value;
    const messageTemplate = document.getElementById('configMessageTemplate').value;
    const actif = document.getElementById('configActif').checked;

    // Validation
    if (!nom || !entity || !nameField || !messageTemplate) {
        alert('Veuillez remplir tous les champs obligatoires (*)');
        return;
    }

    // Récupérer les conditions
    const conditions = [];
    document.querySelectorAll('#conditionsList .card').forEach(card => {
        const id = card.id;
        const type = card.querySelector('.condition-type').value;
        const field = card.querySelector('.condition-field').value;
        const valueInput = card.querySelector('.condition-value');

        if (!field) {
            alert('Toutes les conditions doivent avoir un champ ou une relation');
            return;
        }

        const condition = { type };

        // Déterminer si c'est un champ ou une relation
        if (['relation_empty', 'relation_not_empty'].includes(type)) {
            condition.relation = field;
        } else {
            condition.field = field;
        }

        // Ajouter la valeur si nécessaire
        if (['field_equals', 'field_not_equals', 'number_less_than', 'number_greater_than'].includes(type)) {
            condition.value = valueInput.value;
        }

        conditions.push(condition);
    });

    if (conditions.length === 0) {
        alert('Vous devez ajouter au moins une condition de détection');
        return;
    }

    // Récupérer les rôles cibles
    const rolesCibles = [];
    document.querySelectorAll('.config-role:checked').forEach(input => {
        rolesCibles.push(input.value);
    });

    // Construire la configuration JSON
    const configuration = {
        entity: entity,
        conditions: conditions,
        message_template: messageTemplate,
        name_field: nameField
    };

    // Construire les données du type d'alerte
    const data = {
        nom: nom,
        description: description,
        severity: severity,
        classeDetection: 'App\\Service\\AlerteDetection\\ConfigurableDetector',
        actif: actif,
        rolesCibles: rolesCibles,
        configuration: configuration
    };

    // Envoyer au serveur
    const csrfToken = document.querySelector('meta[name=csrf-token]')?.content;
    const headers = {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
    };
    if (csrfToken) {
        headers['X-CSRF-Token'] = csrfToken;
    }

    fetch('/admin/alertes/type/create', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('alerteConfigurableModal')).hide();
            chargerAlertesAdmin();

            // Notification succès
            const toast = document.createElement('div');
            toast.className = 'toast align-items-center text-bg-success border-0 position-fixed';
            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999;';
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-check me-2"></i>Alerte automatique créée avec succès
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            `;
            document.body.appendChild(toast);
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
            setTimeout(() => toast.remove(), 5000);
        } else {
            alert('Erreur: ' + (data.message || 'Erreur inconnue'));
        }
    })
    .catch(error => {
        console.error('Erreur création alerte configurable:', error);
        alert('Erreur lors de la création de l\'alerte');
    });
}

// Éditer une alerte configurable existante
function editerAlerteConfigurable(alerteType) {
    // Stocker l'ID pour la mise à jour
    currentEditingTypeId = alerteType.id;

    // Pré-remplir les champs de base
    document.getElementById('configNom').value = alerteType.nom;
    document.getElementById('configDescription').value = alerteType.description || '';
    document.getElementById('configSeverity').value = alerteType.severity;
    document.getElementById('configActif').checked = alerteType.actif;

    // Récupérer la configuration
    const config = alerteType.configuration || {};

    // Pré-remplir l'entité
    const entitySelect = document.getElementById('configEntity');
    entitySelect.value = config.entity || '';

    // Charger les champs de l'entité
    if (config.entity) {
        chargerChampsEntite().then(() => {
            // Après le chargement des champs, sélectionner le champ nom
            document.getElementById('configNameField').value = config.name_field || 'id';

            // Recréer les conditions
            document.getElementById('conditionsList').innerHTML = '';
            if (config.conditions && config.conditions.length > 0) {
                config.conditions.forEach(condition => {
                    ajouterConditionAvecDonnees(condition);
                });
            } else {
                document.getElementById('conditionsList').innerHTML = '<p class="text-muted mb-2"><i class="fas fa-info-circle me-1"></i>Ajoutez des conditions pour détecter les entités problématiques</p>';
            }
            updateConditionsCount();
        });
    }

    // Pré-remplir le template de message
    document.getElementById('configMessageTemplate').value = config.message_template || 'Problème détecté pour {entity_name}';

    // Cocher les rôles cibles
    document.querySelectorAll('.config-role').forEach(checkbox => {
        checkbox.checked = alerteType.rolesCibles && alerteType.rolesCibles.includes(checkbox.value);
    });

    // Changer le titre et le bouton
    document.querySelector('#alerteConfigurableModal .modal-title').innerHTML = '<i class="fas fa-edit me-2"></i>Modifier l\'alerte automatique';
    document.querySelector('#alerteConfigurableModal .modal-footer .btn-success').innerHTML = '<i class="fas fa-save me-1"></i>Mettre à jour';
    document.querySelector('#alerteConfigurableModal .modal-footer .btn-success').setAttribute('onclick', 'sauvegarderAlerteConfigurableEdit()');

    // Ouvrir le modal
    const modal = new bootstrap.Modal(document.getElementById('alerteConfigurableModal'));
    modal.show();
}

