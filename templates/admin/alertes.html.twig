<style>
.alert-dismissible {
    transition: all 0.3s ease;
}
.table-responsive {
    border-radius: 0.5rem;
    overflow: hidden;
}
.badge-type {
    font-size: 0.75rem;
    padding: 0.4rem 0.6rem;
}
.cursor-pointer {
    cursor: pointer;
}
.cursor-pointer:hover {
    opacity: 0.8;
    transform: scale(1.05);
    transition: all 0.2s ease;
}
.sortable-ghost {
    opacity: 0.4;
    background: #f0f0f0;
}
.drag-handle:hover {
    color: #0d6efd !important;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
let allAlertes = []; // Stocker toutes les alertes pour le filtrage

function initAlertes() {
    console.log('🔍 [DEBUG ALERTES] initAlertes() starting');
    console.log('🔍 [DEBUG ALERTES] Auto-loading alertes on init');

    // Charger automatiquement les alertes au démarrage
    chargerAlertesAdmin();
}

// Charger les alertes pour l'admin
function chargerAlertesAdmin() {
    console.log('🔍 [DEBUG ALERTES] chargerAlertesAdmin() starting');

    const loading = document.getElementById('alertes-admin-loading');
    const container = document.getElementById('alertes-admin-container');
    const empty = document.getElementById('alertes-admin-empty');

    console.log('🔍 [DEBUG ALERTES] Elements for loading:');
    console.log('🔍 [DEBUG ALERTES] - loading:', loading);
    console.log('🔍 [DEBUG ALERTES] - container:', container);
    console.log('🔍 [DEBUG ALERTES] - empty:', empty);

    if (loading) loading.style.display = 'block';
    if (container) container.style.display = 'none';
    if (empty) empty.style.display = 'none';

    console.log('🔍 [DEBUG ALERTES] Starting fetch to {{ path('app_admin_alertes') }}');

    // Récupérer le token CSRF depuis l'en-tête de la page principale
    let csrfToken = null;
    const csrfMeta = document.querySelector('meta[name="csrf-token"]');
    if (csrfMeta) {
        csrfToken = csrfMeta.getAttribute('content');
        console.log('🔍 [DEBUG ALERTES] CSRF token found:', csrfToken ? 'YES' : 'NO');
    } else {
        console.log('🔍 [DEBUG ALERTES] CSRF token meta not found');
    }

    const headers = { 'X-Requested-With': 'XMLHttpRequest' };
    if (csrfToken) {
        headers['X-CSRF-Token'] = csrfToken;
    }

    fetch('{{ path('app_admin_alertes') }}', {
        method: 'GET',
        headers: headers
    })
    .then(response => {
        console.log('🔍 [DEBUG ALERTES] Fetch response received:', response);
        console.log('🔍 [DEBUG ALERTES] Response status:', response.status);
        console.log('🔍 [DEBUG ALERTES] Response URL:', response.url);

        // Vérifier si on a été redirigé vers la page de login
        if (response.url.includes('/login') || response.status === 302) {
            console.error('❌ [DEBUG ALERTES] Redirected to login - authentication issue');
            throw new Error('Authentification expirée');
        }

        if (!response.ok) {
            console.error('❌ [DEBUG ALERTES] HTTP error:', response.status, response.statusText);
            throw new Error('Erreur HTTP: ' + response.status);
        }

        return response.json();
    })
    .then(data => {
        console.log('🔍 [DEBUG ALERTES] JSON data received:', data);
        if (loading) loading.style.display = 'none';

        if (data.alertes && data.alertes.length === 0) {
            console.log('🔍 [DEBUG ALERTES] No alertes found, showing empty');
            if (empty) empty.style.display = 'block';
        } else if (data.alertes) {
            console.log('🔍 [DEBUG ALERTES] Alertes found:', data.alertes.length);
            allAlertes = data.alertes; // Stocker pour le filtrage
            if (container) container.style.display = 'block';
            afficherTableauAlertes(data.alertes);
        } else {
            console.error('❌ [DEBUG ALERTES] Invalid data format:', data);
        }
    })
    .catch(error => {
        console.error('❌ [DEBUG ALERTES] Fetch error:', error);
        if (loading) loading.style.display = 'none';

        // Afficher l'erreur dans la section empty
        if (empty) {
            empty.innerHTML = `
                <div class="text-center py-4">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3 text-danger"></i>
                    <h6 class="text-danger">Erreur de chargement des alertes</h6>
                    <p class="text-muted mb-3">${error.message}</p>
                    <button class="btn btn-outline-primary" onclick="chargerAlertesAdmin()">
                        <i class="fas fa-redo me-2"></i>Réessayer
                    </button>
                </div>
            `;
            empty.style.display = 'block';
        }

        if (container) container.style.display = 'none';
    });
}

// Afficher le tableau des alertes
function afficherTableauAlertes(alertes) {
    const tbody = document.getElementById('alertes-admin-tbody');
    let html = '';

    alertes.forEach(alerte => {
        // Badge source (manuel ou automatique)
        const sourceBadge = alerte.isManual
            ? '<span class="badge bg-info"><i class="fas fa-user-edit me-1"></i>Manuelle</span>'
            : '<span class="badge bg-warning text-dark"><i class="fas fa-robot me-1"></i>Auto</span>';

        const statusBadge = alerte.isActive ?
            '<span class="badge bg-success">Active</span>' :
            '<span class="badge bg-secondary">Inactive</span>';

        const typeBadge = `<span class="badge badge-type bg-${alerte.type === 'info' ? 'primary' : alerte.type}">${alerte.type.toUpperCase()}</span>`;

        const expiration = alerte.dateExpiration || '<span class="text-muted">Permanente</span>';
        const isExpired = alerte.isExpired ? ' <span class="badge bg-danger">Expirée</span>' : '';

        // Badge instances : pour les alertes auto, afficher le compteur cliquable
        let instancesBadge = '<span class="text-muted">-</span>';
        if (alerte.isAutomatic) {
            const badgeClass = alerte.instancesCount > 0 ? 'bg-danger' : 'bg-secondary';
            // Échapper les backslashes pour JavaScript
            const escapedDetectorClass = alerte.detectorClass.replace(/\\/g, '\\\\');
            instancesBadge = `<span class="badge ${badgeClass} cursor-pointer" onclick="voirInstancesAlerte('${escapedDetectorClass}')" title="Cliquer pour voir les instances">
                <i class="fas fa-exclamation-triangle me-1"></i>${alerte.instancesCount} instance${alerte.instancesCount > 1 ? 's' : ''}
            </span>`;
        }

        // Actions différentes selon le type
        let actionsHtml = '';
        if (alerte.isManual) {
            // Alertes manuelles : édition + suppression
            actionsHtml = `
                <button class="btn btn-outline-primary btn-sm me-1" onclick="modifierAlerte(${alerte.id})" title="Modifier">
                    <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-outline-danger btn-sm" onclick="supprimerAlerte(${alerte.id})" title="Supprimer">
                    <i class="fas fa-trash"></i>
                </button>
            `;
        } else {
            // Alertes automatiques : édition + suppression
            // Extraire l'ID numérique (retirer le préfixe 'type_')
            const typeId = alerte.id.toString().replace('type_', '');
            actionsHtml = `
                <button class="btn btn-outline-primary btn-sm me-1" onclick="modifierAlerteAutomatique(${typeId})" title="Configurer">
                    <i class="fas fa-cog"></i>
                </button>
                <button class="btn btn-outline-danger btn-sm" onclick="supprimerAlerte('${alerte.id}')" title="Supprimer">
                    <i class="fas fa-trash"></i>
                </button>
            `;
        }

        html += `
            <tr class="${alerte.isExpired ? 'text-muted' : ''}" data-id="${alerte.id}">
                <td class="drag-handle" style="cursor: move;"><i class="fas fa-grip-vertical text-muted"></i></td>
                <td>${sourceBadge}</td>
                <td>
                    <div class="fw-bold">${alerte.titre}</div>
                    <small class="text-muted">${alerte.message.substring(0, 80)}${alerte.message.length > 80 ? '...' : ''}</small>
                </td>
                <td>${typeBadge}</td>
                <td>${statusBadge}</td>
                <td>${instancesBadge}</td>
                <td>${expiration}${isExpired}</td>
                <td>
                    ${actionsHtml}
                </td>
            </tr>
        `;
    });

    tbody.innerHTML = html;

    // Initialiser le drag & drop après l'affichage
    initAlertesDragDrop();
}

// Initialiser le drag & drop pour les alertes
function initAlertesDragDrop() {
    const tbody = document.getElementById('alertes-admin-tbody');
    if (!tbody || tbody.children.length === 0) return;

    // Détruire l'instance existante si elle existe
    if (tbody.sortable) {
        tbody.sortable.destroy();
    }

    // Initialiser SortableJS
    tbody.sortable = Sortable.create(tbody, {
        animation: 150,
        handle: '.drag-handle',
        ghostClass: 'sortable-ghost',
        onEnd: function(evt) {
            // Récupérer l'ordre actuel
            const ordre = [];
            const rows = tbody.querySelectorAll('tr[data-id]');
            rows.forEach((row, index) => {
                ordre.push({
                    id: row.getAttribute('data-id'),
                    ordre: index + 1
                });
            });

            // Sauvegarder l'ordre via AJAX
            sauvegarderOrdreAlertes(ordre);
        }
    });
}

// Sauvegarder l'ordre des alertes
function sauvegarderOrdreAlertes(ordre) {
    const csrfMeta = document.querySelector('meta[name="csrf-token"]');
    const csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : null;

    const headers = {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
    };

    if (csrfToken) {
        headers['X-CSRF-Token'] = csrfToken;
    }

    fetch('/admin/alertes/ordre', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify({ ordre: ordre })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            console.log('✅ Ordre des alertes sauvegardé');
        } else {
            console.error('❌ Erreur sauvegarde ordre:', data.message);
        }
    })
    .catch(error => {
        console.error('❌ Erreur sauvegarde ordre:', error);
    });
}

// Voir les instances d'une alerte automatique
function voirInstancesAlerte(detectorClass) {
    const modal = new bootstrap.Modal(document.getElementById('instancesModal'));
    const loading = document.getElementById('instances-loading');
    const container = document.getElementById('instances-container');
    const empty = document.getElementById('instances-empty');
    const error = document.getElementById('instances-error');

    // Réinitialiser l'affichage
    loading.style.display = 'block';
    container.style.display = 'none';
    empty.style.display = 'none';
    error.style.display = 'none';

    // Extraire le nom court du détecteur pour le titre
    const detectorName = detectorClass.split('\\').pop().replace('Detector', '');
    document.getElementById('instancesModalTitle').innerHTML = '<i class="fas fa-list me-2"></i>Instances - ' + detectorName;

    // Ouvrir la modal
    modal.show();

    // Charger les instances
    fetch('/admin/alertes/instances/' + encodeURIComponent(detectorClass), {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('Erreur HTTP: ' + response.status);
        }
        return response.json();
    })
    .then(data => {
        loading.style.display = 'none';

        if (data.success && data.instances.length === 0) {
            empty.style.display = 'block';
        } else if (data.success && data.instances.length > 0) {
            container.style.display = 'block';
            document.getElementById('instances-info').textContent =
                data.total + ' instance' + (data.total > 1 ? 's' : '') + ' non résolue' + (data.total > 1 ? 's' : '');
            afficherInstancesTableau(data.instances);
        } else {
            throw new Error('Format de données invalide');
        }
    })
    .catch(err => {
        loading.style.display = 'none';
        error.style.display = 'block';
        document.getElementById('instances-error-message').textContent = err.message;
    });
}

// Afficher le tableau des instances
function afficherInstancesTableau(instances) {
    const tbody = document.getElementById('instances-tbody');
    let html = '';

    instances.forEach(instance => {
        const typeBadge = `<span class="badge bg-${instance.type === 'info' ? 'primary' : instance.type}">${instance.type.toUpperCase()}</span>`;

        // Générer le lien vers l'entité si disponible
        let editUrl = null;
        if (instance.entityType === 'App\\Entity\\Client') {
            editUrl = '/prospect/' + instance.entityId;
        } else if (instance.entityType === 'App\\Entity\\Contact' && instance.metadata.client_id) {
            editUrl = '/prospect/' + instance.metadata.client_id;
        }

        const actionsHtml = editUrl
            ? `<a href="${editUrl}" class="btn btn-sm btn-outline-primary" target="_blank" title="Voir l'entité">
                <i class="fas fa-external-link-alt"></i>
               </a>
               <button class="btn btn-sm btn-outline-success" onclick="resoudreInstance(${instance.id})" title="Marquer comme résolu">
                <i class="fas fa-check"></i>
               </button>`
            : `<button class="btn btn-sm btn-outline-success" onclick="resoudreInstance(${instance.id})" title="Marquer comme résolu">
                <i class="fas fa-check"></i>
               </button>`;

        html += `
            <tr data-instance-id="${instance.id}">
                <td>${instance.message}</td>
                <td><small class="text-muted">${instance.createdAt}</small></td>
                <td>${typeBadge}</td>
                <td>
                    ${actionsHtml}
                </td>
            </tr>
        `;
    });

    tbody.innerHTML = html;
}

// Résoudre une instance d'alerte (depuis l'admin)
function resoudreInstance(instanceId) {
    fetch('/admin/alertes/instance/' + instanceId + '/resolve', {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Retirer la ligne du tableau
            const row = document.querySelector('tr[data-instance-id="' + instanceId + '"]');
            if (row) {
                row.remove();
            }

            // Mettre à jour le compteur
            const tbody = document.getElementById('instances-tbody');
            const remainingCount = tbody.querySelectorAll('tr').length;

            if (remainingCount === 0) {
                // Plus d'instances, afficher l'état vide
                document.getElementById('instances-container').style.display = 'none';
                document.getElementById('instances-empty').style.display = 'block';
            } else {
                // Mettre à jour le texte du compteur
                document.getElementById('instances-info').textContent =
                    remainingCount + ' instance' + (remainingCount > 1 ? 's' : '') + ' non résolue' + (remainingCount > 1 ? 's' : '');
            }

            // Recharger les alertes pour mettre à jour le badge dans le tableau principal
            chargerAlertesAdmin();
        } else {
            alert('Erreur: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Erreur résolution:', error);
        alert('Erreur de communication avec le serveur');
    });
}

