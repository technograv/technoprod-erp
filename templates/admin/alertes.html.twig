// Sauvegarder alerte
function sauvegarderAlerte() {
    const form = document.getElementById('alerteForm');
    const formData = new FormData(form);
    const alerteId = document.getElementById('alerteId').value;
    
    // Récupérer les cibles cochées
    const cibles = [];
    document.querySelectorAll('input[name="cibles"]:checked').forEach(input => {
        cibles.push(input.value);
    });
    
    const data = {
        titre: formData.get('titre'),
        message: formData.get('message'),
        type: formData.get('type'),
        isActive: document.getElementById('alerteActive').checked,
        dismissible: document.getElementById('alerteDismissible').checked,
        dateExpiration: formData.get('dateExpiration') || null,
        cibles: cibles
    };

    // Ajouter l'ID pour les updates
    if (alerteId) {
        data.id = parseInt(alerteId);
    }
    
    const url = alerteId ? 
        `{{ path('app_admin_alerte_update', {id: '__ID__'}) }}`.replace('__ID__', alerteId) :
        '{{ path('app_admin_alerte_create') }}';
    const method = alerteId ? 'PUT' : 'POST';
    
    // Récupérer le token CSRF de manière sécurisée
    const csrfMeta = document.querySelector('meta[name="csrf-token"]');
    const csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : null;

    const headers = {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
    };

    if (csrfToken) {
        headers['X-CSRF-Token'] = csrfToken;
    }

    console.log('🔍 [DEBUG] Sauvegarde alerte - URL:', url);
    console.log('🔍 [DEBUG] Sauvegarde alerte - Method:', method);
    console.log('🔍 [DEBUG] Sauvegarde alerte - Data:', data);

    fetch(url, {
        method: method,
        headers: headers,
        body: JSON.stringify(data)
    })
    .then(response => {
        console.log('🔍 [DEBUG] Response status:', response.status);
        return response.json().then(data => {
            if (!response.ok) {
                // Lancer une erreur avec les données JSON
                throw { status: response.status, data: data };
            }
            return data;
        });
    })
    .then(data => {
        console.log('🔍 [DEBUG] Response data:', data);
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('alerteModal')).hide();
            console.log('🔍 [DEBUG ALERTES] Sauvegarde réussie - reloading alertes');
            chargerAlertesAdmin();

            // Notification succès
            const toast = document.createElement('div');
            toast.className = 'toast align-items-center text-bg-success border-0 position-fixed';
            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999;';
            toast.innerHTML = '<div class="d-flex"><div class="toast-body"><i class="fas fa-check me-2"></i>' + data.message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            document.body.appendChild(toast);
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
            setTimeout(() => toast.remove(), 5000);
        } else {
            console.error('❌ [DEBUG] Erreur serveur:', data);
            // Afficher les erreurs de validation de manière claire
            if (data.errors) {
                let errorMsg = 'Erreurs de validation :\n';
                for (let field in data.errors) {
                    errorMsg += '- ' + data.errors[field] + '\n';
                }
                alert(errorMsg);
            } else {
                alert('Erreur: ' + (data.message || 'Erreur inconnue'));
            }
        }
    })
    .catch(error => {
        console.error('❌ [DEBUG] Erreur sauvegarde alerte:', error);

        // Si c'est une erreur HTTP avec des données de validation
        if (error.data && error.data.errors) {
            let errorMsg = 'Erreurs de validation :\n';
            for (let field in error.data.errors) {
                errorMsg += '- ' + error.data.errors[field] + '\n';
            }
            alert(errorMsg);
        } else if (error.data && error.data.message) {
            alert('Erreur: ' + error.data.message);
        } else if (error.message) {
            alert('Erreur lors de la sauvegarde: ' + error.message);
        } else {
            alert('Erreur inconnue lors de la sauvegarde');
        }
    });
}

// Supprimer alerte
function supprimerAlerte(alerteId) {
    if (!confirm('Êtes-vous sûr de vouloir supprimer cette alerte ?')) {
        return;
    }

    // Récupérer le token CSRF de manière sécurisée
    const csrfMeta = document.querySelector('meta[name="csrf-token"]');
    const csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : null;

    const headers = {
        'X-Requested-With': 'XMLHttpRequest'
    };

    if (csrfToken) {
        headers['X-CSRF-Token'] = csrfToken;
    }

    // Vérifier si c'est une alerte automatique (type_XX) ou manuelle
    let url;
    if (alerteId.toString().startsWith('type_')) {
        // Alerte automatique (AlerteType)
        const typeId = alerteId.replace('type_', '');
        url = '/admin/alertes/type/' + typeId;
    } else {
        // Alerte manuelle
        url = '{{ path('app_admin_alerte_delete', {id: '__ID__'}) }}'.replace('__ID__', alerteId);
    }

    fetch(url, {
        method: 'DELETE',
        headers: headers
    })
    .then(response => {
        if (!response.ok) {
            return response.text().then(text => {
                throw new Error('HTTP ' + response.status + ': ' + text);
            });
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            console.log('✅ Suppression réussie - rechargement de la liste');

            // Toast de succès
            const toast = document.createElement('div');
            toast.className = 'toast align-items-center text-bg-success border-0 position-fixed';
            toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999;';
            toast.innerHTML = '<div class="d-flex"><div class="toast-body"><i class="fas fa-check me-2"></i>Alerte supprimée avec succès</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            document.body.appendChild(toast);
            const bsToast = new bootstrap.Toast(toast, { autohide: true, delay: 3000 });
            bsToast.show();
            setTimeout(() => toast.remove(), 4000);

            // Recharger la liste
            chargerAlertesAdmin();
        } else {
            alert('Erreur: ' + data.message);
        }
    })
    .catch(error => {
        console.error('❌ Erreur suppression alerte:', error);
        alert('Erreur lors de la suppression: ' + error.message);
    });
}

