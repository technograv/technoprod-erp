let conditionsData = [];
let entityFields = [];
let entityRelations = [];

// Ouvrir le modal de création d'alerte configurable
function ajouterAlerteConfigurable() {
    conditionsData = [];
    entityFields = [];
    entityRelations = [];
    document.getElementById('alerteConfigurableForm').reset();
    document.getElementById('conditionsList').innerHTML = '<p class="text-muted mb-2"><i class="fas fa-info-circle me-1"></i>Ajoutez des conditions pour détecter les entités problématiques</p>';
    updateConditionsCount();

    // Réinitialiser le champ nom
    const nameFieldSelect = document.getElementById('configNameField');
    nameFieldSelect.innerHTML = '<option value="">Sélectionnez d\'abord une entité...</option>';
    nameFieldSelect.disabled = true;

