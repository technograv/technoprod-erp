<script>
// =============== SYSTÈME DRAG & DROP HIÉRARCHIQUE AVEC SORTABLEJS ===============

// Styles CSS pour SortableJS
const sortableStyles = '<style>' +
'/* Styles drag & drop identiques aux autres onglets pour un rendu ergonomique */' +
'.sortable-ghost {' +
'    opacity: 0.4;' +
'}' +
