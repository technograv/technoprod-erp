'    box-shadow: 0 2px 8px rgba(0,0,0,0.1);' +
'}' +
'.drag-handle:hover {' +
'    color: #007bff;' +
'}' +
'/* Styles spécifiques pour la hiérarchie */' +
'.sortable-item[data-is-mere="true"] {' +
'    border-left: 4px solid #ffc107;' +
'}' +
'.sortable-item[data-is-mere="false"] {' +
'    border-left: 4px solid #6c757d;' +
'    padding-left: 1rem;' +
'}' +
'</style>';

// Injecter les styles CSS
document.head.insertAdjacentHTML('beforeend', sortableStyles);

// Instance globale du drag & drop sociétés
let dragDropSocietesInstance = null;

// Fonction de validation stricte pour les mouvements de sociétés
function validateSocieteDragDrop(draggedItem, targetPosition, allItems) {
    const draggedIsMere = draggedItem.dataset.isMere === 'true';
    const draggedParentId = draggedItem.dataset.parentId;
    const draggedName = draggedItem.querySelector('td:nth-child(2)')?.textContent.trim() || 'Unknown';

    // Si on déplace une filiale
    if (!draggedIsMere && draggedParentId) {
        // Une filiale ne peut JAMAIS être placée avant sa société mère
        const parentItem = allItems.find(item =>
            item.dataset.isMere === 'true' &&
            item.dataset.id === draggedParentId
        );

        if (parentItem) {
            const parentPosition = allItems.indexOf(parentItem);
            if (targetPosition <= parentPosition) {
                console.warn("❌ Une filiale ne peut pas être placée avant sa société mère");
                return false;
            }
        }

        // Une filiale ne peut changer de société mère
        const targetItem = allItems[targetPosition];
        if (targetItem) {
            const targetParentId = targetItem.dataset.parentId;
            const targetIsMere = targetItem.dataset.isMere === 'true';

            // Si on essaie de déplacer vers un autre groupe
            if (!targetIsMere && targetParentId && targetParentId !== draggedParentId) {
                console.warn("❌ Une filiale ne peut pas changer de société mère");
                return false;
            }
        }

        return true;
    }

    // Si on déplace une société mère
    if (draggedIsMere) {
        // Déterminer précisément où on veut insérer
        if (targetPosition === 0) {
            // Insertion en première position - toujours autorisé
            return true;
        }

        if (targetPosition >= allItems.length) {
            // Insertion en dernière position - toujours autorisé
            return true;
        }

        // Analyser la position cible
        const prevItem = allItems[targetPosition - 1];
        const targetItem = allItems[targetPosition];

        if (!prevItem || !targetItem) {
            return true; // Cas limite, on autorise
        }

        const prevIsMere = prevItem.dataset.isMere === 'true';
        const targetIsMere = targetItem.dataset.isMere === 'true';
        const targetParentId = targetItem.dataset.parentId;

        // CAS CRITIQUE : Vérifier si on essaie de s'insérer entre une mère et ses filiales
        if (prevIsMere && !targetIsMere && targetParentId === prevItem.dataset.id) {
            const prevName = prevItem.querySelector('td:nth-child(2)')?.textContent.trim() || 'Unknown';
            const targetName = targetItem.querySelector('td:nth-child(2)')?.textContent.trim() || 'Unknown';
            console.warn("❌ BLOQUÉ : Impossible d'insérer " + draggedName + " entre " + prevName + " et sa filiale " + targetName);
            return false;
        }

        // CAS : Insertion au milieu d'un groupe de filiales
        if (!targetIsMere && targetParentId) {
            // Vérifier si on est au milieu des filiales
            const prevParentId = prevItem.dataset.parentId;
            if (!prevIsMere && prevParentId === targetParentId) {
                console.warn("❌ BLOQUÉ : Impossible d'insérer " + draggedName + " au milieu des filiales du groupe " + targetParentId);
                return false;
            }
        }

        return true;
    }

    return true;
}

function initSocietesDragDrop() {
    console.log('🏢 Initialisation du drag & drop sociétés avec hiérarchie');

    // Vérifier que l'élément DOM existe
    const sortableContainer = document.getElementById('sortable-societes');
    if (!sortableContainer) {
        console.error('❌ Container #sortable-societes non trouvé, retry dans 200ms...');
        setTimeout(initSocietesDragDrop, 200);
        return;
    }

    // Vérifier que SortableJS est disponible
    if (typeof Sortable === 'undefined') {
        console.error('❌ SortableJS non disponible, retry dans 100ms...');
        setTimeout(initSocietesDragDrop, 100);
        return;
    }

    console.log('✅ Tous les prérequis sont disponibles, initialisation...');

    // Configuration SortableJS avec logique hiérarchique
    dragDropSocietesInstance = new Sortable(document.getElementById('sortable-societes'), {
        handle: '.drag-handle',
        animation: 150,
        ghostClass: 'sortable-ghost',
        chosenClass: 'sortable-chosen',
        dragClass: 'sortable-drag',
        filter: '.thead, .table-dark',
        preventOnFilter: false,
        forceFallback: true, // Force le fallback HTML5 pour Firefox
        fallbackTolerance: 3, // Tolérance en pixels pour Firefox

        // Logique de validation avant le déplacement
        onMove: function(evt) {
            const draggedItem = evt.dragged;
            const relatedItem = evt.related;
            const allItems = Array.from(document.getElementById('sortable-societes').querySelectorAll('.sortable-item'));

            // Calculer la position cible
            let targetPosition = allItems.indexOf(relatedItem);

            // Si on déplace vers le bas, ajuster la position
            const draggedPosition = allItems.indexOf(draggedItem);
            if (draggedPosition < targetPosition) {
                targetPosition--; // Ajuster car l'élément déplacé sera retiré
            }

            // Log pour debug
            const draggedName = draggedItem.querySelector('td:nth-child(2)')?.textContent.trim() || 'Unknown';
            const relatedName = relatedItem.querySelector('td:nth-child(2)')?.textContent.trim() || 'Unknown';
            console.log('🎯 Validation déplacement:', {
                dragged: draggedName,
                related: relatedName,
                targetPosition: targetPosition
            });

            // Utiliser notre fonction de validation centralisée
            return validateSocieteDragDrop(draggedItem, targetPosition, allItems);
        },

        onEnd: async function(evt) {
            console.log("🔄 Fin de déplacement, mise à jour de l'ordre...");

            // Vérifier si on a déplacé une société mère
            const draggedItem = evt.item;
            const draggedIsMere = draggedItem.dataset.isMere === 'true';
            const draggedId = draggedItem.dataset.id;

            if (draggedIsMere) {
                console.log("🏢 Société mère déplacée, repositionnement des filiales...");

                // Trouver toutes les sociétés filles de cette société mère
                const allItems = Array.from(document.getElementById('sortable-societes').querySelectorAll('.sortable-item'));
                const filiales = allItems.filter(item =>
                    item.dataset.isMere === 'false' &&
                    item.dataset.parentId === draggedId
                );

                if (filiales.length > 0) {
                    console.log(`📦 Déplacement de ${filiales.length} filiales après leur société mère`);

                    // Déplacer chaque filiale juste après la société mère
                    let insertAfter = draggedItem;
                    filiales.forEach(filiale => {
                        // Insérer après l'élément précédent (société mère ou filiale précédente)
                        insertAfter.parentNode.insertBefore(filiale, insertAfter.nextSibling);
                        insertAfter = filiale;
                    });

                    // Notification pour informer l'utilisateur
                    const mereNom = draggedItem.querySelector('strong')?.textContent || 'Société mère';
                    showNotification(`${filiales.length} filiale(s) de "${mereNom}" repositionnée(s) automatiquement`, 'info');
                }
            }

            // Récupérer l'ordre final après repositionnement éventuel des filiales
            const items = Array.from(document.getElementById('sortable-societes').querySelectorAll('.sortable-item'));
            const updates = [];

            items.forEach((item, index) => {
                const id = parseInt(item.dataset.id);
                if (!isNaN(id)) {
                    updates.push({
                        id: id,
                        ordre: index + 1
                    });
                }
            });

            console.log('📋 Nouvel ordre sociétés (avec filiales repositionnées):', updates);

            try {
                const response = await fetch('/admin/societes/reorder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ societes: updates })
                });

                const data = await response.json();

                if (data.success) {
                    console.log('✅ Ordre des sociétés mis à jour avec succès');
                    showNotification('Ordre des sociétés mis à jour avec succès', 'success');
                } else {
                    console.error('❌ Erreur lors de la mise à jour:', data.error);
                    showNotification("Erreur lors de la mise à jour de l'ordre", 'error');
                    setTimeout(() => rechargerOngletSocietes(), 1000);
                }
            } catch (error) {
                console.error('❌ Erreur lors de la sauvegarde:', error);
                showNotification('Erreur de communication avec le serveur', 'error');
                setTimeout(() => rechargerOngletSocietes(), 1000);
            }
        }
    });

    console.log('✅ Drag & drop sociétés initialisé avec succès');
}

function handleDragStart(e) {
    draggedElement = this;
    this.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/html', this.outerHTML);
}

function handleDragEnter(e) {
    e.preventDefault();
    this.classList.add('drag-over');
    draggedOverElement = this;
}

function handleDragOver(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    return false;
}

function handleDragLeave(e) {
    if (!this.contains(e.relatedTarget)) {
        this.classList.remove('drag-over');
    }
}

function handleDrop(e) {
    e.preventDefault();
    
    if (this !== draggedElement) {
        // Déterminer la position d'insertion
        const rect = this.getBoundingClientRect();
        const midpoint = rect.top + rect.height / 2;
        
        if (e.clientY < midpoint) {
            // Insérer avant cet élément
            this.parentNode.insertBefore(draggedElement, this);
        } else {
            // Insérer après cet élément
            this.parentNode.insertBefore(draggedElement, this.nextSibling);
        }
        
        // Sauvegarder le nouvel ordre
        saveNewOrder();
    }
    
    return false;
}

function handleDragEnd(e) {
    // Nettoyer les classes CSS
    const rows = document.querySelectorAll('.sortable-row');
    rows.forEach(row => {
        row.classList.remove('dragging', 'drag-over');
    });
    
    draggedElement = null;
    draggedOverElement = null;
}

function saveNewOrder() {
    const rows = document.querySelectorAll('#societesTable tbody .sortable-row');
    const societesOrder = [];
    
    rows.forEach((row) => {
        const societeId = row.getAttribute('data-id');
        if (societeId) {
            societesOrder.push(parseInt(societeId));
        }
    });
    
    if (societesOrder.length === 0) {
        return;
    }
    
    // Envoyer l'ordre au serveur
    fetch('{{ path('app_admin_societes_reorder')|e('js') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            societes: societesOrder
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification('Ordre des sociétés mis à jour avec succès', 'success');
            // Mettre à jour les attributs data-order
            const rows = document.querySelectorAll('#societesTable tbody .sortable-row');
            rows.forEach((row, index) => {
                row.setAttribute('data-order', index);
            });
        } else {
            showNotification("Erreur lors de la mise à jour de l'ordre", 'error');
            // Recharger en cas d'erreur pour restaurer l'ordre correct
            setTimeout(() => rechargerOngletSocietes(), 1000);
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        showNotification('Erreur de communication avec le serveur', 'error');
        setTimeout(() => rechargerOngletSocietes(), 1000);
    });
}

