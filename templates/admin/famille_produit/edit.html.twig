{% extends 'base.html.twig' %}

{% block title %}Modifier {{ famille.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin_famille_produit_index') }}">Familles de produits</a></li>
            <li class="breadcrumb-item active">{{ famille.libelle }}</li>
        </ol>
    </nav>

    <h1 class="mb-4"><i class="fas fa-edit"></i> Modifier {{ famille.libelle }}</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-4">
                                {{ form_row(form.code) }}
                            </div>
                            <div class="col-md-8">
                                {{ form_row(form.libelle) }}
                            </div>
                        </div>

                        {{ form_row(form.description) }}

                        <div class="row">
                            <div class="col-md-8">
                                {{ form_row(form.parent) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.ordre) }}
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            {{ form_widget(form.actif) }}
                            {{ form_label(form.actif) }}
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('admin_famille_produit_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light mb-3">
                <div class="card-header">
                    <i class="fas fa-chart-tree"></i> Hiérarchie
                </div>
                <div class="card-body">
                    <p class="small mb-1"><strong>Chemin complet:</strong></p>
                    <p class="text-primary">{{ famille.cheminComplet }}</p>
                    <p class="small mb-1"><strong>Niveau:</strong> {{ famille.niveau }}</p>
                </div>
            </div>

            <div class="card bg-light">
                <div class="card-header">
                    <i class="fas fa-info-circle"></i> Statistiques
                </div>
                <div class="card-body">
                    <p class="mb-1">
                        <strong>Sous-familles:</strong>
                        <span class="badge bg-info">{{ famille.enfants|length }}</span>
                    </p>
                    <p class="mb-0">
                        <strong>Produits:</strong>
                        <span class="badge bg-primary">{{ famille.produits|length }}</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
