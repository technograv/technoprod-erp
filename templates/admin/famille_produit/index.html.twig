{% extends 'base.html.twig' %}

{% block title %}Familles de produits - Administration{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-sitemap"></i> Familles de produits</h1>
        <a href="{{ path('admin_famille_produit_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvelle famille
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-body">
            {% if racines is empty %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Aucune famille de produits n'a encore été créée.
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Libellé</th>
                                <th>Sous-familles</th>
                                <th>Produits</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for famille in racines %}
                                {{ _self.famille_row(famille, 0) }}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% macro famille_row(famille, niveau) %}
    <tr data-id="{{ famille.id }}" class="famille-niveau-{{ niveau }}">
        <td>
            {% for i in 0..niveau %}
                {% if i > 0 %}<span class="text-muted">└─</span>{% endif %}
            {% endfor %}
            <strong>{{ famille.code }}</strong>
        </td>
        <td>{{ famille.libelle }}</td>
        <td>
            {% if famille.enfants|length > 0 %}
                <span class="badge bg-info">{{ famille.enfants|length }}</span>
            {% else %}
                <span class="text-muted">-</span>
            {% endif %}
        </td>
        <td>
            {% if famille.produits|length > 0 %}
                <span class="badge bg-primary">{{ famille.produits|length }}</span>
            {% else %}
                <span class="text-muted">-</span>
            {% endif %}
        </td>
        <td>
            {% if famille.actif %}
                <span class="badge bg-success">Actif</span>
            {% else %}
                <span class="badge bg-secondary">Inactif</span>
            {% endif %}
        </td>
        <td>
            <div class="btn-group btn-group-sm">
                <a href="{{ path('admin_famille_produit_edit', {id: famille.id}) }}"
                   class="btn btn-outline-primary" title="Modifier">
                    <i class="fas fa-edit"></i>
                </a>
                <button type="button"
                        class="btn btn-outline-{{ famille.actif ? 'warning' : 'success' }}"
                        onclick="toggleFamille({{ famille.id }})"
                        title="{{ famille.actif ? 'Désactiver' : 'Activer' }}">
                    <i class="fas fa-{{ famille.actif ? 'eye-slash' : 'eye' }}"></i>
                </button>
                <form method="post"
                      action="{{ path('admin_famille_produit_delete', {id: famille.id}) }}"
                      style="display:inline;"
                      onsubmit="return confirm('Confirmer la suppression ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ famille.id) }}">
                    <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
            </div>
        </td>
    </tr>

    {% for enfant in famille.enfants %}
        {{ _self.famille_row(enfant, niveau + 1) }}
    {% endfor %}
{% endmacro %}

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function toggleFamille(id) {
    fetch('/admin/famille-produit/' + id + '/toggle', {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            location.reload();
        }
    })
    .catch(function(error) {
        console.error('Erreur:', error);
        alert('Erreur lors du changement de statut');
    });
}
</script>
{% endblock %}
