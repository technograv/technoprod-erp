<h3 class="section-title">
    <i class="fas fa-exclamation-triangle me-2 text-warning"></i>Types d'alertes système
</h3>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">
                    <i class="fas fa-list me-2"></i>Types d'alertes configurés
                </h6>
                <div class="btn-group">
                    <button type="button" class="btn btn-success btn-sm" onclick="runAllDetections()">
                        <i class="fas fa-play me-1"></i>Lancer toutes les détections
                    </button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="ajouterTypeAlerte()">
                        <i class="fas fa-plus me-1"></i>Nouveau type
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div id="types-alerte-loading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="mt-2 text-muted">Chargement des types d'alertes...</div>
                </div>
                <div id="types-alerte-container" style="display: none;">
                    <div class="table-responsive">
                        <table class="table table-hover" id="sortable-types-alerte">
                            <thead>
                                <tr>
                                    <th width="30"><i class="fas fa-grip-vertical"></i></th>
                                    <th width="50">Ordre</th>
                                    <th>Nom</th>
                                    <th>Détecteur</th>
                                    <th width="80">Statut</th>
                                    <th width="100">Sévérité</th>
                                    <th width="80">Instances</th>
                                    <th width="120">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="types-alerte-tbody">
                                {% for type in types_alerte %}
                                    <tr data-id="{{ type.id }}"
                                        data-nom="{{ type.nom }}"
                                        data-description="{{ type.description ?? '' }}"
                                        data-classe-detection="{{ type.classeDetection }}"
                                        data-severity="{{ type.severity }}"
                                        data-ordre="{{ type.ordre }}"
                                        data-actif="{{ type.actif ? '1' : '0' }}"
                                        data-roles-cibles="{{ type.rolesCibles|default([])|json_encode|e('html_attr') }}"
                                        data-societes-cibles="{{ type.societesCibles|default([])|json_encode|e('html_attr') }}">
                                        <td class="text-center">
                                            <i class="fas fa-grip-vertical drag-handle"></i>
                                        </td>
                                        <td class="text-center"><strong>{{ type.ordre }}</strong></td>
                                        <td>
                                            <div class="fw-bold">{{ type.nom }}</div>
                                            {% if type.description %}<small class="text-muted">{{ type.description }}</small>{% endif %}
                                        </td>
                                        <td>
                                            <code class="small">{{ detecteurs[type.classeDetection].name ?? 'N/A' }}</code>
                                        </td>
                                        <td>
                                            {% if type.actif %}
                                                <span class="badge bg-success">Actif</span>
                                            {% else %}
                                                <span class="badge bg-secondary">Inactif</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% set severityColors = {'info': 'primary', 'warning': 'warning', 'danger': 'danger'} %}
                                            <span class="badge badge-severity bg-{{ severityColors[type.severity] ?? 'secondary' }}">{{ type.severity|upper }}</span>
                                        </td>
                                        <td class="text-center">
                                            {% set instancesCount = type.activeInstancesCount %}
                                            {% if instancesCount > 0 %}
                                                <a href="#" onclick="voirInstancesAlerte({{ type.id }}); return false;"
                                                   class="badge bg-warning text-decoration-none"
                                                   title="Cliquer pour voir les instances">
                                                    {{ instancesCount }}
                                                </a>
                                            {% else %}
                                                <span class="badge bg-secondary">0</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-success btn-sm me-1" onclick="lancerDetection({{ type.id }})" title="Lancer détection">
                                                <i class="fas fa-play"></i>
                                            </button>
                                            <button class="btn btn-outline-primary btn-sm me-1" onclick="modifierTypeAlerte({{ type.id }})" title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" onclick="supprimerTypeAlerte({{ type.id }})" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div id="types-alerte-empty" style="display: none;" class="text-center py-4 text-muted">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                    <h6>Aucun type d'alerte configuré</h6>
                    <p class="mb-0">Commencez par créer votre premier type d'alerte système.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Instances d'alertes -->
<div class="modal fade" id="instancesAlerteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-list me-2"></i><span id="instancesModalTitle">Instances d'alertes</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="instancesAlerteLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="mt-2">Chargement des instances...</div>
                </div>
                <div id="instancesAlerteContent" style="display: none;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Création/Édition Type Alerte -->
<div class="modal fade" id="typeAlerteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="typeAlerteModalTitle">
                    <i class="fas fa-exclamation-triangle me-2"></i>Nouveau type d'alerte
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="typeAlerteForm">
                    <input type="hidden" id="typeAlerteId" name="id">

                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label for="typeAlerteNom" class="form-label">Nom du type d'alerte *</label>
                                <input type="text" class="form-control" id="typeAlerteNom" name="nom" required maxlength="255">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="typeAlerteOrdre" class="form-label">Ordre d'affichage</label>
                                <input type="number" class="form-control" id="typeAlerteOrdre" name="ordre" min="0" value="0">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="typeAlerteDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="typeAlerteDescription" name="description" rows="2"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="typeAlerteDetecteur" class="form-label">Détecteur *</label>
                                <select class="form-select" id="typeAlerteDetecteur" name="classeDetection" required>
                                    <option value="">-- Choisir un détecteur --</option>
                                    {% for className, detector in detecteurs %}
                                        <option value="{{ className }}">{{ detector.name }}</option>
                                    {% endfor %}
                                </select>
                                <small class="form-text text-muted">Classe PHP responsable de la détection</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="typeAlerteSeverity" class="form-label">Sévérité</label>
                                <select class="form-select" id="typeAlerteSeverity" name="severity">
                                    <option value="info">Information (bleu)</option>
                                    <option value="warning" selected>Attention (orange)</option>
                                    <option value="danger">Danger (rouge)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Rôles cibles</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="roleAdmin" name="rolesCibles" value="ROLE_ADMIN">
                                    <label class="form-check-label" for="roleAdmin">Administrateurs</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="roleManager" name="rolesCibles" value="ROLE_MANAGER">
                                    <label class="form-check-label" for="roleManager">Managers</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="roleCommercial" name="rolesCibles" value="ROLE_COMMERCIAL">
                                    <label class="form-check-label" for="roleCommercial">Commerciaux</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="roleComptable" name="rolesCibles" value="ROLE_COMPTABLE">
                                    <label class="form-check-label" for="roleComptable">Comptables</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="roleUser" name="rolesCibles" value="ROLE_USER">
                                    <label class="form-check-label" for="roleUser">Utilisateurs</label>
                                </div>
                                <small class="form-text text-muted">Laissez vide pour afficher à tous les utilisateurs</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Sociétés cibles</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="touteSociete" onchange="toggleSocietes()">
                                    <label class="form-check-label" for="touteSociete">
                                        <strong>Toutes les sociétés</strong>
                                    </label>
                                </div>
                                <div id="societes-list">
                                    {% for societe in societes %}
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="societe{{ societe.id }}" name="societesCibles" value="{{ societe.id }}">
                                            <label class="form-check-label" for="societe{{ societe.id }}">{{ societe.nom }}</label>
                                        </div>
                                    {% endfor %}
                                </div>
                                <small class="form-text text-muted">Laissez vide pour afficher à toutes les sociétés</small>
                            </div>

                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="typeAlerteActif" name="actif" checked>
                                    <label class="form-check-label" for="typeAlerteActif">
                                        Type d'alerte actif
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="sauvegarderTypeAlerte()">
                    <i class="fas fa-save me-1"></i>Enregistrer
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.drag-handle {
    cursor: move;
    color: #6c757d;
}
.sortable-ghost {
    opacity: 0.4;
}
.badge-severity {
    font-size: 0.75rem;
    padding: 0.4rem 0.6rem;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
let dragDropTypesAlerteInstance;

function initTypesAlerte() {
    console.log('🔍 DEBUG: Initialisation des types d\'alertes admin');
    // Les données sont déjà chargées dans le template côté serveur
    // On initialise juste le drag & drop et on affiche le contenu
    const loading = document.getElementById('types-alerte-loading');
    const container = document.getElementById('types-alerte-container');
    const empty = document.getElementById('types-alerte-empty');
    const tbody = document.getElementById('types-alerte-tbody');

    // Vérifier si des types sont présents
    const hasTypes = tbody && tbody.children.length > 0;

    if (loading) loading.style.display = 'none';

    if (hasTypes) {
        if (container) container.style.display = 'block';
        if (empty) empty.style.display = 'none';
        initDragDropTypesAlerte();
    } else {
        if (container) container.style.display = 'none';
        if (empty) empty.style.display = 'block';
    }
}

function initDragDropTypesAlerte() {
    const tableBody = document.getElementById('types-alerte-tbody');
    if (tableBody && !dragDropTypesAlerteInstance) {
        dragDropTypesAlerteInstance = new Sortable(tableBody, {
            handle: '.drag-handle',
            animation: 150,
            ghostClass: 'sortable-ghost',
            onEnd: function(evt) {
                const rows = Array.from(evt.to.children);
                const reorderData = rows.map((row, index) => ({
                    id: parseInt(row.dataset.id),
                    ordre: index
                }));

                sauvegarderOrdreTypesAlerte(reorderData);
            }
        });
    }
}

function sauvegarderOrdreTypesAlerte(reorderData) {
    fetch('{{ path('app_admin_types_alerte_reorder') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ types: reorderData })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            console.error('Erreur réorganisation:', data.error);
            window.location.reload();
        }
    })
    .catch(error => {
        console.error('Erreur réorganisation:', error);
        window.location.reload();
    });
}

function ajouterTypeAlerte() {
    resetTypeAlerteForm();
    document.getElementById('typeAlerteModalTitle').innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>Nouveau type d\'alerte';
    const modal = new bootstrap.Modal(document.getElementById('typeAlerteModal'));
    modal.show();
}

function modifierTypeAlerte(typeId) {
    // Récupérer les données depuis les attributs data-* de la ligne
    const row = document.querySelector('tr[data-id="' + typeId + '"]');
    if (!row) {
        showToast('Type d\'alerte introuvable', 'error');
        return;
    }

    // Réinitialiser le formulaire
    resetTypeAlerteForm();

    // Remplir le formulaire avec les données du type
    document.getElementById('typeAlerteId').value = typeId;
    document.getElementById('typeAlerteNom').value = row.dataset.nom;
    document.getElementById('typeAlerteDescription').value = row.dataset.description || '';
    document.getElementById('typeAlerteDetecteur').value = row.dataset.classeDetection;
    document.getElementById('typeAlerteSeverity').value = row.dataset.severity;
    document.getElementById('typeAlerteOrdre').value = row.dataset.ordre;
    document.getElementById('typeAlerteActif').checked = row.dataset.actif === '1';

    // Cocher les rôles cibles
    try {
        const rolesCibles = JSON.parse(row.dataset.rolesCibles || '[]');
        if (Array.isArray(rolesCibles)) {
            rolesCibles.forEach(function(role) {
                const checkbox = document.querySelector('input[name="rolesCibles"][value="' + role + '"]');
                if (checkbox) checkbox.checked = true;
            });
        }
    } catch (e) {
        console.error('Erreur parsing roles_cibles:', e);
    }

    // Cocher les sociétés cibles
    try {
        const societesCibles = JSON.parse(row.dataset.societesCibles || '[]');
        if (Array.isArray(societesCibles)) {
            societesCibles.forEach(function(societeId) {
                const checkbox = document.getElementById('societe' + societeId);
                if (checkbox) checkbox.checked = true;
            });
        }
    } catch (e) {
        console.error('Erreur parsing societes_cibles:', e);
    }

    // Changer le titre de la modale
    document.getElementById('typeAlerteModalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>Modifier le type d\'alerte';

    // Afficher la modale
    const modal = new bootstrap.Modal(document.getElementById('typeAlerteModal'));
    modal.show();
}

function sauvegarderTypeAlerte() {
    const form = document.getElementById('typeAlerteForm');
    const formData = new FormData(form);
    const typeId = document.getElementById('typeAlerteId').value;

    const rolesCibles = [];
    document.querySelectorAll('input[name="rolesCibles"]:checked').forEach(input => {
        rolesCibles.push(input.value);
    });

    const societesCibles = [];
    document.querySelectorAll('input[name="societesCibles"]:checked').forEach(input => {
        societesCibles.push(parseInt(input.value));
    });

    const data = {
        nom: formData.get('nom'),
        description: formData.get('description'),
        classeDetection: formData.get('classeDetection'),
        severity: formData.get('severity'),
        ordre: parseInt(formData.get('ordre')) || 0,
        actif: document.getElementById('typeAlerteActif').checked,
        rolesCibles: rolesCibles,
        societesCibles: societesCibles
    };

    const url = typeId ?
        '{{ path('app_admin_types_alerte_update', {id: '__ID__'}) }}'.replace('__ID__', typeId) :
        '{{ path('app_admin_types_alerte_create') }}';
    const method = typeId ? 'PUT' : 'POST';

    fetch(url, {
        method: method,
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('typeAlerteModal')).hide();
            showToast(data.message, 'success');

            // Mettre à jour la ligne dans le tableau au lieu de recharger
            if (data.type) {
                const row = document.querySelector('tr[data-id="' + data.type.id + '"]');
                if (row) {
                    // Mettre à jour les données data-*
                    const form = document.getElementById('typeAlerteForm');
                    row.dataset.nom = document.getElementById('typeAlerteNom').value;
                    row.dataset.description = document.getElementById('typeAlerteDescription').value;
                    row.dataset.classeDetection = document.getElementById('typeAlerteDetecteur').value;
                    row.dataset.severity = document.getElementById('typeAlerteSeverity').value;
                    row.dataset.ordre = document.getElementById('typeAlerteOrdre').value;
                    row.dataset.actif = document.getElementById('typeAlerteActif').checked ? '1' : '0';

                    // Mettre à jour l'affichage
                    const nomCell = row.querySelector('td:nth-child(3)');
                    if (nomCell) {
                        const desc = document.getElementById('typeAlerteDescription').value;
                        nomCell.innerHTML = '<div class="fw-bold">' + document.getElementById('typeAlerteNom').value + '</div>' +
                            (desc ? '<small class="text-muted">' + desc + '</small>' : '');
                    }

                    const statusCell = row.querySelector('td:nth-child(5)');
                    if (statusCell) {
                        const actif = document.getElementById('typeAlerteActif').checked;
                        statusCell.innerHTML = actif ?
                            '<span class="badge bg-success">Actif</span>' :
                            '<span class="badge bg-secondary">Inactif</span>';
                    }
                }
            }
        } else {
            showToast('Erreur: ' + data.error, 'error');
        }
    })
    .catch(error => {
        console.error('Erreur sauvegarde type alerte:', error);
        showToast('Erreur lors de la sauvegarde', 'error');
    });
}

function supprimerTypeAlerte(typeId) {
    if (!confirm('Êtes-vous sûr de vouloir supprimer ce type d\'alerte ?')) {
        return;
    }

    fetch('{{ path('app_admin_types_alerte_delete', {id: '__ID__'}) }}'.replace('__ID__', typeId), {
        method: 'DELETE',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast(data.message, 'success');
            // Supprimer la ligne du tableau
            const row = document.querySelector('tr[data-id="' + typeId + '"]');
            if (row) {
                row.remove();
            }
            // Vérifier s'il reste des types
            const tbody = document.getElementById('types-alerte-tbody');
            if (tbody && tbody.children.length === 0) {
                document.getElementById('types-alerte-container').style.display = 'none';
                document.getElementById('types-alerte-empty').style.display = 'block';
            }
        } else {
            showToast('Erreur: ' + data.error, 'error');
        }
    })
    .catch(error => {
        console.error('Erreur suppression type alerte:', error);
        showToast('Erreur lors de la suppression', 'error');
    });
}

function lancerDetection(typeId) {
    fetch('{{ path('app_admin_types_alerte_detect', {id: '__ID__'}) }}'.replace('__ID__', typeId), {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast(data.message, 'success');
            // Mettre à jour le badge avec le total d'instances non résolues
            const row = document.querySelector('tr[data-id="' + typeId + '"]');
            if (row && data.total_instances !== undefined) {
                const badgeCell = row.querySelector('td:nth-child(7)');
                if (badgeCell) {
                    if (data.total_instances > 0) {
                        badgeCell.innerHTML = '<a href="#" onclick="voirInstancesAlerte(' + typeId + '); return false;" ' +
                            'class="badge bg-warning text-decoration-none" title="Cliquer pour voir les instances">' +
                            data.total_instances + '</a>';
                    } else {
                        badgeCell.innerHTML = '<span class="badge bg-secondary">0</span>';
                    }
                }
            }
        } else {
            showToast('Erreur: ' + data.error, 'error');
        }
    })
    .catch(error => {
        console.error('Erreur détection:', error);
        showToast('Erreur lors de la détection', 'error');
    });
}

function runAllDetections() {
    if (!confirm('Lancer toutes les détections d\'alertes ?')) {
        return;
    }

    fetch('{{ path('app_admin_types_alerte_run_all') }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast(data.message, 'success');
            // Mettre à jour les badges avec le total d'instances non résolues
            if (data.totals) {
                Object.entries(data.totals).forEach(function(entry) {
                    const typeId = entry[0];
                    const totalInstances = entry[1];
                    const row = document.querySelector('tr[data-id="' + typeId + '"]');
                    if (row) {
                        const badgeCell = row.querySelector('td:nth-child(7)');
                        if (badgeCell) {
                            if (totalInstances > 0) {
                                badgeCell.innerHTML = '<a href="#" onclick="voirInstancesAlerte(' + typeId + '); return false;" ' +
                                    'class="badge bg-warning text-decoration-none" title="Cliquer pour voir les instances">' +
                                    totalInstances + '</a>';
                            } else {
                                badgeCell.innerHTML = '<span class="badge bg-secondary">0</span>';
                            }
                        }
                    }
                });
            }
        } else {
            showToast('Erreur: ' + data.error, 'error');
        }
    })
    .catch(error => {
        console.error('Erreur détections:', error);
        showToast('Erreur lors des détections', 'error');
    });
}

function toggleSocietes() {
    const checkbox = document.getElementById('touteSociete');
    const societeInputs = document.querySelectorAll('input[name="societesCibles"]');

    societeInputs.forEach(input => {
        input.disabled = checkbox.checked;
        if (checkbox.checked) {
            input.checked = false;
        }
    });
}

function resetTypeAlerteForm() {
    document.getElementById('typeAlerteForm').reset();
    document.getElementById('typeAlerteId').value = '';
    document.querySelectorAll('input[name="rolesCibles"]').forEach(input => {
        input.checked = false;
    });
    document.querySelectorAll('input[name="societesCibles"]').forEach(input => {
        input.checked = false;
        input.disabled = false;
    });
    document.getElementById('touteSociete').checked = false;
}

function showToast(message, type) {
    const toast = document.createElement('div');
    const bgClass = type === 'success' ? 'text-bg-success' : 'text-bg-danger';
    const icon = type === 'success' ? 'fa-check' : 'fa-times';

    toast.className = `toast align-items-center ${bgClass} border-0 position-fixed`;
    toast.style.cssText = 'top: 20px; right: 20px; z-index: 9999;';
    toast.innerHTML = `
        <div class="d-flex">
            <div class="toast-body">
                <i class="fas ${icon} me-2"></i>${message}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    `;

    document.body.appendChild(toast);
    const bsToast = new bootstrap.Toast(toast);
    bsToast.show();

    setTimeout(() => toast.remove(), 5000);
}

function voirInstancesAlerte(typeId) {
    const modal = new bootstrap.Modal(document.getElementById('instancesAlerteModal'));
    const loading = document.getElementById('instancesAlerteLoading');
    const content = document.getElementById('instancesAlerteContent');

    loading.style.display = 'block';
    content.style.display = 'none';

    fetch('{{ path('app_admin_types_alerte_instances', {id: '__ID__'}) }}'.replace('__ID__', typeId), {
        method: 'GET',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        loading.style.display = 'none';

        if (data.success) {
            document.getElementById('instancesModalTitle').textContent = data.typeName + ' (' + data.instances.length + ' instance(s))';

            let html = '<div class="table-responsive"><table class="table table-hover"><thead><tr>' +
                '<th>Date</th><th>Entité</th><th>Message</th><th width="150">Actions</th></tr></thead><tbody>';

            data.instances.forEach(instance => {
                const entityName = instance.metadata.client_nom || instance.metadata.contact_nom || 'N/A';

                // Construire l'URL selon le type d'entité
                let editUrl = '#';
                let hasLink = false;

                if (instance.entityType === 'App\\Entity\\Client') {
                    editUrl = '{{ path('app_prospect_show', {id: '__ID__'}) }}'.replace('__ID__', instance.entityId);
                    hasLink = true;
                } else if (instance.entityType === 'App\\Entity\\Contact') {
                    // Pour un contact, on doit aller vers le client parent
                    if (instance.clientId) {
                        editUrl = '{{ path('app_prospect_show', {id: '__ID__'}) }}'.replace('__ID__', instance.clientId);
                        hasLink = true;
                    }
                }

                const linkButton = hasLink ?
                    '<a href="' + editUrl + '" target="_blank" class="btn btn-sm btn-outline-primary me-1" title="Ouvrir dans un nouvel onglet">' +
                    '<i class="fas fa-external-link-alt"></i></a>' :
                    '<button class="btn btn-sm btn-outline-secondary me-1" disabled title="Lien non disponible">' +
                    '<i class="fas fa-external-link-alt"></i></button>';

                html += '<tr>' +
                    '<td>' + instance.dateCreation + '</td>' +
                    '<td>' + entityName + '</td>' +
                    '<td>' + instance.message + '</td>' +
                    '<td>' +
                    linkButton +
                    '<button class="btn btn-sm btn-outline-success" onclick="resoudreInstance(' + instance.id + ')" title="Marquer comme résolu">' +
                    '<i class="fas fa-check"></i></button>' +
                    '</td></tr>';
            });

            html += '</tbody></table></div>';
            content.innerHTML = html;
            content.style.display = 'block';
            modal.show();
        } else {
            showToast('Erreur: ' + data.error, 'error');
        }
    })
    .catch(error => {
        loading.style.display = 'none';
        console.error('Erreur chargement instances:', error);
        showToast('Erreur lors du chargement', 'error');
    });
}

function resoudreInstance(instanceId) {
    if (!confirm('Marquer cette instance comme résolue ?')) {
        return;
    }
    showToast('Fonctionnalité à implémenter: résolution instance #' + instanceId, 'info');
}
</script>