// Fonction générique pour charger les données et afficher une modale
function chargerDonneesEtAfficherModal(url, titre, type) {
    // Créer la modale dynamiquement
    const modalId = 'modal-' + type;
    let modal = document.getElementById(modalId);
    
    if (!modal) {
        modal = document.createElement('div');
        modal.className = 'modal fade';
        modal.id = modalId;
        modal.innerHTML = `
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">${titre}</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div id="loading-${type}" class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Chargement...</span>
                            </div>
                            <div class="mt-2">Chargement des données...</div>
                        </div>
                        <div id="content-${type}" style="display: none;"></div>
                        <div id="error-${type}" style="display: none;" class="alert alert-danger">
                            Erreur lors du chargement des données.
                        </div>
                    </div>
                </div>
            </div>
        `;
        document.body.appendChild(modal);
    }
    
    // Afficher la modale
    const bootstrapModal = new bootstrap.Modal(modal);
    
    // Ajouter un event listener pour nettoyer quand la modal est fermée
    modal.addEventListener('hidden.bs.modal', function () {
        // Supprimer le backdrop s'il existe encore
        const backdrop = document.querySelector('.modal-backdrop');
        if (backdrop) {
            backdrop.remove();
        }
        // Restaurer complètement les styles du body
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('padding-right');
        document.body.style.removeProperty('overflow');
        // Forcer le reflow pour éviter le décalage
        document.body.offsetHeight;
    });
    
    bootstrapModal.show();
    
    // Réinitialiser le contenu
    document.getElementById('loading-' + type).style.display = 'block';
    document.getElementById('content-' + type).style.display = 'none';
    document.getElementById('error-' + type).style.display = 'none';
    
    // Faire l'appel AJAX
    fetch(url, {
        method: 'GET',
        headers: {
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        document.getElementById('loading-' + type).style.display = 'none';
        
        if (data.success) {
            const contentDiv = document.getElementById('content-' + type);
            contentDiv.innerHTML = construireTableauDonnees(data.data, type);
            contentDiv.style.display = 'block';
        } else {
            const errorDiv = document.getElementById('error-' + type);
            errorDiv.textContent = data.message || 'Erreur inconnue';
            errorDiv.style.display = 'block';
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        document.getElementById('loading-' + type).style.display = 'none';
        document.getElementById('error-' + type).style.display = 'block';
    });
}

// Construire le tableau des données selon le type
function construireTableauDonnees(data, type) {
    if (!data || data.length === 0) {
        return '<div class="alert alert-info">Aucune donnée à afficher.</div>';
    }
    
    let html = '<div class="table-responsive"><table class="table table-striped table-hover">';
    
    // En-têtes selon le type
    if (type.includes('devis')) {
        html += `
            <thead class="table-dark">
                <tr>
                    <th>Numéro</th>
                    <th>Client</th>
                    <th>Total TTC</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
        `;
    } else if (type.includes('commandes') || type.includes('livraisons')) {
        html += `
            <thead class="table-dark">
                <tr>
                    <th>Numéro</th>
                    <th>Client</th>
                    <th>Total TTC</th>
                    <th>Date</th>
                    <th>Urgence</th>
                    <th>Actions</th>
                </tr>
            </thead>
        `;
    }
    
    html += '<tbody>';
    
    // Lignes de données
    data.forEach(item => {
        const badgeClass = getUrgenceBadgeClass(item.urgence);
        
        html += '<tr>';
        html += `<td><strong>${item.numeroDevis || item.numeroCommande}</strong></td>`;
        html += `<td>${item.client_nom}</td>`;
        html += `<td>${parseFloat(item.totalTtc).toFixed(2)} €</td>`;
        
        if (type.includes('devis')) {
            const date = item.dateCreation || item.dateEnvoi || '-';
            html += `<td>${date}</td>`;
            html += `<td><span class="badge bg-warning">${item.statut}</span></td>`;
        } else {
            const date = item.dateCommande || item.dateLivraison || '-';
            html += `<td>${date}</td>`;
            html += `<td><span class="badge ${badgeClass}">${item.urgence || 'Normal'}</span></td>`;
        }
        
        html += '<td>';
        if (item.url_show) {
            html += `<a href="${item.url_show}" class="btn btn-sm btn-outline-primary me-1">
                        <i class="fas fa-eye"></i> Voir
                     </a>`;
        }
        if (item.url_edit) {
            html += `<a href="${item.url_edit}" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-edit"></i> Modifier
                     </a>`;
        }
        html += '</td>';
        html += '</tr>';
    });
    
    html += '</tbody></table></div>';
    
    if (data.length > 0) {
        html += `<div class="mt-3 text-muted">
                    <small><i class="fas fa-info-circle"></i> ${data.length} élément(s) trouvé(s)</small>
                 </div>`;
    }
    
    return html;
}

// Classe CSS pour les badges d'urgence
function getUrgenceBadgeClass(urgence) {
    switch (urgence) {
        case 'high': return 'bg-danger';
        case 'medium': return 'bg-warning';
        case 'low': return 'bg-success';
        default: return 'bg-secondary';
    }
}

