<div class="modal-header">
    <h5 class="modal-title">
        <i class="fas fa-map-marker-alt me-2"></i>Ajouter une adresse pour {{ client.nomEntreprise ?: (client.prenom ~ ' ' ~ client.nom) }}
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <form id="address-form" method="POST" data-client-id="{{ client.id }}">
        <div class="mb-3">
            <label class="form-label">Nom/Type de l'adresse *</label>
            <input type="text" class="form-control" name="nom" id="address-nom" 
                   placeholder="Siège social, Entrepôt, etc." required>
        </div>
        
        <div class="mb-3">
            <label class="form-label">Adresse *</label>
            <input type="text" class="form-control" name="ligne1" id="address-ligne1" 
                   placeholder="Numéro et rue" required>
        </div>
        
        <div class="row">
            <div class="col-md-4">
                <label class="form-label">Code postal *</label>
                <div class="position-relative">
                    <input type="text" class="form-control postal-autocomplete" 
                           name="codePostal" id="address-code-postal" required 
                           maxlength="5" data-target-ville="address-ville">
                </div>
            </div>
            <div class="col-md-8">
                <label class="form-label">Ville *</label>
                <div class="position-relative">
                    <input type="text" class="form-control ville-autocomplete" 
                           name="ville" id="address-ville" required 
                           data-target-postal="address-code-postal">
                </div>
            </div>
        </div>
        
        <div class="mt-3">
            <label class="form-label">Pays</label>
            <input type="text" class="form-control" name="pays" id="address-pays" value="France">
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i>Annuler
    </button>
    <button type="button" class="btn btn-success" id="save-address-btn">
        <i class="fas fa-plus me-1"></i>Ajouter l'adresse
    </button>
</div>

<!-- Charger le service d'autocomplétion -->
<script src="/js/services/PostalAutocompleteService.js"></script>

<script>
// Exécuter immédiatement (pas d'attente DOMContentLoaded car modal chargée via AJAX)
(function() {
    // Attendre un petit délai pour que le DOM soit prêt
    setTimeout(function() {
        // Initialiser l'autocomplétion avec le service réutilisable
        const autocompleteService = new PostalAutocompleteService();
        autocompleteService.init('address-code-postal', 'address-ville');
        
        // Gérer la soumission du formulaire
        const saveBtn = document.getElementById('save-address-btn');
        
        if (saveBtn) {
            saveBtn.addEventListener('click', function() {
                submitAddressForm();
            });
        }
        
        // Permettre la soumission avec Entrée
        const addressForm = document.getElementById('address-form');
        if (addressForm) {
            addressForm.addEventListener('submit', function(e) {
                e.preventDefault();
                submitAddressForm();
            });
        }
        
        // Gérer les boutons Annuler et Fermer pour retourner à la modale contact
        const cancelBtn = document.querySelector('.btn-secondary[data-bs-dismiss="modal"]');
        const closeBtn = document.querySelector('.btn-close[data-bs-dismiss="modal"]');
        
        function handleAddressCancelClose() {
            console.log('🔙 Fermeture modale adresse sans sauvegarde');
            
            // Vérifier si on vient vraiment d'une modale contact
            const lastContactEvent = window.lastContactEditEvent;
            const fromContact = lastContactEvent && (lastContactEvent.fromModal === true);
            
            console.log('🔍 Source d\'ouverture:', {
                fromContact: fromContact,
                lastContactEvent: lastContactEvent
            });
            
            // Fermer la modale adresse
            const modal = bootstrap.Modal.getInstance(document.querySelector('.modal'));
            if (modal) {
                modal.hide();
            }
            
            // Rouvrir la modale contact seulement si on vient d'une modale contact
            if (fromContact) {
                setTimeout(() => {
                    console.log('🔄 Réouverture modale contact:', lastContactEvent.contactId);
                    const contactService = new ContactModalService({ debug: true });
                    if (lastContactEvent.mode === 'edit') {
                        contactService.editContact(lastContactEvent.contactId);
                    } else {
                        contactService.createContact(lastContactEvent.clientId);
                    }
                }, 300);
            } else {
                console.log('✅ Fermeture simple - pas de retour vers modale contact');
            }
        }
        
        if (cancelBtn) {
            cancelBtn.addEventListener('click', handleAddressCancelClose);
        }
        if (closeBtn) {
            closeBtn.addEventListener('click', handleAddressCancelClose);
        }
        
        // Gérer la fermeture de la modale par clic à côté ou ESC
        const modalElement = document.querySelector('.modal');
        if (modalElement) {
            modalElement.addEventListener('hidden.bs.modal', function(e) {
                console.log('🔔 Modale adresse fermée (toutes méthodes)');
                
                // Réinitialiser le flag
                window.editAddressInProgress = false;
                
                // Nettoyage simple des backdrops
                setTimeout(() => {
                    const backdrops = document.querySelectorAll('.modal-backdrop');
                    if (backdrops.length > 0) {
                        console.log('🧹 Nettoyage', backdrops.length, 'backdrops');
                        backdrops.forEach(backdrop => backdrop.remove());
                        document.body.classList.remove('modal-open');
                        document.body.style.removeProperty('padding-right');
                        document.body.style.removeProperty('overflow');
                    }
                }, 100);
            });
        }
    }, 100);
})();


function submitAddressForm() {
    // ⚠️ PROTECTION CONTRE DOUBLE SOUMISSION
    if (window.addressFormSubmitting) {
        console.log('⚠️ Soumission déjà en cours, appel ignoré');
        return;
    }
    window.addressFormSubmitting = true;

    console.log('🚀 submitAddressForm NEW - soumission unique en cours');

    const form = document.getElementById('address-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-address-btn');

    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    const ligne1 = (formData.get('ligne1') || '').trim();
    const codePostal = (formData.get('codePostal') || '').trim();
    const ville = (formData.get('ville') || '').trim();

    if (!nom || !ligne1 || !codePostal || !ville) {
        console.log('❌ Validation échouée - champs manquants');
        alert('Veuillez remplir tous les champs obligatoires');
        window.addressFormSubmitting = false; // Réinitialiser le flag
        return;
    }

    console.log('✅ Validation réussie, début soumission...');

    // Désactiver le bouton pendant la soumission
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Création...';
    
    // Soumettre via fetch vers l'URL de la modal
    const clientId = document.querySelector('#address-form').dataset.clientId || '{{ client.id }}';
    const modalUrl = `/adresse/modal/new/${clientId}`;
    
    console.log('📤 Envoi vers:', modalUrl, 'avec clientId:', clientId);
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        console.log('📡 Réponse reçue:', {
            status: response.status,
            statusText: response.statusText,
            ok: response.ok,
            headers: Object.fromEntries(response.headers.entries())
        });
        
        if (!response.ok) {
            return response.text().then(text => {
                console.error('❌ Erreur réponse détail:', text);
                throw new Error(`HTTP ${response.status}: ${response.statusText} - ${text}`);
            });
        }
        return response.json();
    })
    .then(data => {
        console.log('📊 Données reçues:', data);
        
        if (data.success) {
            console.log('✅ Adresse créée avec succès:', data.adresse);
            
            // Émettre un événement pour notifier la page parent
            window.dispatchEvent(new CustomEvent('addressCreated', {
                detail: { 
                    adresse: data.adresse,
                    message: data.message
                }
            }));
            console.log('📢 Événement addressCreated émis');
            
            // ✅ NOUVELLE LOGIQUE : Fermer UNIQUEMENT la modale adresse, pas les autres
            console.log('🔒 Fermeture de la modale adresse uniquement...');

            // Trouver spécifiquement la modale d'adresse (pas toutes les modales visibles)
            const addressModal = document.getElementById('address-modal') ||
                                 document.querySelector('.modal[data-type="address"]') ||
                                 document.querySelector('.modal.show'); // Fallback

            if (addressModal) {
                console.log('🎯 Modale d\'adresse trouvée:', addressModal.id || 'sans ID');

                const modal = bootstrap.Modal.getInstance(addressModal);
                if (modal) {
                    console.log('🔒 Fermeture via Bootstrap Modal');
                    modal.hide();
                } else {
                    console.log('🔒 Fermeture manuelle de la modale d\'adresse');
                    addressModal.classList.remove('show');
                    addressModal.style.display = 'none';
                    addressModal.setAttribute('aria-hidden', 'true');
                }

                // ⚠️ NE PAS supprimer TOUS les backdrops - seulement le dernier
                setTimeout(() => {
                    const allBackdrops = document.querySelectorAll('.modal-backdrop');
                    const openModals = document.querySelectorAll('.modal.show');

                    console.log('🔍 État après fermeture:', {
                        backdrops: allBackdrops.length,
                        modalstOuvertes: openModals.length
                    });

                    // Si il y a plus de backdrops que de modales ouvertes, supprimer le surplus
                    if (allBackdrops.length > openModals.length) {
                        const backdropsToRemove = allBackdrops.length - openModals.length;
                        for (let i = 0; i < backdropsToRemove; i++) {
                            const lastBackdrop = allBackdrops[allBackdrops.length - 1 - i];
                            if (lastBackdrop) {
                                console.log('🧹 Suppression backdrop surplus');
                                lastBackdrop.remove();
                            }
                        }
                    }

                    // Restaurer le body SEULEMENT si aucune modale n'est ouverte
                    if (openModals.length === 0) {
                        console.log('🔄 Restauration body (aucune modale ouverte)');
                        document.body.classList.remove('modal-open');
                        document.body.style.removeProperty('padding-right');
                        document.body.style.removeProperty('overflow');
                    }
                }, 100);
            } else {
                console.log('❌ Modale d\'adresse non trouvée');
            }
        } else {
            console.log('❌ Création échouée:', data.message);
            alert(data.message || 'Erreur lors de la création de l\'adresse');
        }
    })
    .catch(error => {
        console.error('❌ Erreur fetch:', error);
        alert('Erreur lors de la création de l\'adresse');
    })
    .finally(() => {
        console.log('🔄 Réactivation du bouton');
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-plus me-1"></i>Ajouter l\'adresse';

        // ⚠️ RÉINITIALISER LE FLAG DE PROTECTION
        window.addressFormSubmitting = false;
        console.log('🔄 Flag de protection réinitialisé');
    });
}
</script>