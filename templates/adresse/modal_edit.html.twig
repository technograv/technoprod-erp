<div class="modal-header">
    <h5 class="modal-title">
        <i class="fas fa-edit me-2"></i>Modifier l'adresse "{{ adresse.nom }}"
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <form id="address-form" method="POST" data-adresse-id="{{ adresse.id }}">
        <div class="mb-3">
            <label class="form-label">Nom/Type de l'adresse *</label>
            <input type="text" class="form-control" name="nom" id="address-nom" 
                   value="{{ adresse.nom }}" placeholder="Siège social, Entrepôt, etc." required>
        </div>
        
        <div class="mb-3">
            <label class="form-label">Adresse *</label>
            <input type="text" class="form-control" name="ligne1" id="address-ligne1" 
                   value="{{ adresse.ligne1 }}" placeholder="Numéro et rue" required>
        </div>
        
        <div class="row">
            <div class="col-md-4">
                <label class="form-label">Code postal *</label>
                <div class="position-relative">
                    <input type="text" class="form-control postal-autocomplete" 
                           name="codePostal" id="address-code-postal" 
                           value="{{ adresse.codePostal }}" required 
                           maxlength="5" data-target-ville="address-ville">
                </div>
            </div>
            <div class="col-md-8">
                <label class="form-label">Ville *</label>
                <div class="position-relative">
                    <input type="text" class="form-control ville-autocomplete" 
                           name="ville" id="address-ville" 
                           value="{{ adresse.ville }}" required 
                           data-target-postal="address-code-postal">
                </div>
            </div>
        </div>
        
        <div class="mt-3">
            <label class="form-label">Pays</label>
            <input type="text" class="form-control" name="pays" id="address-pays" 
                   value="{{ adresse.pays ?: 'France' }}">
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i>Annuler
    </button>
    <button type="button" class="btn btn-primary" id="save-address-btn">
        <i class="fas fa-save me-1"></i>Modifier l'adresse
    </button>
</div>

<!-- Charger le service d'autocomplétion -->
<script src="/js/services/PostalAutocompleteService.js"></script>

<script>
// Exécuter immédiatement (pas d'attente DOMContentLoaded car modal chargée via AJAX)
(function() {
    // Attendre un petit délai pour que le DOM soit prêt
    setTimeout(function() {
        // Initialiser l'autocomplétion avec le service réutilisable
        const autocompleteService = new PostalAutocompleteService();
        autocompleteService.init('address-code-postal', 'address-ville');
        
        // Gérer la soumission du formulaire
        const saveBtn = document.getElementById('save-address-btn');
        
        if (saveBtn) {
            saveBtn.addEventListener('click', function() {
                submitAddressForm();
            });
        }
        
        // Permettre la soumission avec Entrée
        const addressForm = document.getElementById('address-form');
        if (addressForm) {
            addressForm.addEventListener('submit', function(e) {
                e.preventDefault();
                submitAddressForm();
            });
        }
        
        // Gérer les boutons Annuler et Fermer pour retourner à la modale contact
        const cancelBtn = document.querySelector('.btn-secondary[data-bs-dismiss="modal"]');
        const closeBtn = document.querySelector('.btn-close[data-bs-dismiss="modal"]');
        
        function handleAddressCancelClose() {
            console.log('🔙 Fermeture modale adresse sans sauvegarde');
            
            // CORRECTION: Vérifier si on vient vraiment d'une modale contact ET si l'événement est récent
            const lastContactEvent = window.lastContactEditEvent;
            const fromContact = lastContactEvent && (lastContactEvent.fromModal === true);
            
            // Vérifier si l'événement n'est pas trop ancien (protection contre les événements parasites)
            const eventAge = lastContactEvent?.timestamp ? (Date.now() - lastContactEvent.timestamp) : Infinity;
            const isRecentEvent = eventAge < 10000; // 10 secondes max
            
            console.log('🔍 Source d\'ouverture:', {
                fromContact: fromContact,
                eventAge: eventAge,
                isRecentEvent: isRecentEvent,
                lastContactEvent: lastContactEvent
            });
            
            // Fermer la modale adresse
            const modal = bootstrap.Modal.getInstance(document.querySelector('.modal'));
            if (modal) {
                modal.hide();
            }
            
            // CORRECTION: Rouvrir la modale contact seulement si on vient VRAIMENT d'une modale contact récente
            if (fromContact && isRecentEvent) {
                setTimeout(() => {
                    console.log('🔄 Réouverture modale contact:', lastContactEvent.contactId);
                    const contactService = new ContactModalService({ debug: true });
                    if (lastContactEvent.mode === 'edit') {
                        contactService.editContact(lastContactEvent.contactId);
                    } else {
                        contactService.createContact(lastContactEvent.clientId);
                    }
                }, 300);
            } else {
                console.log('✅ Fermeture simple - pas de retour vers modale contact (événement trop ancien ou direct)');
                // Nettoyer l'événement si trop ancien
                if (!isRecentEvent) {
                    window.lastContactEditEvent = null;
                }
            }
        }
        
        if (cancelBtn) {
            cancelBtn.addEventListener('click', handleAddressCancelClose);
        }
        if (closeBtn) {
            closeBtn.addEventListener('click', handleAddressCancelClose);
        }
        
        // Gérer la fermeture de la modale par clic à côté ou ESC
        const modalElement = document.querySelector('.modal');
        if (modalElement) {
            modalElement.addEventListener('hidden.bs.modal', function(e) {
                console.log('🔔 Modale adresse fermée (toutes méthodes)');
                
                // CORRECTION: Vérifier si la fermeture est due à une validation réussie
                const isSuccessClose = window.addressEditSuccess === true;
                console.log('🔍 Type de fermeture:', { isSuccessClose: isSuccessClose });
                
                // Réinitialiser les flags
                window.editAddressInProgress = false;
                window.addressEditSuccess = false;
                
                // IMPORTANT: Si c'est une fermeture après validation réussie, ne pas retourner à la modale contact
                if (isSuccessClose) {
                    console.log('✅ Fermeture après validation - nettoyage des événements contact parasites');
                    window.lastContactEditEvent = null; // Nettoyer pour éviter les réouvertures parasites
                }
                
                // Nettoyage simple des backdrops
                setTimeout(() => {
                    const backdrops = document.querySelectorAll('.modal-backdrop');
                    if (backdrops.length > 0) {
                        console.log('🧹 Nettoyage', backdrops.length, 'backdrops');
                        backdrops.forEach(backdrop => backdrop.remove());
                        document.body.classList.remove('modal-open');
                        document.body.style.removeProperty('padding-right');
                        document.body.style.removeProperty('overflow');
                    }
                }, 100);
            });
        }
    }, 100);
})();


function submitAddressForm() {
    const form = document.getElementById('address-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-address-btn');
    
    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    const ligne1 = (formData.get('ligne1') || '').trim();
    const codePostal = (formData.get('codePostal') || '').trim();
    const ville = (formData.get('ville') || '').trim();
    
    if (!nom || !ligne1 || !codePostal || !ville) {
        alert('Veuillez remplir tous les champs obligatoires');
        return;
    }
    
    // Désactiver le bouton pendant la soumission
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Modification...';
    
    // Soumettre via fetch vers l'URL de la modal
    const adresseId = document.querySelector('#address-form').dataset.adresseId || '{{ adresse.id }}';
    const modalUrl = `/adresse/modal/edit/${adresseId}`;
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Émettre un événement pour notifier la page parent
            window.dispatchEvent(new CustomEvent('addressUpdated', {
                detail: { 
                    adresse: data.adresse,
                    message: data.message
                }
            }));
            
            // CORRECTION: Marquer que la fermeture est due à une validation réussie
            window.addressEditSuccess = true;
            
            // Fermeture normale de la modale adresse
            // Chercher spécifiquement la modale adresse visible
            const visibleModal = document.querySelector('.modal.show');
            if (visibleModal) {
                const modal = bootstrap.Modal.getInstance(visibleModal);
                if (modal) {
                    console.log('🔒 Fermeture modale adresse après validation réussie (EDIT)');
                    modal.hide();
                } else {
                    // Fallback : fermeture manuelle
                    console.log('⚠️ Instance Bootstrap non trouvée, fermeture manuelle');
                    visibleModal.classList.remove('show');
                    visibleModal.style.display = 'none';
                    document.body.classList.remove('modal-open');
                    // Supprimer les backdrops
                    document.querySelectorAll('.modal-backdrop').forEach(b => b.remove());
                }
            } else {
                console.error('❌ Aucune modale visible trouvée pour fermeture');
            }
        } else {
            alert(data.message || 'Erreur lors de la modification de l\'adresse');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur lors de la modification de l\'adresse');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-save me-1"></i>Modifier l\'adresse';
    });
}
</script>