<div class="modal-header">
    <h5 class="modal-title">
        <i class="fas fa-user-plus me-2"></i>Ajouter un contact pour {{ client.nomEntreprise ?: (client.prenom ~ ' ' ~ client.nom) }}
    </h5>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-warning" onclick="window.modalDebugService?.generateReport()" title="Debug Modal">
            🔍
        </button>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
</div>

<style>
/* Fix pour Select2 dans les modals - AGRESSIF */
.modal .select2-container {
    z-index: 9999 !important;
}
.modal .select2-dropdown {
    z-index: 10000 !important;
}
.select2-container--open .select2-dropdown {
    z-index: 10001 !important;
}

/* Forcer le dropdown Select2 au-dessus de la modale mais dans la modale */
.modal .select2-dropdown {
    z-index: 1070 !important;
}
.modal .select2-container--bootstrap-5 .select2-dropdown {
    z-index: 1070 !important;
}
.modal .select2-container--open .select2-dropdown {
    z-index: 1070 !important;
}


/* Gestion des modales empilées - adresse par-dessus contact */
.modal {
    z-index: 1050;
}
.modal.show {
    z-index: 1055;
}
/* Modale d'adresse au-dessus de contact */
.modal + .modal {
    z-index: 1060 !important;
}
.modal + .modal .modal-backdrop {
    z-index: 1059 !important;
}
</style>
<div class="modal-body">
    <form id="contact-form" method="POST" data-client-id="{{ client.id }}">
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Prénom</label>
                    <input type="text" class="form-control" name="prenom" id="contact-prenom">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Nom *</label>
                    <input type="text" class="form-control" name="nom" id="contact-nom" required>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" name="email" id="contact-email">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Fonction</label>
                    <input type="text" class="form-control" name="fonction" id="contact-fonction" 
                           placeholder="Directeur, Commercial, Comptable...">
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Téléphone fixe</label>
                    <input type="tel" class="form-control" name="telephone" id="contact-telephone">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Mobile</label>
                    <input type="tel" class="form-control" name="mobile" id="contact-mobile">
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-12">
                <div class="mb-3">
                    <label class="form-label">Adresse associée</label>
                    <div class="d-flex align-items-center gap-2">
                        <select class="form-select" name="adresse" id="contact-adresse" style="flex-grow: 1;">
                            <option value="">-- Sélectionner une adresse --</option>
                            {% if adresses is defined and adresses is not empty %}
                                {% for adresse in adresses %}
                                    <option value="{{ adresse.id }}">{{ adresse.displayLabel }}</option>
                                {% endfor %}
                            {% else %}
                                <option value="" disabled>Aucune adresse disponible pour ce client</option>
                            {% endif %}
                        </select>
                        <!-- Boutons d'action adresse -->
                        <button type="button" class="btn btn-success btn-sm" id="add-address-btn" 
                                title="Ajouter une nouvelle adresse" data-client-id="{{ client.id }}">
                            <i class="fas fa-plus"></i>
                        </button>
                        <button type="button" class="btn btn-primary btn-sm" id="edit-address-btn" 
                                title="Modifier l'adresse sélectionnée" style="display: none;">
                            <i class="fas fa-edit"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="isFacturationDefault" id="contact-facturation-default">
                    <label class="form-check-label" for="contact-facturation-default">
                        <i class="fas fa-file-invoice me-1"></i>Contact de facturation par défaut
                    </label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="isLivraisonDefault" id="contact-livraison-default">
                    <label class="form-check-label" for="contact-livraison-default">
                        <i class="fas fa-truck me-1"></i>Contact de livraison par défaut
                    </label>
                </div>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i>Annuler
    </button>
    <button type="button" class="btn btn-success" id="save-contact-btn">
        <i class="fas fa-plus me-1"></i>Ajouter le contact
    </button>
</div>

<!-- Inclusion directe des services JavaScript (comme /devis/new) -->
<script src="/js/services/ModalDebugService.js"></script>
<script src="/js/services/ModalService.js"></script>
<script src="/js/services/MultiModalNavigationService.js"></script>
<script src="/js/services/AddressModalService.js"></script>
<script src="/js/services/ContactModalService.js"></script>

<script>
// Exécuter immédiatement (pas d'attente DOMContentLoaded car modal chargée via AJAX)
(function() {
    console.log('🚀 Initialisation modal contact - début');
    
    // Services déjà chargés de manière synchrone (comme /devis/new)
    
    // Attendre un petit délai pour que le DOM soit prêt
    setTimeout(function() {
        console.log('🔧 DOM prêt, initialisation des boutons et rechargement adresses');
        
        // Stocker automatiquement les informations de contact pour les prochaines actions
        window.lastContactEditEvent = {
            mode: 'new',
            contactId: null,
            clientId: '{{ client.id }}',
            fromModal: false // Par défaut, pas depuis une modale
        };
        console.log('💾 Auto-stockage info contact à l\'ouverture (NEW):', window.lastContactEditEvent);
        
        // Gérer les boutons d'adresse
        initAddressButtons();
        
        // Charger les adresses depuis l'API pour s'assurer qu'elles sont à jour
        // Vérifier s'il y a une adresse à présélectionner (navigation multi-modale)
        const preselectAddressId = window.lastContactEditEvent?.preselectAddressId || null;
        console.log('🔍 Adresse à présélectionner depuis navigation:', preselectAddressId);
        reloadAddresses(preselectAddressId);
        
        // Initialiser le formatage des numéros de téléphone
        setupPhoneFormatting();
        
        // Gérer la soumission du formulaire
        const saveBtn = document.getElementById('save-contact-btn');
        
        if (saveBtn) {
            saveBtn.addEventListener('click', function() {
                submitContactForm();
            });
        }
        
        // Permettre la soumission avec Entrée
        const contactForm = document.getElementById('contact-form');
        if (contactForm) {
            contactForm.addEventListener('submit', function(e) {
                e.preventDefault();
                submitContactForm();
            });
        }
    }, 100);
})();

function initAddressButtons() {
    const addressSelect = document.getElementById('contact-adresse');
    const editBtn = document.getElementById('edit-address-btn');
    const addBtn = document.getElementById('add-address-btn');
    
    // Navigation multi-modale gérée automatiquement par MultiModalNavigationService
    // Plus besoin d'event listeners manuels pour addressCreated/addressUpdated
    
    // Afficher/masquer le bouton modifier selon la sélection
    if (addressSelect) {
        console.log('✅ AddressSelect trouvé, ajout event listener change (NEW)');
        
        // Supprimer d'éventuels anciens event listeners
        addressSelect.removeEventListener('change', handleAddressChange);
        
        // Ajouter le nouvel event listener
        addressSelect.addEventListener('change', handleAddressChange);
        
        // Event listener aussi pour Select2
        if (window.$ && $(addressSelect).hasClass('select2-hidden-accessible')) {
            console.log('✅ Select2 détecté, ajout event listener select2:select (NEW)');
            $(addressSelect).off('select2:select select2:unselect').on('select2:select select2:unselect', function(e) {
                console.log('🔧 Select2 event déclenché (NEW):', e.type, 'valeur:', this.value);
                handleAddressChange.call(this);
            });
        }
        
        // Test initial de l'état
        console.log('🔍 État initial du bouton (NEW):', {
            addressValue: addressSelect.value,
            editBtnExists: !!editBtn,
            editBtnDisplay: editBtn ? editBtn.style.display : 'N/A'
        });
    } else {
        console.log('❌ AddressSelect introuvable (NEW)');
    }
    
    // 🚫 ANCIENS EVENT LISTENERS SUPPRIMÉS
    // Utiliser AddressModalService pour gérer la navigation multi-modale
    
    if (window.AddressModalService && addBtn && editBtn) {
        console.log('🔧 Configuration AddressModalService pour modal contact NEW');
        
        const addressModalService = new AddressModalService({
            debug: true
        });
        
        // Attacher aux boutons de cette modale avec logique spéciale pour "nouveau contact"
        
        // Pour le bouton "ajouter adresse", créer un event listener personnalisé
        if (addBtn) {
            addBtn.addEventListener('click', function() {
                console.log('🔗 Clic Nouvelle Adresse depuis modal contact NEW');
                
                // Pour nouveau contact, sauvegarder d'abord en brouillon avant d'aller vers l'adresse
                const form = document.getElementById('contact-form');
                const formData = new FormData(form);
                
                // Validation côté client
                const nom = (formData.get('nom') || '').trim();
                
                if (!nom) {
                    alert('Veuillez renseigner au moins le nom du contact avant d\'ajouter une adresse');
                    return;
                }
                
                console.log('💾 Sauvegarde automatique du contact avant navigation vers adresse...');
                
                // Sauvegarder le contact en premier
                saveContactBeforeAddressNavigation('{{ client.id }}');
            });
        }
        
        // Pour le bouton "modifier adresse", sauvegarder aussi le contact d'abord
        if (editBtn) {
            editBtn.addEventListener('click', function() {
                console.log('🔗 Clic Modifier Adresse depuis modal contact NEW');
                
                const addressSelect = document.getElementById('contact-adresse');
                const addressId = addressSelect?.value;
                
                if (!addressId) {
                    alert('Veuillez d\'abord sélectionner une adresse à modifier');
                    return;
                }
                
                // Pour nouveau contact, sauvegarder d'abord avant de modifier l'adresse
                const form = document.getElementById('contact-form');
                const formData = new FormData(form);
                
                // Validation côté client
                const nom = (formData.get('nom') || '').trim();
                
                if (!nom) {
                    alert('Veuillez renseigner au moins le nom du contact avant de modifier une adresse');
                    return;
                }
                
                console.log('💾 Sauvegarde automatique du contact avant navigation vers modification adresse...');
                
                // Sauvegarder le contact puis naviguer vers l'édition d'adresse
                saveContactBeforeAddressEdit('{{ client.id }}', addressId);
            });
        }
        
        console.log('✅ AddressModalService attaché aux boutons');
    } else {
        console.log('❌ AddressModalService ou boutons non disponibles');
    }
}

// Fonction séparée pour gérer le changement d'adresse
function handleAddressChange() {
    const editBtn = document.getElementById('edit-address-btn');
    const shouldShow = this.value ? 'inline-block' : 'none';
    
    console.log('🔧 handleAddressChange appelé (NEW):', { 
        addressValue: this.value, 
        shouldShow: shouldShow,
        buttonFound: !!editBtn,
        currentDisplay: editBtn ? editBtn.style.display : 'N/A'
    });
    
    if (editBtn) {
        editBtn.style.display = shouldShow;
        console.log('✅ Bouton edit mis à jour (NEW):', editBtn.style.display);
    } else {
        console.log('❌ EditBtn introuvable lors du changement (NEW)');
    }
}

function reloadAddresses(selectedAddressId = null) {
    console.log('🔄 reloadAddresses appelé avec selectedAddressId:', selectedAddressId);
    
    const addressSelect = document.getElementById('contact-adresse');
    const clientId = document.getElementById('add-address-btn')?.dataset.clientId || '{{ client.id }}'; // Fallback Twig
    
    console.log('🔍 Éléments trouvés:', {
        addressSelect: !!addressSelect,
        clientId: clientId,
        addBtn: !!document.getElementById('add-address-btn'),
        'form clientId': document.getElementById('contact-form')?.dataset.clientId
    });
    
    // Essayer plusieurs sources pour le clientId
    const finalClientId = clientId || document.getElementById('contact-form')?.dataset.clientId;
    
    if (!addressSelect || !finalClientId) {
        console.error('❌ reloadAddresses: Éléments manquants', { 
            addressSelect: !!addressSelect, 
            clientId: clientId,
            finalClientId: finalClientId,
            formElement: !!document.getElementById('contact-form')
        });
        return;
    }
    
    const apiUrl = `/client/${finalClientId}/addresses`;
    console.log('📡 Appel API adresses:', apiUrl);
    
    // Charger les adresses via API
    fetch(apiUrl)
        .then(response => {
            console.log('📡 Réponse API adresses:', response.status, response.statusText);
            console.log('📡 Headers de réponse:', Object.fromEntries(response.headers.entries()));
            if (!response.ok) {
                return response.text().then(text => {
                    console.error('❌ Erreur API détail:', text);
                    throw new Error(`HTTP ${response.status}: ${response.statusText} - ${text}`);
                });
            }
            return response.json();
        })
        .then(addresses => {
            console.log('📊 Adresses reçues (type:', typeof addresses, ', longueur:', addresses?.length, '):', addresses);
            
            // Vider et repeupler le select
            addressSelect.innerHTML = '<option value="">-- Sélectionner une adresse --</option>';
            
            if (addresses && addresses.length > 0) {
                addresses.forEach(address => {
                    const option = document.createElement('option');
                    option.value = address.id;
                    option.textContent = address.label;
                    if (selectedAddressId && address.id == selectedAddressId) {
                        option.selected = true;
                    }
                    addressSelect.appendChild(option);
                });
            } else {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Aucune adresse disponible pour ce client';
                option.disabled = true;
                addressSelect.appendChild(option);
            }
            
            // 🔧 Mettre à jour Select2 si présent
            if (window.$ && $(addressSelect).hasClass('select2-hidden-accessible')) {
                console.log('🔧 Rafraîchissement Select2 pour', addressSelect.id, 'avec selectedAddressId:', selectedAddressId);
                try {
                    const $select = $(addressSelect);
                    
                    // D'abord, sélectionner la bonne option dans le DOM natif
                    if (selectedAddressId) {
                        console.log('🎯 Pré-sélection option:', selectedAddressId);
                        addressSelect.value = selectedAddressId;
                    }
                    
                    // Ensuite, forcer la reconstruction complète de Select2
                    console.log('🔄 Destruction et reconstruction Select2...');
                    $select.select2('destroy');
                    
                    // Réinitialiser avec configuration simple
                    $select.select2({
                        dropdownParent: $select.closest('.modal'),
                        width: '100%',
                        theme: 'bootstrap-5',
                        dropdownAutoWidth: true
                    });
                    
                    // Re-sélectionner après reconstruction
                    if (selectedAddressId) {
                        console.log('🎯 Post-sélection Select2:', selectedAddressId);
                        $select.val(selectedAddressId).trigger('change');
                        
                        // Vérification et re-sélection différée si nécessaire
                        setTimeout(() => {
                            const currentVal = $select.val();
                            console.log('🔍 Vérification sélection différée:', currentVal, 'vs', selectedAddressId);
                            if (currentVal != selectedAddressId) {
                                console.log('🔄 Re-sélection forcée car valeur incorrecte');
                                $select.val(selectedAddressId).trigger('change');
                                
                                // Aussi forcer la sélection native
                                addressSelect.value = selectedAddressId;
                                addressSelect.dispatchEvent(new Event('change'));
                            }
                        }, 500);
                    }
                    
                    console.log('✅ Select2 reconstruit avec succès, valeur finale:', $select.val());
                } catch (e) {
                    console.error('❌ Erreur reconstruction Select2:', e);
                }
            }
            
            // Mettre à jour le bouton d'édition
            const editBtn = document.getElementById('edit-address-btn');
            if (editBtn) {
                const shouldShow = addressSelect.value ? 'inline-block' : 'none';
                console.log('🔧 Mise à jour bouton edit adresse (NEW):', { 
                    addressValue: addressSelect.value, 
                    shouldShow: shouldShow,
                    currentDisplay: editBtn.style.display 
                });
                editBtn.style.display = shouldShow;
            } else {
                console.log('❌ Bouton edit-address-btn introuvable (NEW)');
            }
        })
        .catch(error => {
            console.error('Erreur rechargement adresses:', error);
            addressSelect.innerHTML = '<option value="">-- Erreur chargement adresses --</option>';
        });
}

function openAddressModalDirectly(idValue, mode) {
    if (window.modalDebugService) {
        window.modalDebugService.log('🔗 DÉBUT Navigation Contact → Adresse', {
            mode: mode,
            idValue: idValue,
            clientId: '{{ client.id }}',
            currentModals: document.querySelectorAll('.modal.show').length,
            lastContactEvent: window.lastContactEditEvent
        });
    }
    
    console.log('🔗 Navigation Contact → Adresse (' + mode.toUpperCase() + ') via service centralisé pour:', idValue);
    
    // Utiliser le service centralisé de navigation
    if (window.MultiModalNavigationService) {
        if (window.modalDebugService) {
            window.modalDebugService.log('✅ MultiModalNavigationService disponible, appel navigateToAddress');
        }
        
        MultiModalNavigationService.navigateToAddress({
            mode: 'new',
            contactId: null,
            clientId: '{{ client.id }}'
        }, mode, idValue);
        
        if (window.modalDebugService) {
            window.modalDebugService.log('📞 navigateToAddress appelé', {
                targetMode: mode,
                targetId: idValue
            });
        }
    } else {
        console.error('❌ MultiModalNavigationService non disponible');
        if (window.modalDebugService) {
            window.modalDebugService.log('❌ MultiModalNavigationService NON DISPONIBLE');
        }
        alert('Erreur: Service de navigation non disponible. Veuillez réessayer.');
    }
}

function submitContactForm() {
    const form = document.getElementById('contact-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-contact-btn');
    
    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    
    if (!nom) {
        alert('Le nom est obligatoire');
        return;
    }
    
    // Désactiver le bouton pendant la soumission
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Création...';
    
    // Soumettre via fetch vers l'URL de la modal
    const clientId = document.querySelector('#contact-form').dataset.clientId || '{{ client.id }}';
    const modalUrl = `/contact/modal/new/${clientId}`;
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Émettre un événement pour notifier la page parent
            window.dispatchEvent(new CustomEvent('contactCreated', {
                detail: { 
                    contact: data.contact,
                    message: data.message
                }
            }));
            
            // Fermer la modale
            const modal = bootstrap.Modal.getInstance(document.querySelector('.modal'));
            if (modal) {
                modal.hide();
            }
        } else {
            alert(data.message || 'Erreur lors de la création du contact');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur lors de la création du contact');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-plus me-1"></i>Ajouter le contact';
    });
}

// ==================================
// FORMATAGE DES NUMÉROS DE TÉLÉPHONE
// ==================================

function formatPhoneNumber(value) {
    // Supprimer tous les caractères non numériques
    const numbers = value.replace(/\D/g, '');
    
    // Limiter à 10 chiffres pour la France
    const limited = numbers.substring(0, 10);
    
    // Formater en groupes de 2 chiffres (format français)
    if (limited.length === 0) return '';
    
    const formatted = limited.match(/.{1,2}/g);
    return formatted ? formatted.join(' ') : limited;
}

function setupPhoneFormatting() {
    console.log('📞 Configuration formatage téléphones (modale contact new)');
    
    // Sélectionner tous les champs téléphone
    const phoneFields = document.querySelectorAll('input[type="tel"], input[name*="telephone"], input[name*="phone"], input[id*="telephone"], input[name*="mobile"]');
    
    phoneFields.forEach(field => {
        field.addEventListener('input', function(e) {
            const cursorPos = this.selectionStart;
            const oldValue = this.value;
            const newValue = formatPhoneNumber(this.value);
            
            this.value = newValue;
            
            // Ajuster la position du curseur
            if (newValue.length > oldValue.length) {
                this.setSelectionRange(cursorPos + 1, cursorPos + 1);
            } else {
                this.setSelectionRange(cursorPos, cursorPos);
            }
        });
        
        // Formater à la perte de focus aussi
        field.addEventListener('blur', function() {
            this.value = formatPhoneNumber(this.value);
        });
    });
}

// ==================================
// SAUVEGARDE AUTOMATIQUE AVANT NAVIGATION (comme /devis/new)
// ==================================

function saveContactBeforeAddressNavigation(clientId) {
    console.log('💾 Début sauvegarde contact avant navigation vers adresse');
    
    const form = document.getElementById('contact-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-contact-btn');
    
    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    
    if (!nom) {
        alert('Le nom est obligatoire pour sauvegarder le contact');
        return;
    }
    
    console.log('📤 Envoi de la sauvegarde contact automatique...');
    
    // Désactiver temporairement le bouton
    const originalBtnText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Sauvegarde...';
    
    // Soumettre via fetch vers l'URL de la modal
    const modalUrl = `/contact/modal/new/${clientId}`;
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            console.log('✅ Contact sauvegardé avec succès, navigation vers adresse...');
            
            // Émettre un événement pour notifier la page parent (mais ne pas fermer la modale)
            window.dispatchEvent(new CustomEvent('contactCreated', {
                detail: { 
                    contact: data.contact,
                    message: data.message
                }
            }));
            
            // Maintenant naviguer vers l'adresse avec le contact créé
            // Mais marquer qu'on ne veut PAS revenir vers la modale contact (fermer définitivement)
            if (window.MultiModalNavigationService) {
                MultiModalNavigationService.navigateToAddress({
                    mode: 'new', // Rester en mode new pour éviter réouverture en édition
                    contactId: null, // Pas de retour prévu vers modale contact
                    clientId: clientId,
                    noReturn: true // Flag pour indiquer de ne pas rouvrir après
                }, 'create', clientId);
            }
        } else {
            console.error('❌ Erreur sauvegarde contact:', data.message);
            alert(data.message || 'Erreur lors de la sauvegarde du contact');
        }
    })
    .catch(error => {
        console.error('❌ Erreur réseau sauvegarde contact:', error);
        alert('Erreur lors de la sauvegarde du contact');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
    });
}

// ==================================
// SAUVEGARDE AUTOMATIQUE AVANT MODIFICATION D'ADRESSE
// ==================================

function saveContactBeforeAddressEdit(clientId, addressId) {
    console.log('💾 Début sauvegarde contact avant navigation vers modification adresse');
    
    const form = document.getElementById('contact-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-contact-btn');
    
    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    
    if (!nom) {
        alert('Le nom est obligatoire pour sauvegarder le contact');
        return;
    }
    
    console.log('📤 Envoi de la sauvegarde contact automatique avant modification adresse...');
    
    // Désactiver temporairement le bouton
    const originalBtnText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Sauvegarde...';
    
    // Soumettre via fetch vers l'URL de la modal
    const modalUrl = `/contact/modal/new/${clientId}`;
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            console.log('✅ Contact sauvegardé avec succès, navigation vers modification adresse...');
            
            // Émettre un événement pour notifier la page parent (mais ne pas fermer la modale)
            window.dispatchEvent(new CustomEvent('contactCreated', {
                detail: { 
                    contact: data.contact,
                    message: data.message
                }
            }));
            
            // Maintenant naviguer vers la modification d'adresse
            // Marquer qu'on ne veut PAS revenir vers la modale contact (fermer définitivement)
            if (window.MultiModalNavigationService) {
                MultiModalNavigationService.navigateToAddress({
                    mode: 'new', // Rester en mode new pour éviter réouverture en édition
                    contactId: null, // Pas de retour prévu vers modale contact
                    clientId: clientId,
                    noReturn: true // Flag pour indiquer de ne pas rouvrir après
                }, 'edit', addressId);
            }
        } else {
            console.error('❌ Erreur sauvegarde contact:', data.message);
            alert(data.message || 'Erreur lors de la sauvegarde du contact');
        }
    })
    .catch(error => {
        console.error('❌ Erreur réseau sauvegarde contact:', error);
        alert('Erreur lors de la sauvegarde du contact');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
    });
}
</script>