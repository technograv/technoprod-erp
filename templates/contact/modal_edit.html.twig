<div class="modal-header">
    <h5 class="modal-title">
        <i class="fas fa-user-edit me-2"></i>Modifier le contact "{{ contact.prenom }} {{ contact.nom }}"
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<style>
/* Fix pour Select2 dans les modals - AGRESSIF */
.modal .select2-container {
    z-index: 9999 !important;
}
.modal .select2-dropdown {
    z-index: 10000 !important;
}
.select2-container--open .select2-dropdown {
    z-index: 10001 !important;
}

/* Forcer le dropdown Select2 au-dessus de la modale mais dans la modale */
.modal .select2-dropdown {
    z-index: 1070 !important;
}
.modal .select2-container--bootstrap-5 .select2-dropdown {
    z-index: 1070 !important;
}
.modal .select2-container--open .select2-dropdown {
    z-index: 1070 !important;
}

/* Fix spécifique pour Select2 dans modale contact */
.select2-dropdown {
    z-index: 9999 !important;
}

/* S'assurer que le dropdown Select2 s'affiche dans la modale */
.modal .select2-container .select2-dropdown {
    z-index: 1070 !important;
}

/* Firefox specific fixes pour Select2 dans modales */
@-moz-document url-prefix() {
    .modal .select2-dropdown {
        z-index: 1070 !important;
        position: fixed !important;
    }
    
    .modal .select2-container--open .select2-dropdown {
        z-index: 1070 !important;
        position: fixed !important;
    }
    
    /* Forcer l'affichage du dropdown sur Firefox */
    .select2-dropdown {
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
    }
    
    /* Fix pour la position du dropdown sur Firefox */
    .modal .select2-dropdown {
        top: auto !important;
        left: auto !important;
        transform: none !important;
    }
    
    /* Classe spécifique pour Firefox Select2 */
    .firefox-select2-dropdown {
        z-index: 9999 !important;
        position: fixed !important;
        display: block !important;
    }
}


/* Gestion des modales empilées - adresse par-dessus contact */
.modal {
    z-index: 1050;
}
.modal.show {
    z-index: 1055;
}
/* Modale d'adresse au-dessus de contact */
.modal + .modal {
    z-index: 1060 !important;
}
.modal + .modal .modal-backdrop {
    z-index: 1059 !important;
}
</style>
<div class="modal-body">
    <form id="contact-form" method="POST" data-contact-id="{{ contact.id }}">
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Prénom</label>
                    <input type="text" class="form-control" name="prenom" id="contact-prenom" 
                           value="{{ contact.prenom }}">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Nom *</label>
                    <input type="text" class="form-control" name="nom" id="contact-nom" 
                           value="{{ contact.nom }}" required>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" name="email" id="contact-email" 
                           value="{{ contact.email }}">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Fonction</label>
                    <input type="text" class="form-control" name="fonction" id="contact-fonction" 
                           value="{{ contact.fonction }}" placeholder="Directeur, Commercial, Comptable...">
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Téléphone fixe</label>
                    <input type="tel" class="form-control" name="telephone" id="contact-telephone" 
                           value="{{ contact.telephone }}">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Mobile</label>
                    <input type="tel" class="form-control" name="mobile" id="contact-mobile" 
                           value="{{ contact.telephoneMobile }}">
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-12">
                <div class="mb-3">
                    <label class="form-label">Adresse associée</label>
                    <div class="d-flex align-items-center gap-2">
                        <select class="form-select" name="adresse" id="contact-adresse" style="flex-grow: 1;">
                            <option value="">-- Sélectionner une adresse --</option>
                            {% if adresses is defined and adresses is not empty %}
                                {% for adresse in adresses %}
                                    <option value="{{ adresse.id }}" 
                                            {% if contact.adresse and contact.adresse.id == adresse.id %}selected{% endif %}>
                                        {{ adresse.displayLabel }}
                                    </option>
                                {% endfor %}
                            {% else %}
                                <option value="" disabled>Aucune adresse disponible pour ce client</option>
                            {% endif %}
                        </select>
                        <!-- Boutons d'action adresse -->
                        <button type="button" class="btn btn-success btn-sm" id="add-address-btn" 
                                title="Ajouter une nouvelle adresse" data-client-id="{{ contact.client.id }}">
                            <i class="fas fa-plus"></i>
                        </button>
                        <button type="button" class="btn btn-primary btn-sm" id="edit-address-btn" 
                                title="Modifier l'adresse sélectionnée" 
                                style="{{ contact.adresse ? 'inline-block' : 'none' }}">
                            <i class="fas fa-edit"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-6">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="isFacturationDefault" 
                           id="contact-facturation-default" {% if contact.isFacturationDefault %}checked{% endif %}>
                    <label class="form-check-label" for="contact-facturation-default">
                        <i class="fas fa-file-invoice me-1"></i>Contact de facturation par défaut
                    </label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="isLivraisonDefault" 
                           id="contact-livraison-default" {% if contact.isLivraisonDefault %}checked{% endif %}>
                    <label class="form-check-label" for="contact-livraison-default">
                        <i class="fas fa-truck me-1"></i>Contact de livraison par défaut
                    </label>
                </div>
            </div>
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i>Annuler
    </button>
    <button type="button" class="btn btn-primary" id="save-contact-btn">
        <i class="fas fa-save me-1"></i>Modifier le contact
    </button>
</div>

<!-- Inclusion directe des services JavaScript (comme /devis/new) -->
<script src="/js/services/ModalDebugService.js"></script>
<script src="/js/services/ModalService.js"></script>
<script src="/js/services/MultiModalNavigationService.js"></script>
<script src="/js/services/AddressModalService.js"></script>
<script src="/js/services/ContactModalService.js"></script>

<script>
// Exécuter immédiatement (pas d'attente DOMContentLoaded car modal chargée via AJAX)
(function initContactModal() {
    console.log('🚀 Initialisation modale contact edit - début');
    
    // Services déjà chargés de manière synchrone (comme /devis/new)
    
    // Attendre un petit délai pour que le DOM soit prêt
    setTimeout(function() {
        console.log('🔧 DOM prêt et services chargés, initialisation des fonctionnalités...');
        
        // Stocker automatiquement les informations de contact pour les prochaines actions
        window.lastContactEditEvent = {
            mode: 'edit',
            contactId: '{{ contact.id }}',
            clientId: '{{ contact.client.id }}',
            fromModal: false // Par défaut, pas depuis une modale
        };
        console.log('💾 Auto-stockage info contact à l\'ouverture (EDIT):', window.lastContactEditEvent);
        
        // Gérer les boutons d'adresse
        initAddressButtons();
        
        // Charger les adresses depuis l'API pour s'assurer qu'elles sont à jour
        const currentAddressId = document.getElementById('contact-adresse').value;
        reloadAddresses(currentAddressId);
        
        // Fix spécifique Firefox : reconfigurer Select2 après un délai
        if (navigator.userAgent.toLowerCase().indexOf('firefox') > -1) {
            setTimeout(() => {
                const addressSelect = document.getElementById('contact-adresse');
                if (addressSelect && window.$ && $(addressSelect).hasClass('select2-hidden-accessible')) {
                    console.log('🔧 Firefox détecté - reconfiguration Select2...');
                    
                    const $select = $(addressSelect);
                    const currentValue = $select.val();
                    
                    // Détruire et recréer avec configuration Firefox-friendly
                    $select.select2('destroy');
                    $select.select2({
                        dropdownParent: $select.closest('.modal'),
                        width: '100%',
                        theme: 'bootstrap-5',
                        dropdownAutoWidth: false,
                        dropdownCssClass: 'firefox-select2-dropdown'
                    });
                    
                    // Restaurer la valeur
                    if (currentValue) {
                        $select.val(currentValue).trigger('change');
                    }
                    
                    console.log('✅ Select2 reconfiguré pour Firefox');
                }
            }, 200);
        }
        
        // Initialiser le formatage des numéros de téléphone
        setupPhoneFormatting();
        
        // Gérer la soumission du formulaire
        const saveBtn = document.getElementById('save-contact-btn');
        
        if (saveBtn) {
            saveBtn.addEventListener('click', function() {
                submitContactForm();
            });
        }
        
        // Permettre la soumission avec Entrée
        const contactForm = document.getElementById('contact-form');
        if (contactForm) {
            contactForm.addEventListener('submit', function(e) {
                e.preventDefault();
                submitContactForm();
            });
        }
    }, 100);
})();

function initAddressButtons() {
    console.log('🔧 initAddressButtons (EDIT) - début initialisation');
    const addressSelect = document.getElementById('contact-adresse');
    const editBtn = document.getElementById('edit-address-btn');
    const addBtn = document.getElementById('add-address-btn');
    
    console.log('🔍 Éléments boutons adresse (EDIT):', {
        addressSelect: !!addressSelect,
        editBtn: !!editBtn,
        addBtn: !!addBtn,
        editBtnVisible: editBtn ? editBtn.style.display : 'N/A',
        addBtnVisible: addBtn ? addBtn.style.display : 'N/A'
    });
    
    // Écouter les événements de création/modification d'adresse
    window.addEventListener('addressCreated', function(event) {
        console.log('🏠 Adresse créée - retour vers modale contact (EDIT):', event.detail);
        
        // Attendre que la modale adresse se ferme puis rouvrir la modale contact
        setTimeout(() => {
            console.log('🔄 Réouverture modale contact avec nouvelle adresse:', event.detail.adresse.id);
            const contactId = '{{ contact.id }}'; // Récupérer l'ID du contact depuis Twig
            const contactService = new ContactModalService({ debug: true });
            contactService.editContact(contactId);
            
            // Programmer la sélection de l'adresse après ouverture de la modale
            setTimeout(() => {
                const addressSelect = document.getElementById('contact-adresse');
                if (addressSelect) {
                    addressSelect.value = event.detail.adresse.id;
                    addressSelect.dispatchEvent(new Event('change'));
                    console.log('🎯 Adresse présélectionnée:', event.detail.adresse.id);
                }
            }, 500);
        }, 300);
    });
    
    window.addEventListener('addressUpdated', function(event) {
        console.log('🏠 Adresse modifiée - retour vers modale contact (EDIT):', event.detail);
        
        // Attendre que la modale adresse se ferme puis rouvrir la modale contact
        setTimeout(() => {
            console.log('🔄 Réouverture modale contact après modification adresse:', event.detail.adresse.id);
            const contactId = '{{ contact.id }}'; // Récupérer l'ID du contact depuis Twig
            const contactService = new ContactModalService({ debug: true });
            contactService.editContact(contactId);
            
            // Programmer la sélection de l'adresse après ouverture de la modale
            setTimeout(() => {
                const addressSelect = document.getElementById('contact-adresse');
                if (addressSelect) {
                    addressSelect.value = event.detail.adresse.id;
                    addressSelect.dispatchEvent(new Event('change'));
                    console.log('🎯 Adresse présélectionnée après modification:', event.detail.adresse.id);
                }
                
                // Nettoyer les backdrops résiduels après un délai supplémentaire
                setTimeout(() => {
                    cleanupOrphanedBackdrops();
                }, 1000);
                
                // Nettoyage supplémentaire après 2 secondes pour être sûr
                setTimeout(() => {
                    cleanupOrphanedBackdrops();
                }, 2000);
            }, 500);
        }, 300);
    });
    
    // Afficher/masquer le bouton modifier selon la sélection
    if (addressSelect) {
        console.log('✅ AddressSelect trouvé, ajout event listener change (EDIT)');
        
        // Supprimer d'éventuels anciens event listeners
        addressSelect.removeEventListener('change', handleAddressChange);
        
        // Ajouter le nouvel event listener
        addressSelect.addEventListener('change', handleAddressChange);
        
        
        // Plus besoin d'event listener Select2 car les adresses utilisent des selects normaux
        console.log('✅ Event listener standard attaché pour select normal');
        
        // Test initial de l'état
        console.log('🔍 État initial du bouton (EDIT):', {
            addressValue: addressSelect.value,
            editBtnExists: !!editBtn,
            editBtnDisplay: editBtn ? editBtn.style.display : 'N/A'
        });
    } else {
        console.log('❌ AddressSelect introuvable (EDIT)');
    }
    
    // Gérer le clic sur ajouter adresse
    if (addBtn) {
        addBtn.addEventListener('click', function() {
            console.log('🖱️ CLIC sur bouton ajouter adresse (EDIT)');
            const clientId = this.dataset.clientId;
            console.log('🔍 ClientId trouvé (EDIT):', clientId);
            console.log('🔍 AddressModalService disponible (EDIT):', !!window.AddressModalService);
            
            if (clientId && window.MultiModalNavigationService) {
                console.log('🔗 Navigation Contact → Adresse via service centralisé');
                
                // Utiliser le service centralisé de navigation
                MultiModalNavigationService.navigateToAddress({
                    mode: 'edit',
                    contactId: '{{ contact.id }}',
                    clientId: '{{ contact.client.id }}',
                    noReturn: true // Flag pour indiquer de ne pas rouvrir après
                }, 'create', clientId);
            } else {
                console.log('❌ Conditions non remplies (EDIT):', {
                    clientId: !!clientId,
                    addressService: !!window.AddressModalService
                });
            }
        });
    }
    
    // Gérer le clic sur modifier adresse
    if (editBtn) {
        console.log('✅ Bouton edit trouvé, ajout du click handler (EDIT)', {
            id: editBtn.id,
            className: editBtn.className,
            innerHTML: editBtn.innerHTML
        });
        
        // Supprimer les anciens event listeners pour éviter les doublons
        editBtn.removeEventListener('click', editAddressClickHandler);
        
        // Ajouter le nouvel event listener
        editBtn.addEventListener('click', editAddressClickHandler);
        
        console.log('✅ Event listener attaché au bouton edit address (EDIT)');
    } else {
        console.log('❌ Bouton edit address introuvable lors de initAddressButtons (EDIT)');
    }
}

// Fonction séparée pour gérer le changement d'adresse
function handleAddressChange() {
    const editBtn = document.getElementById('edit-address-btn');
    const shouldShow = this.value ? 'inline-block' : 'none';
    
    console.log('🔧 handleAddressChange appelé (EDIT):', { 
        addressValue: this.value, 
        shouldShow: shouldShow,
        buttonFound: !!editBtn,
        currentDisplay: editBtn ? editBtn.style.display : 'N/A'
    });
    
    if (editBtn) {
        editBtn.style.display = shouldShow;
        console.log('✅ Bouton edit mis à jour (EDIT):', editBtn.style.display);
    } else {
        console.log('❌ EditBtn introuvable lors du changement (EDIT)');
    }
}

// Fonction séparée pour le click handler du bouton edit
function editAddressClickHandler(e) {
    // Protection contre les appels multiples
    if (window.editAddressInProgress) {
        console.log('🚫 Action déjà en cours, ignoré');
        return;
    }
    
    window.editAddressInProgress = true;
    console.log('🖱️ CLIC sur bouton modifier adresse (EDIT) - HANDLER APPELÉ');
    
    // Empêcher la propagation si c'est un vrai event
    if (e) {
        e.preventDefault();
        e.stopPropagation();
    }
    
    const addressSelect = document.getElementById('contact-adresse');
    const addressId = addressSelect?.value;
    
    console.log('🔍 AddressId trouvé (EDIT):', addressId);
    console.log('🔍 AddressModalService disponible (EDIT):', !!window.AddressModalService);
    console.log('🔍 Address select element:', !!addressSelect);
    console.log('🔍 Address select value:', addressSelect?.value);
    
    if (addressId && window.AddressModalService) {
        console.log('💾 Sauvegarde du contact avant ouverture modale adresse...');
        
        // Sauvegarder d'abord le contact avant d'ouvrir la modale d'adresse
        saveContactBeforeAddressModal(addressId);
    } else {
        console.log('❌ Conditions non remplies (EDIT):', {
            addressId: !!addressId,
            addressIdValue: addressId,
            addressService: !!window.AddressModalService,
            addressSelect: !!addressSelect
        });
        
        if (!addressId) {
            alert('Veuillez d\'abord sélectionner une adresse à modifier');
        } else if (!window.AddressModalService) {
            alert('Service d\'adresse non disponible. Veuillez réessayer.');
        }
    }
}

function reloadAddresses(selectedAddressId = null) {
    console.log('🔄 reloadAddresses (EDIT) appelé avec selectedAddressId:', selectedAddressId);
    
    const addressSelect = document.getElementById('contact-adresse');
    const clientId = document.getElementById('add-address-btn')?.dataset.clientId || '{{ client.id }}'; // Fallback Twig
    
    console.log('🔍 Éléments trouvés (EDIT):', {
        addressSelect: !!addressSelect,
        clientId: clientId,
        addBtn: !!document.getElementById('add-address-btn'),
        'form contactId': document.getElementById('contact-form')?.dataset.contactId
    });
    
    // Essayer plusieurs sources pour le clientId
    const finalClientId = clientId || document.getElementById('contact-form')?.dataset.contactId;
    
    if (!addressSelect || !finalClientId) {
        console.error('❌ reloadAddresses (EDIT): Éléments manquants', { 
            addressSelect: !!addressSelect, 
            clientId: clientId,
            finalClientId: finalClientId,
            formElement: !!document.getElementById('contact-form')
        });
        return;
    }
    
    const apiUrl = `/client/${finalClientId}/addresses`;
    console.log('📡 Appel API adresses (EDIT):', apiUrl);
    
    // Charger les adresses via API
    fetch(apiUrl)
        .then(response => {
            console.log('📡 Réponse API adresses (EDIT):', response.status, response.statusText);
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            return response.json();
        })
        .then(addresses => {
            console.log('📊 Adresses reçues (EDIT):', addresses);
            
            // Vider et repeupler le select
            addressSelect.innerHTML = '<option value="">-- Sélectionner une adresse --</option>';
            
            if (addresses && addresses.length > 0) {
                addresses.forEach(address => {
                    const option = document.createElement('option');
                    option.value = address.id;
                    option.textContent = address.label;
                    if (selectedAddressId && address.id == selectedAddressId) {
                        option.selected = true;
                    }
                    addressSelect.appendChild(option);
                });
            } else {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Aucune adresse disponible pour ce client';
                option.disabled = true;
                addressSelect.appendChild(option);
            }
            
            // 🔧 Mettre à jour Select2 SEULEMENT s'il existe déjà
            if (window.$ && $(addressSelect).hasClass('select2-hidden-accessible')) {
                console.log('🔧 Rafraîchissement Select2 existant (EDIT) pour', addressSelect.id);
                
                try {
                    const $select = $(addressSelect);
                    
                    // Re-sélectionner l'adresse si nécessaire
                    if (selectedAddressId) {
                        console.log('🎯 Sélection adresse:', selectedAddressId);
                        $select.val(selectedAddressId).trigger('change');
                    }
                    
                    console.log('✅ Select2 (EDIT) mis à jour');
                } catch (e) {
                    console.error('❌ Erreur mise à jour Select2 (EDIT):', e);
                }
            }
            
            // Mettre à jour le bouton d'édition
            const editBtn = document.getElementById('edit-address-btn');
            if (editBtn) {
                const shouldShow = addressSelect.value ? 'inline-block' : 'none';
                console.log('🔧 Mise à jour bouton edit adresse (EDIT):', { 
                    addressValue: addressSelect.value, 
                    shouldShow: shouldShow,
                    currentDisplay: editBtn.style.display 
                });
                editBtn.style.display = shouldShow;
            } else {
                console.log('❌ Bouton edit-address-btn introuvable (EDIT)');
            }
        })
        .catch(error => {
            console.error('Erreur rechargement adresses:', error);
            addressSelect.innerHTML = '<option value="">-- Erreur chargement adresses --</option>';
        });
}

function saveContactBeforeAddressModal(addressId) {
    console.log('💾 Début sauvegarde contact avant ouverture modale adresse:', addressId);
    
    const form = document.getElementById('contact-form');
    const formData = new FormData(form);
    
    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    
    if (!nom) {
        alert('Le nom est obligatoire pour sauvegarder le contact');
        return;
    }
    
    // Soumettre via fetch vers l'URL de la modal
    const contactId = document.querySelector('#contact-form').dataset.contactId || '{{ contact.id }}';
    const modalUrl = `/contact/modal/edit/${contactId}`;
    
    console.log('📤 Envoi de la sauvegarde contact...');
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            console.log('✅ Contact sauvegardé avec succès, ouverture modale adresse...');
            
            // Émettre un événement pour notifier la page parent (sans fermer la modale)
            window.dispatchEvent(new CustomEvent('contactUpdated', {
                detail: { 
                    contact: data.contact,
                    message: data.message
                }
            }));
            
            // Maintenant ouvrir la modale d'adresse
            openAddressModalAfterSave(addressId);
        } else {
            console.error('❌ Erreur sauvegarde contact:', data.message);
            alert(data.message || 'Erreur lors de la sauvegarde du contact');
            window.editAddressInProgress = false; // Réinitialiser le flag
        }
    })
    .catch(error => {
        console.error('❌ Erreur réseau sauvegarde contact:', error);
        alert('Erreur lors de la sauvegarde du contact');
        window.editAddressInProgress = false; // Réinitialiser le flag
    });
}

function openAddressModalAfterSave(addressId) {
    console.log('🔗 Navigation Contact → Adresse (EDIT) via service centralisé pour:', addressId);
    
    // Utiliser le service centralisé de navigation
    if (window.MultiModalNavigationService) {
        MultiModalNavigationService.navigateToAddress({
            mode: 'edit',
            contactId: '{{ contact.id }}',
            clientId: '{{ contact.client.id }}',
            noReturn: true // Flag pour indiquer de ne pas rouvrir après
        }, 'edit', addressId);
    } else {
        console.error('❌ MultiModalNavigationService non disponible');
        alert('Erreur: Service de navigation non disponible. Veuillez réessayer.');
        window.editAddressInProgress = false;
    }
}

function submitContactForm() {
    const form = document.getElementById('contact-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-contact-btn');
    
    // Validation côté client
    const nom = (formData.get('nom') || '').trim();
    
    if (!nom) {
        alert('Le nom est obligatoire');
        return;
    }
    
    // Désactiver le bouton pendant la soumission
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Modification...';
    
    // Soumettre via fetch vers l'URL de la modal
    const contactId = document.querySelector('#contact-form').dataset.contactId || '{{ contact.id }}';
    const modalUrl = `/contact/modal/edit/${contactId}`;
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Émettre un événement pour notifier la page parent
            window.dispatchEvent(new CustomEvent('contactUpdated', {
                detail: { 
                    contact: data.contact,
                    message: data.message
                }
            }));
            
            // Fermer la modale
            const modal = bootstrap.Modal.getInstance(document.querySelector('.modal'));
            if (modal) {
                modal.hide();
                
                // Nettoyer les backdrops après fermeture de la modale contact
                setTimeout(() => {
                    cleanupOrphanedBackdrops();
                }, 500);
            }
        } else {
            alert(data.message || 'Erreur lors de la modification du contact');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur lors de la modification du contact');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-save me-1"></i>Modifier le contact';
    });
}

// ==================================
// FORMATAGE DES NUMÉROS DE TÉLÉPHONE
// ==================================

function formatPhoneNumber(value) {
    // Supprimer tous les caractères non numériques
    const numbers = value.replace(/\D/g, '');
    
    // Limiter à 10 chiffres pour la France
    const limited = numbers.substring(0, 10);
    
    // Formater en groupes de 2 chiffres (format français)
    if (limited.length === 0) return '';
    
    const formatted = limited.match(/.{1,2}/g);
    return formatted ? formatted.join(' ') : limited;
}

function setupPhoneFormatting() {
    console.log('📞 Configuration formatage téléphones (modale contact edit)');
    
    // Sélectionner tous les champs téléphone
    const phoneFields = document.querySelectorAll('input[type="tel"], input[name*="telephone"], input[name*="phone"], input[id*="telephone"], input[name*="mobile"]');
    
    phoneFields.forEach(field => {
        field.addEventListener('input', function(e) {
            const cursorPos = this.selectionStart;
            const oldValue = this.value;
            const newValue = formatPhoneNumber(this.value);
            
            this.value = newValue;
            
            // Ajuster la position du curseur
            if (newValue.length > oldValue.length) {
                this.setSelectionRange(cursorPos + 1, cursorPos + 1);
            } else {
                this.setSelectionRange(cursorPos, cursorPos);
            }
        });
        
        // Formater à la perte de focus aussi
        field.addEventListener('blur', function() {
            this.value = formatPhoneNumber(this.value);
        });
    });
}

// Fonction de nettoyage des backdrops orphelins
function cleanupOrphanedBackdrops() {
    console.log('🧹 Nettoyage des backdrops résiduels...');
    
    // Supprimer le CSS forcé qui pourrait causer des problèmes
    const forcedStyle = document.getElementById('force-backdrop-style');
    if (forcedStyle) {
        console.log('🗑️ Suppression du CSS forcé pour backdrop');
        forcedStyle.remove();
    }
    
    // Vérifier s'il y a des modales ouvertes
    const openModals = document.querySelectorAll('.modal.show');
    const allBackdrops = document.querySelectorAll('.modal-backdrop');
    
    console.log('🔍 État des modales:', {
        openModals: openModals.length,
        backdrops: allBackdrops.length,
        modalOpenClass: document.body.classList.contains('modal-open')
    });
    
    // Log détaillé de tous les backdrops trouvés
    allBackdrops.forEach((backdrop, index) => {
        console.log(`🔍 Backdrop ${index + 1}:`, {
            className: backdrop.className,
            style: backdrop.getAttribute('style'),
            parent: backdrop.parentElement?.tagName
        });
    });
    
    // NETTOYAGE AGRESSIF : Supprimer TOUS les backdrops s'il n'y a aucune modale ouverte
    if (openModals.length === 0) {
        console.log('🧹 NETTOYAGE AGRESSIF - Aucune modale ouverte, suppression de TOUS les backdrops');
        
        // Supprimer tous les backdrops, même ceux avec des classes différentes
        const allPossibleBackdrops = document.querySelectorAll('[class*="modal-backdrop"], .modal-backdrop');
        allPossibleBackdrops.forEach((backdrop, index) => {
            console.log(`🗑️ Suppression backdrop ${index + 1} (agressif):`, backdrop.className);
            backdrop.remove();
        });
        
        // Restaurer complètement l'état du body
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('padding-right');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('margin-right');
        
        // Forcer la suppression de tout style inline qui pourrait rester
        if (document.body.style.paddingRight) {
            document.body.style.paddingRight = '';
        }
        if (document.body.style.overflow) {
            document.body.style.overflow = '';
        }
        
        console.log('✅ Nettoyage agressif terminé - TOUS les backdrops supprimés et body complètement restauré');
        
        // Vérification finale
        const remainingBackdrops = document.querySelectorAll('[class*="modal-backdrop"], .modal-backdrop');
        console.log('🔍 Vérification finale - backdrops restants:', remainingBackdrops.length);
        
    } else if (openModals.length === 1 && allBackdrops.length > 1) {
        // Une seule modale ouverte mais plusieurs backdrops - garder le premier, supprimer les autres
        console.log('🧹 Une modale ouverte mais', allBackdrops.length, 'backdrops - nettoyage des surplus');
        
        for (let i = 1; i < allBackdrops.length; i++) {
            console.log(`🗑️ Suppression backdrop excédentaire ${i + 1}`);
            allBackdrops[i].remove();
        }
        
        console.log('✅ Backdrops excédentaires supprimés');
    } else {
        console.log('✅ Aucun nettoyage nécessaire');
    }
}
</script>