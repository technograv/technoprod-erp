{# Styles CSS pour les éditeurs WYSIWYG des notes - Réutilisable #}
<style>
/* Styles pour les éditeurs WYSIWYG des notes - identique à new.html.twig */
#toolbar-note-publique .ql-font .ql-picker,
#toolbar-note-privee .ql-font .ql-picker {
    min-width: 180px !important;
    width: 180px !important;
    max-width: 180px !important;
}

#toolbar-note-publique .ql-size .ql-picker,
#toolbar-note-privee .ql-size .ql-picker {
    min-width: 140px !important;
    width: 140px !important;
    max-width: 140px !important;
}

#toolbar-note-publique .ql-font .ql-picker-label,
#toolbar-note-publique .ql-size .ql-picker-label,
#toolbar-note-privee .ql-font .ql-picker-label,
#toolbar-note-privee .ql-size .ql-picker-label {
