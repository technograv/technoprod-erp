    width: 180px !important;
}

/* Forcer la largeur avec une approche CSS plus agressive */
#toolbar-note-publique span.ql-picker[class*="ql-font"],
#toolbar-note-privee span.ql-picker[class*="ql-font"] {
    width: 180px !important;
    min-width: 180px !important;
}

