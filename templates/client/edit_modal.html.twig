{# Template simplifié pour l'édition client en modale #}

<style>
    .form-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid #e9ecef;
    }
    
    .section-title {
        color: #495057;
        font-weight: 600;
        margin-bottom: 1rem;
        font-size: 1.1rem;
    }
    
    .btn-add {
        background: #28a745;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 500;
    }
    
    .btn-add:hover {
        background: #218838;
        color: white;
    }
</style>

<div class="container-fluid">
    <form method="post" action="{{ path('app_client_edit', {'id': client.id}) }}?modal=1">
        
        {# Section informations principales #}
        <div class="form-section">
            <div class="section-title">
                <i class="fas fa-building me-2"></i>Informations principales
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="nom" class="form-label">Dénomination *</label>
                        <input type="text" class="form-control" id="nom" name="nom" 
                               value="{{ client.nom }}" required>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="code" class="form-label">Code</label>
                        <input type="text" class="form-control" id="code" name="code" 
                               value="{{ client.code }}" readonly>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" 
                               value="{{ client.email }}">
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="telephone" class="form-label">Téléphone</label>
                        <input type="tel" class="form-control" id="telephone" name="telephone" 
                               value="{{ client.telephone }}">
                    </div>
                </div>
            </div>
        </div>
        
        {# Section adresse principale si elle existe #}
        {% set adressePrincipale = null %}
        {% for adresse in client.adresses %}
            {% if adresse.nom == 'Siège social' or loop.first %}
                {% set adressePrincipale = adresse %}
            {% endif %}
        {% endfor %}
        
        {% if adressePrincipale %}
        <div class="form-section">
            <div class="section-title">
                <i class="fas fa-map-marker-alt me-2"></i>Adresse principale
            </div>
            
            <div class="row">
                <div class="col-md-12">
                    <div class="mb-3">
                        <label class="form-label">Adresse</label>
                        <input type="text" class="form-control" name="adresse_ligne1" 
                               value="{{ adressePrincipale.ligne1 }}">
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Code postal</label>
                        <input type="text" class="form-control" name="adresse_code_postal" 
                               value="{{ adressePrincipale.codePostal }}" maxlength="5">
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Ville</label>
                        <input type="text" class="form-control" name="adresse_ville" 
                               value="{{ adressePrincipale.ville }}">
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
        
        {# Section contacts #}
        <div class="form-section">
            <div class="section-title">
                <i class="fas fa-users me-2"></i>Contacts
            </div>
            
            {% if client.contacts|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Email</th>
                                <th>Téléphone</th>
                                <th>Fonction</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for contact in client.contacts %}
                                <tr>
                                    <td>
                                        {% if contact.prenom %}{{ contact.prenom }} {% endif %}{{ contact.nom }}
                                        {% if contact.isFacturationDefault %}
                                            <span class="badge bg-primary">Fact.</span>
                                        {% endif %}
                                        {% if contact.isLivraisonDefault %}
                                            <span class="badge bg-success">Livr.</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ contact.email }}</td>
                                    <td>{{ contact.telephone }}</td>
                                    <td>{{ contact.fonction }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted">Aucun contact enregistré</p>
            {% endif %}
        </div>
        
        {# Section adresses #}
        <div class="form-section">
            <div class="section-title">
                <i class="fas fa-map-marker-alt me-2"></i>Adresses
            </div>
            
            {% if client.adresses|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Adresse</th>
                                <th>Code postal</th>
                                <th>Ville</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for adresse in client.adresses %}
                                <tr>
                                    <td>{{ adresse.nom }}</td>
                                    <td>{{ adresse.ligne1 }}</td>
                                    <td>{{ adresse.codePostal }}</td>
                                    <td>{{ adresse.ville }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted">Aucune adresse enregistrée</p>
            {% endif %}
        </div>
        
        {# Boutons #}
        <div class="d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-2"></i>Enregistrer
            </button>
        </div>
        
    </form>
</div>

<script>
// Initialiser Select2 si disponible
if (window.$ && typeof $.fn.select2 !== 'undefined') {
    $('.form-select').select2();
}
</script>