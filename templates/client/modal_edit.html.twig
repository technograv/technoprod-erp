<div class="modal-header">
    <h5 class="modal-title">
        <i class="fas fa-user-edit me-2"></i>Modifier {{ client.nomEntreprise ?: (client.prenom ~ ' ' ~ client.nom) }}
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <form id="client-form" method="POST" data-client-id="{{ client.id }}">
    <!-- Code client (lecture seule) -->
    <div class="row">
        <div class="col-12">
            <div class="mb-3">
                <label class="form-label">Code client</label>
                <input type="text" class="form-control" value="{{ client.code }}" readonly disabled>
            </div>
        </div>
    </div>
    
    <!-- Forme juridique (modifiable avec restrictions) -->
    <div class="row">
        <div class="col-12">
            <div class="mb-3">
                <label class="form-label">Forme juridique <span class="text-danger">*</span></label>
                <select class="form-control" name="formeJuridique" id="forme-juridique-select" required>
                    <option value="">Sélectionner une forme juridique...</option>
                    {% for forme in formes_juridiques %}
                        {# Restriction : si client actuel est personne morale, ne pas permettre personne physique #}
                        {% set disabled = client.formeJuridique and 
                                         client.formeJuridique.templateFormulaire == 'personne_morale' and 
                                         forme.templateFormulaire == 'personne_physique' %}
                        
                        <option value="{{ forme.id }}" 
                                {{ client.formeJuridique and client.formeJuridique.id == forme.id ? 'selected' : '' }}
                                {{ disabled ? 'disabled' : '' }}
                                data-template="{{ forme.templateFormulaire }}">
                            {{ forme.nom }}{{ disabled ? ' (non autorisé)' : '' }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>
    
    <!-- Dénomination (selon le type) -->
    {% if client.formeJuridique and client.formeJuridique.templateFormulaire == 'personne_morale' %}
        <!-- Pour les entreprises -->
        <div class="row">
            <div class="col-12">
                <div class="mb-3">
                    <label class="form-label">Dénomination sociale <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="nomEntreprise" id="client-nom-entreprise" 
                           value="{{ client.nomEntreprise }}" placeholder="Nom de l'entreprise, raison sociale...">
                </div>
            </div>
        </div>
    {% else %}
        <!-- Pour les particuliers -->
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Prénom <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="prenom" id="client-prenom" 
                           value="{{ client.prenom }}" placeholder="Prénom">
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Nom <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="nom" id="client-nom" 
                           value="{{ client.nom }}" placeholder="Nom de famille">
                </div>
            </div>
        </div>
    {% endif %}
        
        <!-- Email et téléphone uniquement pour les particuliers -->
        {% if client.formeJuridique and client.formeJuridique.templateFormulaire == 'personne_physique' %}
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" id="client-email" 
                               value="{{ client.email }}">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Téléphone</label>
                        <input type="tel" class="form-control" name="telephone" id="client-telephone" 
                               value="{{ client.telephone }}">
                    </div>
                </div>
            </div>
        {% endif %}
    
    <!-- Notes et observations -->
    <div class="row">
        <div class="col-12">
            <div class="mb-3">
                <label class="form-label">Notes et observations</label>
                <textarea class="form-control" name="notes" id="client-notes" rows="3" 
                          placeholder="Informations complémentaires, remarques particulières...">{{ client.notes }}</textarea>
            </div>
        </div>
    </div>
</form>
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i>Annuler
    </button>
    <button type="button" class="btn btn-primary" id="save-client-btn">
        <i class="fas fa-save me-1"></i>Modifier le client
    </button>
</div>

<script>
// Exécuter immédiatement (pas d'attente DOMContentLoaded car modal chargée via AJAX)
(function() {
    // Attendre un petit délai pour que le DOM soit prêt
    setTimeout(function() {
        // Gérer la soumission du formulaire
        const saveBtn = document.getElementById('save-client-btn');
        
        if (saveBtn) {
            saveBtn.addEventListener('click', function() {
                submitClientForm();
            });
        }
        
        // Permettre la soumission avec Entrée
        const clientForm = document.getElementById('client-form');
        if (clientForm) {
            clientForm.addEventListener('submit', function(e) {
                e.preventDefault();
                submitClientForm();
            });
        }
        
        // Gérer le changement de forme juridique
        const formeJuridiqueSelect = document.getElementById('forme-juridique-select');
        if (formeJuridiqueSelect) {
            formeJuridiqueSelect.addEventListener('change', function() {
                updateFormFields();
            });
        }
        
        // Fonction pour mettre à jour les champs selon la forme juridique
        function updateFormFields() {
            const selectedOption = formeJuridiqueSelect.options[formeJuridiqueSelect.selectedIndex];
            const templateType = selectedOption ? selectedOption.getAttribute('data-template') : null;
            
            // Mise à jour dynamique des champs selon la forme juridique
        }
    }, 100);
})();

function submitClientForm() {
    const form = document.getElementById('client-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-client-btn');
    
    // Validation côté client
    const nomEntreprise = (formData.get('nomEntreprise') || '').trim();
    const nom = (formData.get('nom') || '').trim();
    
    if (!nomEntreprise && !nom) {
        alert('Veuillez renseigner au moins le nom de l\'entreprise ou le nom de la personne');
        return;
    }
    
    // Désactiver le bouton pendant la soumission
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Modification...';
    
    // Soumettre via fetch vers l'URL de la modal
    const modalUrl = `/client/modal/edit/${document.querySelector('#client-form').dataset.clientId || '{{ client.id }}'}`;
    
    fetch(modalUrl, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Debug du client modifié
            console.log('📝 Client modifié - Données reçues du serveur:', data.client);
            
            // Émettre un événement pour notifier la page parent
            window.dispatchEvent(new CustomEvent('clientUpdated', {
                detail: { 
                    client: data.client,
                    message: data.message
                }
            }));
            
            // Fermer la modale
            const modal = bootstrap.Modal.getInstance(document.querySelector('.modal'));
            if (modal) {
                modal.hide();
            }
        } else {
            alert(data.message || 'Erreur lors de la modification');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur lors de la modification');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-save me-1"></i>Modifier le client';
    });
}
</script>