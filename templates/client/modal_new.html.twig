<div class="modal-header">
    <h5 class="modal-title">
        <i class="fas fa-user-plus me-2"></i>Créer un client
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <form id="client-form" method="POST">
        <!-- Sélection forme juridique -->
        <div class="mb-4">
            <label class="form-label fw-bold">Forme juridique <span class="text-danger">*</span></label>
            <select class="form-control" name="formeJuridique" id="forme-juridique-select" required>
                <option value="">Sélectionner une forme juridique...</option>
                {% for forme in formes_juridiques %}
                    <option value="{{ forme.id }}" 
                            data-template="{{ forme.templateFormulaire }}"
                            {% if forme.formeParDefaut %}selected{% endif %}>
                        {{ forme.nom }}
                    </option>
                {% endfor %}
            </select>
            <small class="form-text text-muted">
                Sélectionnez la forme juridique pour adapter le formulaire
            </small>
        </div>

        <!-- Template pour personne physique (Particulier) -->
        <div id="template-particulier" style="display: none;">
            <h6><i class="fas fa-user me-2"></i>Informations personnelles</h6>
            <div class="row">
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Civilité <span class="text-danger">*</span></label>
                        <select class="form-select" name="civilite" id="client-civilite">
                            <option value="">--</option>
                            <option value="M.">M.</option>
                            <option value="Mme">Mme</option>
                            <option value="Mlle">Mlle</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="mb-3">
                        <label class="form-label">Nom <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="nom" id="client-nom-particulier" 
                               placeholder="Nom de famille">
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="mb-3">
                        <label class="form-label">Prénom <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="prenom" id="client-prenom-particulier" 
                               placeholder="Prénom">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" id="client-email-particulier" 
                               placeholder="email@exemple.fr">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Téléphone</label>
                        <input type="tel" class="form-control" name="telephone" id="client-telephone-particulier" 
                               placeholder="01 23 45 67 89">
                    </div>
                </div>
            </div>
        </div>

        <!-- Template pour personne morale (Entreprise) -->
        <div id="template-entreprise" style="display: none;">
            <h6><i class="fas fa-building me-2"></i>Informations entreprise</h6>
            <div class="row">
                <div class="col-12">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Dénomination sociale <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="nomEntreprise" id="client-nom-entreprise" 
                               placeholder="Nom de l'entreprise, raison sociale...">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" id="client-email-entreprise" 
                               placeholder="contact@entreprise.fr">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Téléphone</label>
                        <input type="tel" class="form-control" name="telephone" id="client-telephone-entreprise" 
                               placeholder="01 23 45 67 89">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">SIRET</label>
                        <input type="text" class="form-control" name="siret" id="client-siret" 
                               maxlength="14" placeholder="12345678901234">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">N° TVA Intra</label>
                        <input type="text" class="form-control" name="tvaIntra" id="client-tva-intra" 
                               placeholder="FR12345678901">
                    </div>
                </div>
            </div>
        </div>
        
        <div class="alert alert-info mt-3">
            <i class="fas fa-info-circle me-2"></i>
            Le code client sera généré automatiquement à la création.
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="fas fa-times me-1"></i>Annuler
    </button>
    <button type="button" class="btn btn-success" id="save-client-btn">
        <i class="fas fa-plus me-1"></i>Créer le client
    </button>
</div>

<script>
// Fonction d'initialisation pour la modale
function initClientModalForm() {
    console.log('🚀 Initialisation du formulaire client modal');
    
    // Gérer le changement de forme juridique
    const formeJuridiqueSelect = document.getElementById('forme-juridique-select');
    const templateParticulier = document.getElementById('template-particulier');
    const templateEntreprise = document.getElementById('template-entreprise');
    
    if (!formeJuridiqueSelect) {
        console.error('❌ Sélecteur forme juridique non trouvé');
        return;
    }
    
    console.log('✅ Éléments trouvés:', {
        formeJuridiqueSelect,
        templateParticulier,
        templateEntreprise
    });
    
    function updateTemplate() {
        const selectedOption = formeJuridiqueSelect.options[formeJuridiqueSelect.selectedIndex];
        const templateType = selectedOption ? selectedOption.getAttribute('data-template') : null;
        
        console.log('🔄 updateTemplate appelée');
        console.log('📋 Option sélectionnée:', selectedOption ? selectedOption.text : 'aucune');
        console.log('🎯 Template type:', templateType);
        
        // Masquer tous les templates
        templateParticulier.style.display = 'none';
        templateEntreprise.style.display = 'none';
        
        // Réinitialiser tous les champs requis
        document.querySelectorAll('#template-particulier [required], #template-entreprise [required]').forEach(field => {
            field.removeAttribute('required');
        });
        
        if (templateType === 'personne_physique') { // Particulier
            templateParticulier.style.display = 'block';
            // Rendre les champs requis
            document.getElementById('client-civilite').setAttribute('required', 'required');
            document.getElementById('client-nom-particulier').setAttribute('required', 'required');
            document.getElementById('client-prenom-particulier').setAttribute('required', 'required');
        } else if (templateType === 'personne_morale') { // Entreprise
            templateEntreprise.style.display = 'block';
            // Rendre les champs requis
            document.getElementById('client-nom-entreprise').setAttribute('required', 'required');
        }
    }
    
    console.log('🔧 Attachement événement change sur:', formeJuridiqueSelect);
    formeJuridiqueSelect.addEventListener('change', function(e) {
        console.log('📡 Événement change déclenché:', e.target.value);
        updateTemplate();
    });
    
    // Gérer la soumission du formulaire
    document.getElementById('save-client-btn').addEventListener('click', function() {
        submitClientForm();
    });
    
    // Permettre la soumission avec Entrée
    document.getElementById('client-form').addEventListener('submit', function(e) {
        e.preventDefault();
        submitClientForm();
    });
    
    // Formater le SIRET automatiquement
    const siretField = document.getElementById('client-siret');
    if (siretField) {
        siretField.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length > 14) value = value.substr(0, 14);
            e.target.value = value;
        });
    }
});

function submitClientForm() {
    const form = document.getElementById('client-form');
    const formData = new FormData(form);
    const submitBtn = document.getElementById('save-client-btn');
    
    // Validation côté client
    const formeJuridique = formData.get('formeJuridique');
    
    if (!formeJuridique) {
        alert('Veuillez sélectionner une forme juridique');
        return;
    }
    
    // Récupérer le type de template de l'option sélectionnée
    const selectedOption = formeJuridiqueSelect.options[formeJuridiqueSelect.selectedIndex];
    const templateType = selectedOption ? selectedOption.getAttribute('data-template') : null;
    
    if (templateType === 'personne_physique') { // Particulier
        const nom = formData.get('nom')?.trim();
        const prenom = formData.get('prenom')?.trim();
        const civilite = formData.get('civilite');
        
        if (!nom || !prenom || !civilite) {
            alert('Pour un particulier, la civilité, le nom et le prénom sont obligatoires');
            return;
        }
    } else if (templateType === 'personne_morale') { // Entreprise
        const nomEntreprise = formData.get('nomEntreprise')?.trim();
        
        if (!nomEntreprise) {
            alert('Pour une entreprise, la dénomination sociale est obligatoire');
            return;
        }
    }
    
    // Désactiver le bouton pendant la soumission
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Création...';
    
    // Soumettre via fetch
    fetch(window.location.href, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Émettre un événement pour notifier la page parent
            window.dispatchEvent(new CustomEvent('clientCreated', {
                detail: { 
                    client: data.client,
                    message: data.message
                }
            }));
            
            // Fermer la modale
            const modal = bootstrap.Modal.getInstance(document.querySelector('.modal'));
            if (modal) {
                modal.hide();
            }
        } else {
            alert(data.message || 'Erreur lors de la création');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Erreur lors de la création');
    })
    .finally(() => {
        // Réactiver le bouton
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-plus me-1"></i>Créer le client';
    });
}

// Initialiser immédiatement et avec des délais pour s'assurer que tout est chargé
initClientModalForm();

// Aussi essayer après un court délai au cas où
setTimeout(initClientModalForm, 100);
setTimeout(initClientModalForm, 500);
</script>