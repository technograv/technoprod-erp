<?php

/**
 * Template pour fichiers de debug sécurisés
 * 
 * Usage: Copiez ce fichier vers un nouveau nom (ex: debug_mon_probleme.php)
 * et adaptez le code selon vos besoins
 * 
 * IMPORTANT: Ne jamais commiter les fichiers de debug !
 * Les patterns debug_*.php sont dans le .gitignore
 */

require_once __DIR__ . '/vendor/autoload.php';

use App\Entity\Secteur;
use App\Entity\AttributionSecteur;  
use App\Entity\DivisionAdministrative;
use Doctrine\ORM\EntityManager;
use Doctrine\ORM\Tools\Setup;
use Doctrine\DBAL\DriverManager;

// ✅ CONFIGURATION SÉCURISÉE: Utilise les variables d'environnement
$config = Setup::createAttributeMetadataConfiguration([__DIR__ . '/src'], true);

// Lecture des paramètres depuis .env
$dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
$dotenv->load();

$connectionParams = [
    'driver'   => 'pdo_pgsql',
    'host'     => $_ENV['DATABASE_HOST'] ?? 'localhost',
    'dbname'   => $_ENV['DATABASE_NAME'] ?? 'technoprod',
    'user'     => $_ENV['DATABASE_USER'] ?? 'postgres',
    'password' => $_ENV['DATABASE_PASSWORD'] ?? '',  // ✅ Jamais de mot de passe hardcodé !
];

try {
    $connection = DriverManager::getConnection($connectionParams);
    $entityManager = new EntityManager($connection, $config);
    
    echo "=== SCRIPT DE DEBUG SÉCURISÉ ===\n\n";
    
    // Votre code de debug ici...
    
    echo "Script terminé avec succès.\n";
    
} catch (\Exception $e) {
    echo "❌ Erreur: " . $e->getMessage() . "\n";
    exit(1);
}